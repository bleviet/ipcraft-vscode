{# VHDL AXI-Lite Bus Wrapper Template #}
{# Generates AXI-Lite slave interface with register decoding #}
--------------------------------------------------------------------------------
-- Entity: {{ entity_name }}_axil
-- Description: AXI-Lite slave interface for register access
-- Generated by ipcraft VHDL Generator
--
-- Register Map:
{% for reg in registers %}
--   {{ "0x%04X" | format(loop.index0 * reg_width) }} : {{ reg.name }} ({{ reg.access }})
{% endfor %}
--------------------------------------------------------------------------------

library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

use work.{{ entity_name }}_pkg.all;

entity {{ entity_name }}_axil is
  port (
    -- Clock and reset
    clk : in std_logic;
    rst : in std_logic;

{% if bus_ports | length > 0 %}
    -- AXI-Lite Slave Interface
{% for port in bus_ports %}
    {{ "%-14s"|format(port.name) }} : {{ "%-3s"|format(port.direction) }} {{ port.type }}{{ ";" if not loop.last else "" }}
{% endfor %}
    ;
{% endif %}

    -- Register interface
    regs_out : out t_regs_sw2hw;  -- To core (SW-writable)
    regs_in  : in  t_regs_hw2sw   -- From core (HW-writable)
  );
end entity {{ entity_name }}_axil;

architecture rtl of {{ entity_name }}_axil is

  -- AXI-Lite response constants
  constant C_RESP_OKAY   : std_logic_vector(1 downto 0) := "00";
  constant C_RESP_SLVERR : std_logic_vector(1 downto 0) := "10";

  -- AXI internal signals
  signal awaddr  : std_logic_vector(C_ADDR_WIDTH - 1 downto 0) := (others => '0');
  signal awready : std_logic                                    := '0';
  signal wready  : std_logic                                    := '0';
  signal bresp   : std_logic_vector(1 downto 0)                 := C_RESP_OKAY;
  signal bvalid  : std_logic                                    := '0';
  signal araddr  : std_logic_vector(C_ADDR_WIDTH - 1 downto 0) := (others => '0');
  signal arready : std_logic                                    := '0';
  signal rdata   : std_logic_vector(C_DATA_WIDTH - 1 downto 0) := (others => '0');
  signal rresp   : std_logic_vector(1 downto 0)                 := C_RESP_OKAY;
  signal rvalid  : std_logic                                    := '0';
  signal awvalid : std_logic                                    := '0';
  signal wvalid  : std_logic                                    := '0';
  signal arvalid : std_logic                                    := '0';
  signal rready  : std_logic                                    := '0';
  signal wdata   : std_logic_vector(C_DATA_WIDTH - 1 downto 0) := (others => '0');
  signal wstrb   : std_logic_vector((C_DATA_WIDTH/8) - 1 downto 0) := (others => '0');
  signal bready  : std_logic                                    := '0';

  -- Register bank interface signals
  signal wr_en     : std_logic;
  signal wr_addr   : std_logic_vector(C_ADDR_WIDTH-1 downto 0);
  signal wr_data   : std_logic_vector(C_DATA_WIDTH-1 downto 0);
  signal wr_strb   : std_logic_vector((C_DATA_WIDTH/8)-1 downto 0);
  signal rd_en     : std_logic;
  signal rd_addr   : std_logic_vector(C_ADDR_WIDTH-1 downto 0);
  signal rd_data   : std_logic_vector(C_DATA_WIDTH-1 downto 0);
  signal rd_valid  : std_logic;

  -- Write transaction tracking using VHDL 2008 records
  type t_write_transaction is record
    aw_en         : std_logic; -- Address write enable flag
    addr_received : std_logic; -- Address has been received
    data_received : std_logic; -- Data has been received
  end record t_write_transaction;

  signal write_txn : t_write_transaction := ('1', '0', '0');

begin

  ----------------------------------------------------------------------------
  -- Register Bank Instantiation
  ----------------------------------------------------------------------------
  u_regs : entity work.{{ entity_name }}_regs
    port map (
      clk      => clk,
      rst      => rst,
      wr_en    => wr_en,
      wr_addr  => wr_addr,
      wr_data  => wr_data,
      wr_strb  => wr_strb,
      rd_en    => rd_en,
      rd_addr  => rd_addr,
      rd_data  => rd_data,
      rd_valid => rd_valid,
      regs_out => regs_out,
      regs_in  => regs_in
    );

  -- Connect internal AXI signals to ports
{% set awaddr_port  = (bus_ports | selectattr('logical_name', 'equalto', 'AWADDR')  | list) %}
{% set awvalid_port = (bus_ports | selectattr('logical_name', 'equalto', 'AWVALID') | list) %}
{% set awready_port = (bus_ports | selectattr('logical_name', 'equalto', 'AWREADY') | list) %}
{% set wdata_port   = (bus_ports | selectattr('logical_name', 'equalto', 'WDATA')   | list) %}
{% set wstrb_port   = (bus_ports | selectattr('logical_name', 'equalto', 'WSTRB')   | list) %}
{% set wvalid_port  = (bus_ports | selectattr('logical_name', 'equalto', 'WVALID')  | list) %}
{% set wready_port  = (bus_ports | selectattr('logical_name', 'equalto', 'WREADY')  | list) %}
{% set bresp_port   = (bus_ports | selectattr('logical_name', 'equalto', 'BRESP')   | list) %}
{% set bvalid_port  = (bus_ports | selectattr('logical_name', 'equalto', 'BVALID')  | list) %}
{% set bready_port  = (bus_ports | selectattr('logical_name', 'equalto', 'BREADY')  | list) %}
{% set araddr_port  = (bus_ports | selectattr('logical_name', 'equalto', 'ARADDR')  | list) %}
{% set arvalid_port = (bus_ports | selectattr('logical_name', 'equalto', 'ARVALID') | list) %}
{% set arready_port = (bus_ports | selectattr('logical_name', 'equalto', 'ARREADY') | list) %}
{% set rdata_port   = (bus_ports | selectattr('logical_name', 'equalto', 'RDATA')   | list) %}
{% set rresp_port   = (bus_ports | selectattr('logical_name', 'equalto', 'RRESP')   | list) %}
{% set rvalid_port  = (bus_ports | selectattr('logical_name', 'equalto', 'RVALID')  | list) %}
{% set rready_port  = (bus_ports | selectattr('logical_name', 'equalto', 'RREADY')  | list) %}
  -- Inputs (master → slave)
  awaddr  <= {{ awaddr_port[0].name  if awaddr_port  | length > 0 else "(others => '0')" }};
  awvalid <= {{ awvalid_port[0].name if awvalid_port | length > 0 else "'0'" }};
  wdata   <= {{ wdata_port[0].name   if wdata_port   | length > 0 else "(others => '0')" }};
  wstrb   <= {{ wstrb_port[0].name   if wstrb_port   | length > 0 else "(others => '1')" }};
  wvalid  <= {{ wvalid_port[0].name  if wvalid_port  | length > 0 else "'0'" }};
  bready  <= {{ bready_port[0].name  if bready_port  | length > 0 else "'1'" }};
  araddr  <= {{ araddr_port[0].name  if araddr_port  | length > 0 else "(others => '0')" }};
  arvalid <= {{ arvalid_port[0].name if arvalid_port | length > 0 else "'0'" }};
  rready  <= {{ rready_port[0].name  if rready_port  | length > 0 else "'1'" }};
  -- Outputs (slave → master)
{% if awready_port | length > 0 %}
  {{ awready_port[0].name }} <= awready;
{% endif %}
{% if wready_port | length > 0 %}
  {{ wready_port[0].name }} <= wready;
{% endif %}
{% if bresp_port | length > 0 %}
  {{ bresp_port[0].name }} <= bresp;
{% endif %}
{% if bvalid_port | length > 0 %}
  {{ bvalid_port[0].name }} <= bvalid;
{% endif %}
{% if arready_port | length > 0 %}
  {{ arready_port[0].name }} <= arready;
{% endif %}
{% if rdata_port | length > 0 %}
  {{ rdata_port[0].name }} <= rdata;
{% endif %}
{% if rresp_port | length > 0 %}
  {{ rresp_port[0].name }} <= rresp;
{% endif %}
{% if rvalid_port | length > 0 %}
  {{ rvalid_port[0].name }} <= rvalid;
{% endif %}

  ----------------------------------------------------------------------------
  -- Write Address Channel
  -- Accept write address when AWVALID is asserted (independent of WVALID)
  ----------------------------------------------------------------------------
  write_addr_proc : process (clk) is
  begin
    if rising_edge(clk) then
      if rst = '1' then
        awready             <= '0';
        write_txn.aw_en     <= '1';
        awaddr              <= (others => '0');
        write_txn.addr_received <= '0';
      else
        if (awready = '0' and awvalid = '1' and write_txn.aw_en = '1') then
          -- Ready to accept write address
          awready             <= '1';
          write_txn.aw_en     <= '0';
          awaddr              <= awaddr;
          write_txn.addr_received <= '1';
        elsif (bvalid = '1' and bready = '1') then
          -- Write response completed, ready for next transaction
          write_txn.aw_en         <= '1';
          write_txn.addr_received <= '0';
          awready             <= '0';
        else
          awready <= '0';
        end if;
      end if;
    end if;
  end process write_addr_proc;

  ----------------------------------------------------------------------------
  -- Write Data Channel
  -- Accept write data when WVALID is asserted (independent of AWVALID)
  ----------------------------------------------------------------------------
  write_data_proc : process (clk) is
  begin
    if rising_edge(clk) then
      if rst = '1' then
        wready              <= '0';
        write_txn.data_received <= '0';
      else
        if (wready = '0' and wvalid = '1') then
          -- Ready to accept write data
          wready              <= '1';
          write_txn.data_received <= '1';
        elsif (bvalid = '1' and bready = '1') then
          -- Write response completed, ready for next transaction
          write_txn.data_received <= '0';
          wready              <= '0';
        else
          wready <= '0';
        end if;
      end if;
    end if;
  end process write_data_proc;

  ----------------------------------------------------------------------------
  -- Register Write Control
  -- Generate write enable to register bank when both address and data received
  ----------------------------------------------------------------------------
  wr_en   <= write_txn.addr_received and write_txn.data_received;
  wr_addr <= awaddr;
  wr_data <= wdata;
  wr_strb <= wstrb;

  ----------------------------------------------------------------------------
  -- Write Response Logic
  ----------------------------------------------------------------------------
  write_response_proc : process (clk) is
  begin
    if rising_edge(clk) then
      if rst = '1' then
        bvalid <= '0';
        bresp  <= C_RESP_OKAY;
      else
        if (write_txn.addr_received = '1' and write_txn.data_received = '1' and bvalid = '0') then
          -- Both address and data received, assert write response
          bvalid <= '1';
          bresp  <= C_RESP_OKAY;
        elsif (bready = '1' and bvalid = '1') then
          -- Write response accepted by master
          bvalid <= '0';
        end if;
      end if;
    end if;
  end process write_response_proc;

  ----------------------------------------------------------------------------
  -- Read Address Channel
  ----------------------------------------------------------------------------
  read_addr_proc : process (clk) is
  begin
    if rising_edge(clk) then
      if rst = '1' then
        arready <= '0';
        araddr  <= (others => '0');
      else
        if (arready = '0' and arvalid = '1') then
          arready <= '1';
          araddr  <= araddr;
        else
          arready <= '0';
        end if;
      end if;
    end if;
  end process read_addr_proc;

  ----------------------------------------------------------------------------
  -- Register Read Control
  -- Trigger read from register bank when address is accepted
  ----------------------------------------------------------------------------
  rd_en   <= arready and arvalid and not rvalid;
  rd_addr <= araddr;

  ----------------------------------------------------------------------------
  -- Read Valid Generation
  -- Assert RVALID when register bank provides valid read data
  ----------------------------------------------------------------------------
  read_valid_proc : process (clk) is
  begin
    if rising_edge(clk) then
      if rst = '1' then
        rvalid <= '0';
        rresp  <= C_RESP_OKAY;
        rdata  <= (others => '0');
      else
        if rd_valid = '1' then
          -- Register bank has valid data
          rvalid <= '1';
          rresp  <= C_RESP_OKAY;
          rdata  <= rd_data;
        elsif (rvalid = '1' and rready = '1') then
          -- Master accepted read data
          rvalid <= '0';
        end if;
      end if;
    end if;
  end process read_valid_proc;

end architecture rtl;
