{# VHDL AXI-Lite Bus Wrapper Template #}
{# Generates AXI-Lite slave interface with register decoding #}
{# pass_user_via_bus: no register file — user ports flow directly through this wrapper #}
{% set pass_user_via_bus = user_ports | length > 0 and sw_registers | length == 0 and hw_registers | length == 0 %}
--------------------------------------------------------------------------------
-- Entity: {{ entity_name }}_axil
-- Description: AXI-Lite slave interface for register access
-- Generated by ipcraft VHDL Generator
--
-- Register Map:
{% for reg in registers %}
--   {{ "0x%04X" | format(loop.index0 * reg_width) }} : {{ reg.name }} ({{ reg.access }})
{% endfor %}
--------------------------------------------------------------------------------

library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

{% if not pass_user_via_bus %}
use work.{{ entity_name }}_pkg.all;
{% endif %}
entity {{ entity_name }}_axil is
{% if pass_user_via_bus and generics | length %}
  generic (
{% for generic in generics %}
    {{ generic.name }} : {{ generic.type }}{{ " := " ~ generic.default_value if generic.default_value is not none else "" }}{{ ";" if not loop.last else "" }}
{% endfor %}
  );
{% endif %}
  port (
    -- Clock and reset
    clk : in std_logic;
    rst : in std_logic;

{% if bus_ports | length > 0 %}
    -- AXI-Lite Slave Interface
{% for port in bus_ports %}
    {{ "%-14s"|format(port.name) }} : {{ "%-3s"|format(port.direction) }} {{ port.type }}{{ ";" }}
{% endfor %}
{% endif %}
{% if pass_user_via_bus %}
    -- Register-bank interface (driven by this entity toward user logic)
{% for port in user_ports %}
    {{ "%-14s"|format(port.name) }} : {{ "%-3s"|format(port.direction) }} {{ port.type }}{{ ";" if not loop.last else "" }}
{% endfor %}
{% else %}
    -- Register interface
{% set has_regs_in = hw_registers | length > 0 or w1c_registers | length > 0 or cos_registers | length > 0 %}
{% if sw_registers | length > 0 %}
    regs_out : out t_regs_sw2hw{{ ";" if has_regs_in else "" }}  -- To core (SW-writable)
{% endif %}
{% if has_regs_in %}
    regs_in  : in  t_regs_hw2sw   -- From core (HW-writable / W1C pulses / CoS values)
{% endif %}
{% endif %}
  );
end entity {{ entity_name }}_axil;

{% if pass_user_via_bus %}
architecture rtl of {{ entity_name }}_axil is

  -- TODO: implement AXI-Lite slave logic that drives the register-bank
  -- output ports above.  The interface matches the original RTL entity.

begin

  -- Drive outputs to default until implementation is provided
{% for port in user_ports %}
{% if port.direction == 'out' %}
  {{ port.name }} <= {% if port.type == 'std_logic' %}'0'{% else %}(others => '0'){% endif %};
{% endif %}
{% endfor %}

end architecture rtl;

{% else %}
architecture rtl of {{ entity_name }}_axil is

  -- AXI-Lite response constants
  constant C_RESP_OKAY   : std_logic_vector(1 downto 0) := "00";
  constant C_RESP_SLVERR : std_logic_vector(1 downto 0) := "10";

  -- AXI internal signals (output registers + address latches only; input ports used directly)
{% for port in bus_ports %}
{% if port.logical_name != 'AWPROT' and port.logical_name != 'ARPROT' %}
{% if port.direction == 'out' or port.logical_name == 'AWADDR' or port.logical_name == 'ARADDR' %}
{% if port.logical_name == 'BRESP' or port.logical_name == 'RRESP' %}
{% set sig_init = 'C_RESP_OKAY' %}
{% elif port.type == 'std_logic' %}
{% set sig_init = "'0'" %}
{% else %}
{% set sig_init = "(others => '0')" %}
{% endif %}
  signal {{ "%-8s"|format(port.logical_name | lower) }} : {{ "%-48s"|format(port.type) }} := {{ sig_init }};
{% endif %}
{% endif %}
{% endfor %}

  -- Register bank interface signals
  signal wr_en     : std_logic;
  signal wr_addr   : std_logic_vector(C_ADDR_WIDTH-1 downto 0);
  signal wr_data   : std_logic_vector(C_DATA_WIDTH-1 downto 0);
  signal wr_strb   : std_logic_vector((C_DATA_WIDTH/8)-1 downto 0);
  signal rd_en     : std_logic;
  signal rd_addr   : std_logic_vector(C_ADDR_WIDTH-1 downto 0);
  signal rd_data   : std_logic_vector(C_DATA_WIDTH-1 downto 0);
  signal rd_valid  : std_logic;

  -- Write data/strobe latches: hold W-channel data until the register write
  -- fires so the master is free to de-assert WVALID after the W handshake.
  signal wdata_latch  : std_logic_vector(C_DATA_WIDTH-1 downto 0)    := (others => '0');
  signal wstrb_latch  : std_logic_vector((C_DATA_WIDTH/8)-1 downto 0) := (others => '0');
  -- Gate wr_en to a single-cycle pulse: wr_pending tracks that wr_en has
  -- already fired this transaction so the second combinatorial cycle is blocked.
  signal wr_pending   : std_logic := '0';
  -- Registered flag for an unmapped read address: lets read_valid_proc respond
  -- with SLVERR one cycle after rd_en, matching the timing of rd_valid.
  signal rd_invalid_d : std_logic := '0';

  -- Write transaction tracking using VHDL 2008 records
  type t_write_transaction is record
    aw_en         : std_logic; -- Address write enable flag
    addr_received : std_logic; -- Address has been received
    data_received : std_logic; -- Data has been received
  end record t_write_transaction;

  signal write_txn : t_write_transaction := ('1', '0', '0');

begin

  ----------------------------------------------------------------------------
  -- Register Bank Instantiation
  ----------------------------------------------------------------------------
  u_regs : entity work.{{ entity_name }}_regs
    port map (
      clk      => clk,
      rst      => rst,
      wr_en    => wr_en,
      wr_addr  => wr_addr,
      wr_data  => wr_data,
      wr_strb  => wr_strb,
      rd_en    => rd_en,
      rd_addr  => rd_addr,
      rd_data  => rd_data,
      rd_valid => rd_valid,
{% if sw_registers | length > 0 %}
      regs_out => regs_out{{ "," if has_regs_in else "" }}
{% endif %}
{% if has_regs_in %}
      regs_in  => regs_in
{% endif %}
    );

  -- Connect internal output registers to AXI-Lite ports
{% set awready_port = (bus_ports | selectattr('logical_name', 'equalto', 'AWREADY') | list) %}
{% set wready_port  = (bus_ports | selectattr('logical_name', 'equalto', 'WREADY')  | list) %}
{% set bresp_port   = (bus_ports | selectattr('logical_name', 'equalto', 'BRESP')   | list) %}
{% set bvalid_port  = (bus_ports | selectattr('logical_name', 'equalto', 'BVALID')  | list) %}
{% set arready_port = (bus_ports | selectattr('logical_name', 'equalto', 'ARREADY') | list) %}
{% set rdata_port   = (bus_ports | selectattr('logical_name', 'equalto', 'RDATA')   | list) %}
{% set rresp_port   = (bus_ports | selectattr('logical_name', 'equalto', 'RRESP')   | list) %}
{% set rvalid_port  = (bus_ports | selectattr('logical_name', 'equalto', 'RVALID')  | list) %}
{% set awaddr_port  = (bus_ports | selectattr('logical_name', 'equalto', 'AWADDR')  | list) %}
{% set awvalid_port = (bus_ports | selectattr('logical_name', 'equalto', 'AWVALID') | list) %}
{% set wdata_port   = (bus_ports | selectattr('logical_name', 'equalto', 'WDATA')   | list) %}
{% set wstrb_port   = (bus_ports | selectattr('logical_name', 'equalto', 'WSTRB')   | list) %}
{% set wvalid_port  = (bus_ports | selectattr('logical_name', 'equalto', 'WVALID')  | list) %}
{% set bready_port  = (bus_ports | selectattr('logical_name', 'equalto', 'BREADY')  | list) %}
{% set araddr_port  = (bus_ports | selectattr('logical_name', 'equalto', 'ARADDR')  | list) %}
{% set arvalid_port = (bus_ports | selectattr('logical_name', 'equalto', 'ARVALID') | list) %}
{% set rready_port  = (bus_ports | selectattr('logical_name', 'equalto', 'RREADY')  | list) %}
{% if awready_port | length > 0 %}
  {{ awready_port[0].name }} <= awready;
{% endif %}
{% if wready_port | length > 0 %}
  {{ wready_port[0].name }} <= wready;
{% endif %}
{% if bresp_port | length > 0 %}
  {{ bresp_port[0].name }} <= bresp;
{% endif %}
{% if bvalid_port | length > 0 %}
  {{ bvalid_port[0].name }} <= bvalid;
{% endif %}
{% if arready_port | length > 0 %}
  {{ arready_port[0].name }} <= arready;
{% endif %}
{% if rdata_port | length > 0 %}
  {{ rdata_port[0].name }} <= rdata;
{% endif %}
{% if rresp_port | length > 0 %}
  {{ rresp_port[0].name }} <= rresp;
{% endif %}
{% if rvalid_port | length > 0 %}
  {{ rvalid_port[0].name }} <= rvalid;
{% endif %}

  ----------------------------------------------------------------------------
  -- Write Address Channel
  -- Accept write address when AWVALID is asserted (independent of WVALID)
  ----------------------------------------------------------------------------
  write_addr_proc : process (clk) is
  begin
    if rising_edge(clk) then
      if rst = '1' then
        awready             <= '0';
        write_txn.aw_en     <= '1';
        awaddr              <= (others => '0');
        write_txn.addr_received <= '0';
      else
        if (awready = '0' and {{ awvalid_port[0].name if awvalid_port | length > 0 else "'0'" }} = '1' and write_txn.aw_en = '1') then
          -- Ready to accept write address; latch address from port
          awready             <= '1';
          write_txn.aw_en     <= '0';
          awaddr              <= {{ awaddr_port[0].name if awaddr_port | length > 0 else "(others => '0')" }};
          write_txn.addr_received <= '1';
        elsif (bvalid = '1' and {{ bready_port[0].name if bready_port | length > 0 else "'1'" }} = '1') then
          -- Write response completed, ready for next transaction
          write_txn.aw_en         <= '1';
          write_txn.addr_received <= '0';
          awready             <= '0';
        else
          awready <= '0';
        end if;
      end if;
    end if;
  end process write_addr_proc;

  ----------------------------------------------------------------------------
  -- Write Data Channel
  -- Accept write data when WVALID is asserted (independent of AWVALID)
  ----------------------------------------------------------------------------
  write_data_proc : process (clk) is
  begin
    if rising_edge(clk) then
      if rst = '1' then
        wready              <= '0';
        write_txn.data_received <= '0';
      else
        if (wready = '0' and {{ wvalid_port[0].name if wvalid_port | length > 0 else "'0'" }} = '1') then
          -- Ready to accept write data; latch data and strobe immediately
          wready              <= '1';
          write_txn.data_received <= '1';
          wdata_latch         <= {{ wdata_port[0].name if wdata_port | length > 0 else "(others => '0')" }};
          wstrb_latch         <= {{ wstrb_port[0].name if wstrb_port | length > 0 else "(others => '1')" }};
        elsif (bvalid = '1' and {{ bready_port[0].name if bready_port | length > 0 else "'1'" }} = '1') then
          -- Write response completed, ready for next transaction
          write_txn.data_received <= '0';
          wready              <= '0';
        else
          wready <= '0';
        end if;
      end if;
    end if;
  end process write_data_proc;

  ----------------------------------------------------------------------------
  -- Write Enable Pulse Gate
  -- wr_pending shadows the combinatorial wr_en one cycle later, ensuring
  -- wr_en is a single-cycle pulse even when addr/data_received stay high
  -- until the B-channel handshake.
  ----------------------------------------------------------------------------
  wr_pending_proc : process (clk) is
  begin
    if rising_edge(clk) then
      if rst = '1' then
        wr_pending <= '0';
      else
        wr_pending <= write_txn.addr_received and write_txn.data_received;
      end if;
    end if;
  end process wr_pending_proc;

  ----------------------------------------------------------------------------
  -- Register Write Control
  -- Generate write enable to register bank when both address and data received
  ----------------------------------------------------------------------------
  wr_en   <= write_txn.addr_received and write_txn.data_received and not wr_pending;
  wr_addr <= awaddr(C_ADDR_WIDTH-1 downto 0);
  wr_data <= wdata_latch;
  wr_strb <= wstrb_latch;

  ----------------------------------------------------------------------------
  -- Write Response Logic
  ----------------------------------------------------------------------------
  write_response_proc : process (clk) is
  begin
    if rising_edge(clk) then
      if rst = '1' then
        bvalid <= '0';
        bresp  <= C_RESP_OKAY;
      else
        if (write_txn.addr_received = '1' and write_txn.data_received = '1' and bvalid = '0') then
          -- Both address and data received, assert write response
          bvalid <= '1';
          if to_integer(unsigned(awaddr(C_ADDR_WIDTH-1 downto 2))) < {{ registers | length }} then
            bresp <= C_RESP_OKAY;
          else
            bresp <= C_RESP_SLVERR;
          end if;
        elsif ({{ bready_port[0].name if bready_port | length > 0 else "'1'" }} = '1' and bvalid = '1') then
          -- Write response accepted by master
          bvalid <= '0';
        end if;
      end if;
    end if;
  end process write_response_proc;

  ----------------------------------------------------------------------------
  -- Read Address Channel
  ----------------------------------------------------------------------------
  read_addr_proc : process (clk) is
  begin
    if rising_edge(clk) then
      if rst = '1' then
        arready <= '0';
        araddr  <= (others => '0');
      else
        if (arready = '0' and {{ arvalid_port[0].name if arvalid_port | length > 0 else "'0'" }} = '1') then
          arready <= '1';
          araddr  <= {{ araddr_port[0].name if araddr_port | length > 0 else "(others => '0')" }};  -- latch address from port
        else
          arready <= '0';
        end if;
      end if;
    end if;
  end process read_addr_proc;

  ----------------------------------------------------------------------------
  -- Register Read Control
  -- Trigger read from register bank when address is accepted
  ----------------------------------------------------------------------------
  rd_en   <= arready and {{ arvalid_port[0].name if arvalid_port | length > 0 else "'0'" }} and not rvalid;
  rd_addr <= araddr(C_ADDR_WIDTH-1 downto 0);

  ----------------------------------------------------------------------------
  -- Invalid Read Address Detection
  -- Register bank never asserts rd_valid for unmapped addresses; rd_invalid_d
  -- provides the alternative trigger for read_valid_proc to return SLVERR.
  ----------------------------------------------------------------------------
  rd_invalid_proc : process (clk) is
  begin
    if rising_edge(clk) then
      if rst = '1' then
        rd_invalid_d <= '0';
      else
        if rd_en = '1' and to_integer(unsigned(rd_addr(C_ADDR_WIDTH-1 downto 2))) >= {{ registers | length }} then
          rd_invalid_d <= '1';
        else
          rd_invalid_d <= '0';
        end if;
      end if;
    end if;
  end process rd_invalid_proc;

  ----------------------------------------------------------------------------
  -- Read Valid Generation
  -- Assert RVALID when register bank provides valid read data or when the
  -- address was unmapped (SLVERR, zero data).
  ----------------------------------------------------------------------------
  read_valid_proc : process (clk) is
  begin
    if rising_edge(clk) then
      if rst = '1' then
        rvalid <= '0';
        rresp  <= C_RESP_OKAY;
        rdata  <= (others => '0');
      else
        if rd_valid = '1' then
          -- Register bank has valid data
          rvalid <= '1';
          rresp  <= C_RESP_OKAY;
          rdata  <= rd_data;
        elsif rd_invalid_d = '1' then
          -- Unmapped read address: complete transaction with SLVERR and zero data
          rvalid <= '1';
          rresp  <= C_RESP_SLVERR;
          rdata  <= (others => '0');
        elsif (rvalid = '1' and {{ rready_port[0].name if rready_port | length > 0 else "'1'" }} = '1') then
          -- Master accepted read data
          rvalid <= '0';
        end if;
      end if;
    end if;
  end process read_valid_proc;

end architecture rtl;

{% endif %}