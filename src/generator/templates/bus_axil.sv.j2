{# SystemVerilog AXI-Lite Bus Wrapper Template #}
{# Generates AXI-Lite slave interface with register decoding #}
////////////////////////////////////////////////////////////////////////////////
// Module: {{ entity_name }}_axil
// Description: AXI-Lite slave interface for register access
// Generated by ipcraft SystemVerilog Generator
//
// Register Map:
{% for reg in registers %}
//   {{ "0x%04X" | format(loop.index0 * reg_width) }} : {{ reg.name }} ({{ reg.access }})
{% endfor %}
////////////////////////////////////////////////////////////////////////////////
`timescale 1ns / 1ps

{# Header import, not compilation-unit scope: iverilog 12 cannot resolve
   functions imported into $unit, only types and parameters. #}
module {{ entity_name }}_axil
  import {{ entity_name }}_pkg::*;
(
  // Clock and reset
  input  logic clk,
  input  logic rst,
{% if bus_ports | length > 0 %}

  // AXI-Lite Slave Interface
{% for port in bus_ports %}
  {{ "%-6s"|format(port.sv_direction) }} {{ "%-34s"|format(port.sv_type) }} {{ port.name }},
{% endfor %}
{% endif %}

  // Register interface
{% set has_regs_in = hw_registers | length > 0 or w1c_registers | length > 0 or sc_registers | length > 0 or cos_registers | length > 0 %}
{% if sw_registers | length > 0 %}
  output regs_sw2hw_t regs_out{{ "," if has_regs_in else "" }}  // To core (SW-writable)
{% endif %}
{% if has_regs_in %}
  input  regs_hw2sw_t regs_in   // From core (HW-writable / W1C pulses / CoS values)
{% endif %}
);

  // AXI-Lite response constants
  localparam logic [1:0] C_RESP_OKAY   = 2'b00;
  localparam logic [1:0] C_RESP_SLVERR = 2'b10;

  // AXI internal signals. Master-to-slave signals are driven from always_comb
  // below, so they must not carry a declaration initializer (a second driver
  // per IEEE 1800 9.2.2.2 — Verilator MULTIDRIVEN).
{% set comb_driven = ['AWADDR', 'AWVALID', 'WDATA', 'WSTRB', 'WVALID', 'BREADY', 'ARADDR', 'ARVALID', 'RREADY'] %}
{% for port in bus_ports %}
{% if port.logical_name != 'AWPROT' and port.logical_name != 'ARPROT' %}
  {{ "%-34s"|format(port.sv_type) }} {{ port.logical_name | lower }}{{ ";" if port.logical_name in comb_driven else " = '0;" }}
{% endif %}
{% endfor %}

  // Register bank interface signals
  logic                        wr_en;
  logic [C_ADDR_WIDTH-1:0]     wr_addr;
  logic [C_DATA_WIDTH-1:0]     wr_data;
  logic [(C_DATA_WIDTH/8)-1:0] wr_strb;
  logic                        rd_en;
  logic [C_ADDR_WIDTH-1:0]     rd_addr;
  logic [C_DATA_WIDTH-1:0]     rd_data;
  logic                        rd_valid;

  // Latches: hold W-channel data and AW/AR addresses after the handshake
  logic [C_DATA_WIDTH-1:0]     wdata_latch  = '0;
  logic [(C_DATA_WIDTH/8)-1:0] wstrb_latch  = '0;
  logic [C_ADDR_WIDTH-1:0]     awaddr_lat   = '0;
  logic [C_ADDR_WIDTH-1:0]     araddr_lat   = '0;
  // wr_pending: single-cycle wr_en gate
  logic                        wr_pending   = 1'b0;
  // rd_invalid_d: registered flag for unmapped read address
  logic                        rd_invalid_d = 1'b0;

  // Write transaction tracking
  logic aw_en          = 1'b1;
  logic addr_received  = 1'b0;
  logic data_received  = 1'b0;

  ////////////////////////////////////////////////////////////////////////////
  // Register Bank Instantiation
  ////////////////////////////////////////////////////////////////////////////
  {{ entity_name }}_regs u_regs (
    .clk      (clk),
    .rst      (rst),
    .wr_en    (wr_en),
    .wr_addr  (wr_addr),
    .wr_data  (wr_data),
    .wr_strb  (wr_strb),
    .rd_en    (rd_en),
    .rd_addr  (rd_addr),
    .rd_data  (rd_data),
    .rd_valid (rd_valid){% if sw_registers | length > 0 or has_regs_in %},{% endif %}

{% if sw_registers | length > 0 %}
    .regs_out (regs_out){{ "," if has_regs_in else "" }}
{% endif %}
{% if has_regs_in %}
    .regs_in  (regs_in)
{% endif %}
  );

  // Connect internal AXI signals to ports
{% set awaddr_port  = (bus_ports | selectattr('logical_name', 'equalto', 'AWADDR')  | list) %}
{% set awvalid_port = (bus_ports | selectattr('logical_name', 'equalto', 'AWVALID') | list) %}
{% set awready_port = (bus_ports | selectattr('logical_name', 'equalto', 'AWREADY') | list) %}
{% set wdata_port   = (bus_ports | selectattr('logical_name', 'equalto', 'WDATA')   | list) %}
{% set wstrb_port   = (bus_ports | selectattr('logical_name', 'equalto', 'WSTRB')   | list) %}
{% set wvalid_port  = (bus_ports | selectattr('logical_name', 'equalto', 'WVALID')  | list) %}
{% set wready_port  = (bus_ports | selectattr('logical_name', 'equalto', 'WREADY')  | list) %}
{% set bresp_port   = (bus_ports | selectattr('logical_name', 'equalto', 'BRESP')   | list) %}
{% set bvalid_port  = (bus_ports | selectattr('logical_name', 'equalto', 'BVALID')  | list) %}
{% set bready_port  = (bus_ports | selectattr('logical_name', 'equalto', 'BREADY')  | list) %}
{% set araddr_port  = (bus_ports | selectattr('logical_name', 'equalto', 'ARADDR')  | list) %}
{% set arvalid_port = (bus_ports | selectattr('logical_name', 'equalto', 'ARVALID') | list) %}
{% set arready_port = (bus_ports | selectattr('logical_name', 'equalto', 'ARREADY') | list) %}
{% set rdata_port   = (bus_ports | selectattr('logical_name', 'equalto', 'RDATA')   | list) %}
{% set rresp_port   = (bus_ports | selectattr('logical_name', 'equalto', 'RRESP')   | list) %}
{% set rvalid_port  = (bus_ports | selectattr('logical_name', 'equalto', 'RVALID')  | list) %}
{% set rready_port  = (bus_ports | selectattr('logical_name', 'equalto', 'RREADY')  | list) %}

  // Inputs (master → slave)
  always_comb begin
    awaddr  = {{ awaddr_port[0].name  if awaddr_port  | length > 0 else "'0" }};
    awvalid = {{ awvalid_port[0].name if awvalid_port | length > 0 else "1'b0" }};
    wdata   = {{ wdata_port[0].name   if wdata_port   | length > 0 else "'0" }};
    wstrb   = {{ wstrb_port[0].name   if wstrb_port   | length > 0 else "'1" }};
    wvalid  = {{ wvalid_port[0].name  if wvalid_port  | length > 0 else "1'b0" }};
    bready  = {{ bready_port[0].name  if bready_port  | length > 0 else "1'b1" }};
    araddr  = {{ araddr_port[0].name  if araddr_port  | length > 0 else "'0" }};
    arvalid = {{ arvalid_port[0].name if arvalid_port | length > 0 else "1'b0" }};
    rready  = {{ rready_port[0].name  if rready_port  | length > 0 else "1'b1" }};
  end

  // Outputs (slave → master)
{% if awready_port | length > 0 %}
  assign {{ awready_port[0].name }} = awready;
{% endif %}
{% if wready_port | length > 0 %}
  assign {{ wready_port[0].name }} = wready;
{% endif %}
{% if bresp_port | length > 0 %}
  assign {{ bresp_port[0].name }} = bresp;
{% endif %}
{% if bvalid_port | length > 0 %}
  assign {{ bvalid_port[0].name }} = bvalid;
{% endif %}
{% if arready_port | length > 0 %}
  assign {{ arready_port[0].name }} = arready;
{% endif %}
{% if rdata_port | length > 0 %}
  assign {{ rdata_port[0].name }} = rdata;
{% endif %}
{% if rresp_port | length > 0 %}
  assign {{ rresp_port[0].name }} = rresp;
{% endif %}
{% if rvalid_port | length > 0 %}
  assign {{ rvalid_port[0].name }} = rvalid;
{% endif %}

  ////////////////////////////////////////////////////////////////////////////
  // Write Address Channel
  // Accept write address when AWVALID is asserted (independent of WVALID)
  ////////////////////////////////////////////////////////////////////////////
  always_ff @(posedge clk) begin : write_addr_proc
    if (rst) begin
      awready       <= 1'b0;
      aw_en         <= 1'b1;
      addr_received <= 1'b0;
    end else begin
      if (!awready && awvalid && aw_en) begin
        awready       <= 1'b1;
        aw_en         <= 1'b0;
        addr_received <= 1'b1;
        awaddr_lat    <= awaddr[C_ADDR_WIDTH-1:0];
      end else if (bvalid && bready) begin
        aw_en         <= 1'b1;
        addr_received <= 1'b0;
        awready       <= 1'b0;
      end else begin
        awready <= 1'b0;
      end
    end
  end

  ////////////////////////////////////////////////////////////////////////////
  // Write Data Channel
  // Accept write data when WVALID is asserted (independent of AWVALID)
  ////////////////////////////////////////////////////////////////////////////
  always_ff @(posedge clk) begin : write_data_proc
    if (rst) begin
      wready        <= 1'b0;
      data_received <= 1'b0;
    end else begin
      if (!wready && wvalid) begin
        wready        <= 1'b1;
        data_received <= 1'b1;
        wdata_latch   <= wdata;
        wstrb_latch   <= wstrb;
      end else if (bvalid && bready) begin
        data_received <= 1'b0;
        wready        <= 1'b0;
      end else begin
        wready <= 1'b0;
      end
    end
  end

  ////////////////////////////////////////////////////////////////////////////
  // Write Enable Pulse Gate
  ////////////////////////////////////////////////////////////////////////////
  always_ff @(posedge clk) begin : wr_pending_proc
    if (rst) begin
      wr_pending <= 1'b0;
    end else begin
      wr_pending <= addr_received & data_received;
    end
  end

  ////////////////////////////////////////////////////////////////////////////
  // Register Write Control
  // Generate write enable to register bank when both address and data received
  ////////////////////////////////////////////////////////////////////////////
  assign wr_en   = addr_received & data_received & ~wr_pending;
  assign wr_addr = awaddr_lat[C_ADDR_WIDTH-1:0];
  assign wr_data = wdata_latch;
  assign wr_strb = wstrb_latch;

  ////////////////////////////////////////////////////////////////////////////
  // Write Response Logic
  ////////////////////////////////////////////////////////////////////////////
  always_ff @(posedge clk) begin : write_response_proc
    if (rst) begin
      bvalid <= 1'b0;
      bresp  <= C_RESP_OKAY;
    end else begin
      if (addr_received && data_received && !bvalid) begin
        bvalid <= 1'b1;
        bresp  <= ($unsigned(awaddr_lat[C_ADDR_WIDTH-1:2]) < {{ registers | length }})
                  ? C_RESP_OKAY : C_RESP_SLVERR;
      end else if (bready && bvalid) begin
        bvalid <= 1'b0;
      end
    end
  end

  ////////////////////////////////////////////////////////////////////////////
  // Read Address Channel
  ////////////////////////////////////////////////////////////////////////////
  always_ff @(posedge clk) begin : read_addr_proc
    if (rst) begin
      arready <= 1'b0;
    end else begin
      if (!arready && arvalid) begin
        arready    <= 1'b1;
        araddr_lat <= araddr[C_ADDR_WIDTH-1:0];
      end else begin
        arready <= 1'b0;
      end
    end
  end

  ////////////////////////////////////////////////////////////////////////////
  // Register Read Control
  ////////////////////////////////////////////////////////////////////////////
  assign rd_en   = arready & arvalid & ~rvalid;
  assign rd_addr = araddr_lat[C_ADDR_WIDTH-1:0];

  ////////////////////////////////////////////////////////////////////////////
  // Invalid Read Address Detection
  ////////////////////////////////////////////////////////////////////////////
  always_ff @(posedge clk) begin : rd_invalid_proc
    if (rst) begin
      rd_invalid_d <= 1'b0;
    end else begin
      rd_invalid_d <= rd_en && ($unsigned(rd_addr[C_ADDR_WIDTH-1:2]) >= {{ registers | length }});
    end
  end

  ////////////////////////////////////////////////////////////////////////////
  // Read Valid Generation
  ////////////////////////////////////////////////////////////////////////////
  always_ff @(posedge clk) begin : read_valid_proc
    if (rst) begin
      rvalid <= 1'b0;
      rresp  <= C_RESP_OKAY;
      rdata  <= '0;
    end else begin
      if (rd_valid) begin
        rvalid <= 1'b1;
        rresp  <= C_RESP_OKAY;
        rdata  <= rd_data;
      end else if (rd_invalid_d) begin
        rvalid <= 1'b1;
        rresp  <= C_RESP_SLVERR;
        rdata  <= '0;
      end else if (rvalid && rready) begin
        rvalid <= 1'b0;
      end
    end
  end

endmodule : {{ entity_name }}_axil
