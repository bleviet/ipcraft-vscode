"""
mm_loader — generic .mm.yml reader for cocotb testbenches.
Generated by ipcraft. No ipcraft runtime dependency required (uses PyYAML only).

The .mm.yml file is the single source of truth.  This module reads it at test
startup so any change to the YAML is immediately reflected in the next run
without regenerating anything.

Quick-start
-----------
Load the register map:

    import os
    from mm_loader import load_regmap

    regmap = load_regmap(os.path.join(os.path.dirname(__file__), "../my_ip.mm.yml"))

Iterate all registers:

    for reg in regmap:
        print(f"{reg.name} @ 0x{reg.offset:04X}  ({reg.access})")

Access a specific register:

    ctrl = regmap["CTRL"]       # dict-style — always works
    ctrl = regmap.CTRL          # attribute-style — works for valid Python identifiers

    ctrl.offset                 # int byte address, e.g. 0
    ctrl.access                 # str, e.g. "read-write"

Access fields within a register:

    f = ctrl.fields["ENABLE"]   # dict-style
    f = ctrl.fields.ENABLE      # attribute-style

    f.bit_offset                # int, LSB position
    f.bit_width                 # int, number of bits
    f.mask                      # int, field mask pre-shifted into register position
    f.access                    # str, e.g. "read-write"

Extract / insert a field value (no bus transaction):

    reg_val = await _read_reg(master, ctrl.offset)

    enable = ctrl.fields.ENABLE.extract(reg_val)    # isolate the ENABLE field
    new_val = ctrl.fields.ENABLE.insert(reg_val, 1) # set ENABLE=1, leave other fields
    await _write_reg(master, ctrl.offset, new_val)

Example cocotb test:

    @cocotb.test()
    async def test_registers(dut):
        master = AxiLiteMaster(AxiLiteBus.from_prefix(dut, "s_axi"), dut.clk)

        for reg in regmap:
            if "write" in reg.access:
                await _write_reg(master, reg.offset, 0xA5A5A5A5)
            if "read" in reg.access:
                val = await _read_reg(master, reg.offset)
                dut._log.info(f"{reg.name}: 0x{val:08X}")
"""

import os
import yaml


# ---------------------------------------------------------------------------
# Data model
# ---------------------------------------------------------------------------

class _Field:
    """A single bit-field within a register."""

    def __init__(self, d: dict):
        self.name: str = d["name"]
        self.bit_offset: int = d["bit_offset"]
        self.bit_width: int = d["bit_width"]
        self.access: str = d["access"]

    @property
    def mask(self) -> int:
        """Bit-mask for this field, shifted into register position."""
        return ((1 << self.bit_width) - 1) << self.bit_offset

    def extract(self, reg_value: int) -> int:
        """Extract this field's value from a full register word."""
        return (reg_value >> self.bit_offset) & ((1 << self.bit_width) - 1)

    def insert(self, reg_value: int, field_value: int) -> int:
        """Return *reg_value* with this field replaced by *field_value*."""
        m = (1 << self.bit_width) - 1
        return (reg_value & ~(m << self.bit_offset)) | ((field_value & m) << self.bit_offset)

    def __repr__(self) -> str:
        return (
            f"Field({self.name!r}, bit_offset={self.bit_offset}, "
            f"bit_width={self.bit_width}, access={self.access!r})"
        )


class _Fields:
    """Collection of fields in a register, accessible by name."""

    def __init__(self, fields: list):
        self._list = fields
        self._by_name = {f.name: f for f in fields}
        for f in fields:
            if f.name.isidentifier():
                setattr(self, f.name, f)

    def __getitem__(self, name: str) -> _Field:
        return self._by_name[name]

    def __iter__(self):
        return iter(self._list)

    def __len__(self) -> int:
        return len(self._list)

    def __repr__(self) -> str:
        return f"Fields([{', '.join(f.name for f in self._list)}])"


class _Register:
    """A single register with its address and fields."""

    def __init__(self, d: dict):
        self.name: str = d["name"]
        self.offset: int = d["offset"]
        self.access: str = d["access"]
        self.fields: _Fields = _Fields([_Field(f) for f in d.get("fields", [])])

    def __repr__(self) -> str:
        return f"Register({self.name!r}, offset=0x{self.offset:04X}, access={self.access!r})"


class RegMap:
    """All registers from a .mm.yml file, accessible by name or iteration.

    Attribute access (``regmap.CTRL``) works for names that are valid Python
    identifiers.  Dict access (``regmap["CTRL"]``) always works.
    """

    def __init__(self, registers: list):
        self._list = registers
        self._by_name = {r.name: r for r in registers}
        for r in registers:
            if r.name.isidentifier():
                setattr(self, r.name, r)

    def __getitem__(self, name: str) -> _Register:
        return self._by_name[name]

    def __iter__(self):
        return iter(self._list)

    def __len__(self) -> int:
        return len(self._list)

    def __repr__(self) -> str:
        return f"RegMap([{', '.join(r.name for r in self._list)}])"


# ---------------------------------------------------------------------------
# YAML parsing helpers
# ---------------------------------------------------------------------------

def _parse_number(val) -> int:
    if isinstance(val, int):
        return val
    if isinstance(val, str):
        return int(val, 0)
    return 0


def _parse_bits(bits_str):
    if bits_str is None:
        return 0, 1
    s = str(bits_str).strip()
    if ":" in s:
        parts = s.split(":")
        high, low = int(parts[0].strip()), int(parts[1].strip())
        return min(low, high), abs(high - low) + 1
    return int(s), 1


def _process_register(reg: dict, base_offset: int, prefix: str, out: list):
    name = prefix + str(reg.get("name", ""))

    if "registers" in reg:
        count = int(reg.get("count", 1))
        stride = _parse_number(reg.get("stride", 0))
        array_base = base_offset + _parse_number(
            reg.get("base_address", reg.get("address_offset", 0))
        )
        for i in range(count):
            inst_prefix = f"{name}_{i}_" if count > 1 else f"{name}_"
            for child in reg["registers"]:
                _process_register(child, array_base + i * stride, inst_prefix, out)
        return

    offset = base_offset + _parse_number(
        reg.get("address_offset", reg.get("addressOffset", reg.get("offset", 0)))
    )
    access = str(reg.get("access", "read-write")).lower()

    fields = []
    for field in reg.get("fields", []):
        bit_offset = field.get("bit_offset", field.get("bitOffset"))
        bit_width = field.get("bit_width", field.get("bitWidth"))
        if bit_offset is None or bit_width is None:
            bit_offset, bit_width = _parse_bits(field.get("bits"))
        fields.append({
            "name": str(field.get("name", "")),
            "bit_offset": int(bit_offset or 0),
            "bit_width": int(bit_width or 1),
            "access": str(field.get("access", access)).lower(),
        })

    out.append({"name": name, "offset": offset, "access": access, "fields": fields})


def _read_yaml(path: str) -> object:
    with open(path, encoding="utf-8") as fh:
        return yaml.safe_load(fh)


# ---------------------------------------------------------------------------
# Public API
# ---------------------------------------------------------------------------

def load_registers(mm_yml_path: str) -> list:
    """Return a flat list of register dicts from a .mm.yml file.

    Each dict has keys: ``name`` (str), ``offset`` (int), ``access`` (str),
    ``fields`` (list of dicts with ``name``, ``bit_offset``, ``bit_width``,
    ``access``).

    Prefer :func:`load_regmap` for a richer, attribute-accessible API.
    """
    mm_yml_path = os.path.abspath(mm_yml_path)
    if not os.path.exists(mm_yml_path):
        raise FileNotFoundError(f"Memory map not found: {mm_yml_path}")

    data = _read_yaml(mm_yml_path)

    if isinstance(data, dict) and "import" in data:
        import_path = os.path.join(os.path.dirname(mm_yml_path), data["import"])
        data = _read_yaml(import_path)

    mm_list = data if isinstance(data, list) else [data]
    registers: list = []
    for mm in mm_list:
        for block in (mm or {}).get("address_blocks", []):
            block_base = _parse_number(block.get("base_address", 0))
            for reg in block.get("registers", []):
                _process_register(reg, block_base, "", registers)

    return sorted(registers, key=lambda r: r["offset"])


def load_regmap(mm_yml_path: str) -> RegMap:
    """Load a .mm.yml file and return a :class:`RegMap`.

    The ``RegMap`` provides attribute-style and dict-style access to registers
    and their fields.  See the module docstring for usage examples.
    """
    return RegMap([_Register(r) for r in load_registers(mm_yml_path)])
