-- VUnit testbench for {{ entity_name }}
-- Generated by IPCraft
--
-- Run with:  python tb/run.py
-- Single:    python tb/run.py lib.{{ entity_name }}_tb.test_basic_smoke

library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

library vunit_lib;
context vunit_lib.vunit_context;

entity {{ entity_name }}_tb is
  generic (runner_cfg : string);
end entity {{ entity_name }}_tb;

architecture tb of {{ entity_name }}_tb is
  -- Clock period and reset polarity
  constant CLK_PERIOD : time := 10 ns;
  {% if reset_active_high %}constant RESET_ASSERT : std_logic := '1';
  constant RESET_DEASSERT : std_logic := '0';{% else %}constant RESET_ASSERT : std_logic := '0';
  constant RESET_DEASSERT : std_logic := '1';{% endif %}

  signal clk   : std_logic := '0';
  signal rst   : std_logic := RESET_ASSERT;

  -- DUT port signals
{% for port in ports %}
  signal {{ port.name }} : {% if port.width is defined and port.width > 1 %}std_logic_vector({{ port.width - 1 }} downto 0){% else %}std_logic{% endif %} := {% if port.width is defined and port.width > 1 %}(others => '0'){% else %}'0'{% endif %};
{% endfor %}

begin

  -- Clock generation
  clk <= not clk after CLK_PERIOD / 2;

  -- DUT instantiation
  dut : entity work.{{ entity_name }}
    {% if parameters %}generic map (
{% for param in parameters %}      {{ param.name }} => {{ param.value }}{% if not loop.last %},{% endif %}

{% endfor %}    )
    {% endif %}port map (
      {{ clock_port }} => clk,
      {{ reset_port }} => rst{% for port in ports %}{% if port.name != clock_port and port.name != reset_port %},
      {{ port.name }} => {{ port.name }}{% endif %}{% endfor %}

    );

  -- Test process
  test_runner : process
  begin
    test_runner_setup(runner, runner_cfg);

    while test_suite loop

      if run("test_basic_smoke") then
        -- Apply reset
        rst <= RESET_ASSERT;
        wait for 100 ns;
        rst <= RESET_DEASSERT;
        wait until rising_edge(clk);
        wait until rising_edge(clk);

        -- Run for 20 clock cycles
        for i in 1 to 20 loop
          wait until rising_edge(clk);
        end loop;

        check(true, "Smoke test: DUT ran 20 cycles after reset");

      end if;

    end loop;

    test_runner_cleanup(runner);
  end process;

end architecture tb;
