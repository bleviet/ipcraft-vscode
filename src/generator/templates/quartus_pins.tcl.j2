# Quartus board pin + I/O-standard assignments for {{ entity_name }} on {{ board_name }}
# Generated by IPCraft
#
# Sourced from the board project Tcl before project_close so the assignments land in the
# project's .qsf alongside the RTL/SDC/device settings.

{% if assignments %}
{% for a in assignments %}
set_location_assignment {{ a.pin }} -to {{ a.port }}
{% if a.ioStandard %}
set_instance_assignment -name IO_STANDARD "{{ a.ioStandard }}" -to {{ a.port }}
{% endif %}
{% endfor %}
{% else %}
# No pin assignments — the board/IP port map produced no matches.
{% endif %}
