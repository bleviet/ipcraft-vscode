{# SystemVerilog Avalon-MM Bus Wrapper Template #}
{# Generates Avalon-MM slave interface with register decoding #}
////////////////////////////////////////////////////////////////////////////////
// Module: {{ entity_name }}_avmm
// Description: Avalon-MM slave interface for register access
// Generated by ipcraft SystemVerilog Generator
//
// Register Map:
{% for reg in registers %}
//   {{ "0x%04X" | format(reg.offset) }} : {{ reg.name }} ({{ reg.access }})
{% endfor %}
////////////////////////////////////////////////////////////////////////////////
`timescale 1ns / 1ps

{# Header import, not compilation-unit scope: iverilog 12 cannot resolve
   functions imported into $unit, only types and parameters. #}
module {{ entity_name }}_avmm
  import {{ entity_name }}_pkg::*;
(
  // Clock and reset
  input  logic clk,
  input  logic rst,
{% set has_regs_in = hw_registers | length > 0 or w1c_registers | length > 0 or sc_registers | length > 0 or cos_registers | length > 0 %}
{% if bus_ports | length > 0 %}

  // Avalon-MM Slave Interface
{% for port in bus_ports %}
  {{ "%-6s"|format(port.sv_direction) }} {{ "%-34s"|format(port.sv_type) }} {{ port.name }}{{ "," if not loop.last or sw_registers | length > 0 or has_regs_in else "" }}
{% endfor %}
{% endif %}

  // Register interface
{% if sw_registers | length > 0 %}
  output regs_sw2hw_t regs_out{{ "," if has_regs_in else "" }}  // To core (SW-writable)
{% endif %}
{% if has_regs_in %}
  input  regs_hw2sw_t regs_in   // From core (HW-writable / W1C pulses / CoS values)
{% endif %}
);

  // Bus internal signals
  logic [C_ADDR_WIDTH-1:0]     address;
  logic                        avmm_read;
  logic                        avmm_write;
  logic [C_DATA_WIDTH-1:0]     writedata;
  logic [(C_DATA_WIDTH/8)-1:0] byteenable;
  logic [C_DATA_WIDTH-1:0]     readdata;
  logic                        readdatavalid;
  logic                        waitrequest;

  ////////////////////////////////////////////////////////////////////////////
  // Bus Interface Connections
  ////////////////////////////////////////////////////////////////////////////
{% set address_port       = (bus_ports | selectattr('logical_name', 'equalto', 'address')       | list) %}
{% set read_port          = (bus_ports | selectattr('logical_name', 'equalto', 'read')          | list) %}
{% set write_port         = (bus_ports | selectattr('logical_name', 'equalto', 'write')         | list) %}
{% set writedata_port     = (bus_ports | selectattr('logical_name', 'equalto', 'writedata')     | list) %}
{% set byteenable_port    = (bus_ports | selectattr('logical_name', 'equalto', 'byteenable')    | list) %}
{% set readdata_port      = (bus_ports | selectattr('logical_name', 'equalto', 'readdata')      | list) %}
{% set readdatavalid_port = (bus_ports | selectattr('logical_name', 'equalto', 'readdatavalid') | list) %}
{% set waitrequest_port   = (bus_ports | selectattr('logical_name', 'equalto', 'waitrequest')   | list) %}

  always_comb begin
    address    = {{ address_port[0].name ~ "[C_ADDR_WIDTH-1:0]" if address_port | length > 0 else "'0" }};
    avmm_read  = {{ read_port[0].name      if read_port      | length > 0 else "1'b0" }};
    avmm_write = {{ write_port[0].name     if write_port     | length > 0 else "1'b0" }};
    writedata  = {{ writedata_port[0].name if writedata_port | length > 0 else "'0" }};
{% if byteenable_port | length > 0 %}
    byteenable = {{ byteenable_port[0].name }};
{% else %}
    byteenable = '1;
{% endif %}
  end

{% if readdata_port | length > 0 %}
  assign {{ readdata_port[0].name }} = readdata;
{% endif %}
{% if readdatavalid_port | length > 0 %}
  assign {{ readdatavalid_port[0].name }} = readdatavalid;
{% endif %}
{% if waitrequest_port | length > 0 %}
  assign {{ waitrequest_port[0].name }} = waitrequest;
{% endif %}

  // No wait states
  assign waitrequest = 1'b0;

  ////////////////////////////////////////////////////////////////////////////
  // Register Bank Instantiation
  ////////////////////////////////////////////////////////////////////////////
  {{ entity_name }}_regs u_regs (
    .clk      (clk),
    .rst      (rst),
    .wr_en    (avmm_write),
    .wr_addr  (address),
    .wr_data  (writedata),
    .wr_strb  (byteenable),
    .rd_en    (avmm_read),
    .rd_addr  (address),
    .rd_data  (readdata),
    .rd_valid (readdatavalid){% if sw_registers | length > 0 or has_regs_in %},{% endif %}

{% if sw_registers | length > 0 %}
    .regs_out (regs_out){{ "," if has_regs_in else "" }}
{% endif %}
{% if has_regs_in %}
    .regs_in  (regs_in)
{% endif %}
  );

endmodule : {{ entity_name }}_avmm
