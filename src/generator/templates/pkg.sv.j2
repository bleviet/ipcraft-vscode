{# SystemVerilog Package Template for IP Core #}
{# Generates register types, constants, and conversion functions #}
////////////////////////////////////////////////////////////////////////////////
// Package: {{ entity_name }}_pkg
// Generated by ipcraft SystemVerilog Generator
////////////////////////////////////////////////////////////////////////////////

`timescale 1ns / 1ps

package {{ entity_name }}_pkg;

  ////////////////////////////////////////////////////////////////////////////
  // Constants
  ////////////////////////////////////////////////////////////////////////////
  localparam int C_DATA_WIDTH = {{ data_width | default(32) }};
  localparam int C_ADDR_WIDTH = {{ addr_width | default(8) }};
  localparam int C_REG_WIDTH  = {{ reg_width | default(4) }};  // Bytes per register

{% if has_endian_swap %}
  ////////////////////////////////////////////////////////////////////////////
  // Endianness (big-endian ports are byte-swapped at the top level)
  ////////////////////////////////////////////////////////////////////////////
{% for width in endian_swap_widths %}
  // Reverses byte order of a {{ width }}-bit vector.
  function automatic logic [{{ width - 1 }}:0] swap_bytes_{{ width }}(input logic [{{ width - 1 }}:0] x);
{% for byte_idx in range((width // 8)) %}
    swap_bytes_{{ width }}[{{ (byte_idx + 1) * 8 - 1 }}:{{ byte_idx * 8 }}] = x[{{ width - byte_idx * 8 - 1 }}:{{ width - (byte_idx + 1) * 8 }}];
{% endfor %}
  endfunction

{% endfor %}
{% endif %}
{% if registers | length %}
  ////////////////////////////////////////////////////////////////////////////
  // Register Address Map (byte offset, matches the resolved memory map and
  // the generated component.xml -- never derived from declaration order)
  ////////////////////////////////////////////////////////////////////////////
{% for reg in registers %}
  localparam logic [C_ADDR_WIDTH-1:0] REG_{{ reg.name | upper }}_ADDR = {{ reg.offset }};  // addr {{ "0x%02X" | format(reg.offset) }}
{% endfor %}

{% endif %}
  ////////////////////////////////////////////////////////////////////////////
  // Register Field Structs and Conversion Functions
  ////////////////////////////////////////////////////////////////////////////
{% for reg in registers %}
{% if reg.fields | length %}

  // {{ reg.name }} register fields
  typedef struct packed {
{% for field in reg.fields %}
{% if field.width == 1 %}
    logic        {{ field.name | lower }};  // bit {{ field.offset }}
{% else %}
    logic [{{ field.width - 1 }}:0] {{ field.name | lower }};  // bits {{ field.offset + field.width - 1 }}:{{ field.offset }}
{% endif %}
{% endfor %}
  } {{ reg.name | lower }}_t;

  // Pack {{ reg.name }} fields into a 32-bit bus word
  function automatic logic [C_DATA_WIDTH-1:0] pack_{{ reg.name | lower }}(input {{ reg.name | lower }}_t reg_in);
    logic [C_DATA_WIDTH-1:0] slv;
    slv = '0;
{% for field in reg.fields %}
{% if field.width == 1 %}
    slv[{{ field.offset }}] = reg_in.{{ field.name | lower }};
{% else %}
    slv[{{ field.offset + field.width - 1 }}:{{ field.offset }}] = reg_in.{{ field.name | lower }};
{% endif %}
{% endfor %}
    return slv;
  endfunction

  // Unpack a 32-bit bus word into {{ reg.name }} fields
  function automatic {{ reg.name | lower }}_t unpack_{{ reg.name | lower }}(input logic [C_DATA_WIDTH-1:0] slv);
    {{ reg.name | lower }}_t reg_out;
{% for field in reg.fields %}
{% if field.width == 1 %}
    reg_out.{{ field.name | lower }} = slv[{{ field.offset }}];
{% else %}
    reg_out.{{ field.name | lower }} = slv[{{ field.offset + field.width - 1 }}:{{ field.offset }}];
{% endif %}
{% endfor %}
    return reg_out;
  endfunction
{% endif %}
{% endfor %}

{% if w1c_registers | length %}
  // W1C event-pulse struct types (hardware drives a 1-cycle strobe to set a sticky bit)
{% for reg in w1c_registers %}
{% if reg.fields | length %}
{% set w1c_flds = reg.fields | selectattr('access', 'in', ['write-1-to-clear', 'read-write-1-to-clear']) | selectattr('is_cos', 'equalto', false) %}
{% if w1c_flds | length %}

  // {{ reg.name }} W1C event-pulse fields (external pulse only — CoS fields excluded)
  typedef struct packed {
{% for field in w1c_flds %}
{% if field.width == 1 %}
    logic        {{ field.name | lower }}_pulse;  // event strobe → sets {{ reg.name }}.{{ field.name | lower }}
{% else %}
    logic [{{ field.width - 1 }}:0] {{ field.name | lower }}_pulse;  // per-bit strobes → set {{ reg.name }}.{{ field.name | lower }}
{% endif %}
{% endfor %}
  } {{ reg.name | lower }}_pulse_t;

{% endif %}
{% endif %}
{% endfor %}
{% endif %}
{% if sc_registers | length %}
  // SC event-clear struct types (hardware drives a 1-cycle strobe to clear a bit set by software)
{% for reg in sc_registers %}
{% if reg.fields | length %}
{% set sc_flds = reg.fields | selectattr('access', 'in', ['write-self-clearing', 'read-write-self-clearing']) %}
{% if sc_flds | length %}

  // {{ reg.name }} SC event-clear fields
  typedef struct packed {
{% for field in sc_flds %}
{% if field.width == 1 %}
    logic        {{ field.name | lower }}_clear;  // event strobe → clears {{ reg.name }}.{{ field.name | lower }}
{% else %}
    logic [{{ field.width - 1 }}:0] {{ field.name | lower }}_clear;  // per-bit strobes → clear {{ reg.name }}.{{ field.name | lower }}
{% endif %}
{% endfor %}
  } {{ reg.name | lower }}_clear_t;

{% endif %}
{% endif %}
{% endfor %}
{% endif %}
{% if mixed_registers | length %}
  // Hardware-driven value-port struct types: live values for read-only fields
  // mixed into an otherwise SW-writable register (includes CoS-monitored
  // fields, which are always mixed by construction).
{% for reg in mixed_registers %}
{% if reg.val_fields | length %}

  // {{ reg.name }} hardware-driven field values
  typedef struct packed {
{% for field in reg.val_fields %}
{% if field.width == 1 %}
    logic        {{ field.name | lower }};  // hardware-driven, read-only in {{ reg.name }}
{% else %}
    logic [{{ field.width - 1 }}:0] {{ field.name | lower }};  // hardware-driven, read-only in {{ reg.name }}
{% endif %}
{% endfor %}
  } {{ reg.name | lower }}_val_t;

{% endif %}
{% endfor %}
{% endif %}
{% if sw_registers | length %}
  ////////////////////////////////////////////////////////////////////////////
  // Aggregate Register Structs (for clean port interface)
  ////////////////////////////////////////////////////////////////////////////

  // SW -> HW: Registers written by software, read by hardware
  typedef struct packed {
{% for reg in sw_registers %}
    {{ reg.name | lower }}_t {{ reg.name | lower }};
{% endfor %}
  } regs_sw2hw_t;

{% endif %}
{% set ext_w1c_regs_sv = [] %}
{% for reg in w1c_registers %}
{% set ext_flds = reg.fields | selectattr('access', 'in', ['write-1-to-clear', 'read-write-1-to-clear']) | selectattr('is_cos', 'equalto', false) %}
{% if ext_flds | length %}
{% set _ = ext_w1c_regs_sv.push(reg) %}
{% endif %}
{% endfor %}
{% if hw_registers | length or ext_w1c_regs_sv | length or sc_registers | length or mixed_registers | length %}
  // HW -> SW: Status registers (RO) + W1C/SC event pulses + hardware-driven value ports
  typedef struct packed {
{% for reg in hw_registers %}
    {{ reg.name | lower }}_t {{ reg.name | lower }};
{% endfor %}
{% for reg in ext_w1c_regs_sv %}
{% if reg.fields | length %}
    {{ reg.name | lower }}_pulse_t {{ reg.name | lower }}_pulse;  // W1C event pulses for {{ reg.name }}
{% endif %}
{% endfor %}
{% for reg in sc_registers %}
{% set sc_flds = reg.fields | selectattr('access', 'in', ['write-self-clearing', 'read-write-self-clearing']) %}
{% if sc_flds | length %}
    {{ reg.name | lower }}_clear_t {{ reg.name | lower }}_clear;  // SC event clear pulses for {{ reg.name }}
{% endif %}
{% endfor %}
{% for reg in mixed_registers %}
{% if reg.val_fields | length %}
    {{ reg.name | lower }}_val_t {{ reg.name | lower }}_val;  // hardware-driven values for {{ reg.name }}
{% endif %}
{% endfor %}
  } regs_hw2sw_t;

{% endif %}
endpackage : {{ entity_name }}_pkg
