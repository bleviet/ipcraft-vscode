{# SystemVerilog Package Template for IP Core #}
{# Generates register types, constants, and conversion functions #}
////////////////////////////////////////////////////////////////////////////////
// Package: {{ entity_name }}_pkg
// Generated by ipcraft SystemVerilog Generator
////////////////////////////////////////////////////////////////////////////////

package {{ entity_name }}_pkg;

  ////////////////////////////////////////////////////////////////////////////
  // Constants
  ////////////////////////////////////////////////////////////////////////////
  localparam int C_DATA_WIDTH = {{ data_width | default(32) }};
  localparam int C_ADDR_WIDTH = {{ addr_width | default(8) }};
  localparam int C_REG_WIDTH  = {{ reg_width | default(4) }};  // Bytes per register

{% if registers | length %}
  ////////////////////////////////////////////////////////////////////////////
  // Register Address Map (word index)
  ////////////////////////////////////////////////////////////////////////////
{% for reg in registers %}
  localparam int REG_{{ reg.name | upper }}_ADDR = {{ loop.index0 }};  // byte offset {{ "0x%02X" | format(loop.index0 * reg_width | default(4)) }}
{% endfor %}

{% endif %}
  ////////////////////////////////////////////////////////////////////////////
  // Register Field Structs and Conversion Functions
  ////////////////////////////////////////////////////////////////////////////
{% for reg in registers %}
{% if reg.fields | length %}

  // {{ reg.name }} register fields
  typedef struct packed {
{% for field in reg.fields %}
{% if field.width == 1 %}
    logic        {{ field.name | lower }};  // bit {{ field.offset }}
{% else %}
    logic [{{ field.width - 1 }}:0] {{ field.name | lower }};  // bits {{ field.offset + field.width - 1 }}:{{ field.offset }}
{% endif %}
{% endfor %}
  } {{ reg.name | lower }}_t;

  // Pack {{ reg.name }} fields into a 32-bit bus word
  function automatic logic [C_DATA_WIDTH-1:0] pack_{{ reg.name | lower }}(input {{ reg.name | lower }}_t reg_in);
    logic [C_DATA_WIDTH-1:0] slv;
    slv = '0;
{% for field in reg.fields %}
{% if field.width == 1 %}
    slv[{{ field.offset }}] = reg_in.{{ field.name | lower }};
{% else %}
    slv[{{ field.offset + field.width - 1 }}:{{ field.offset }}] = reg_in.{{ field.name | lower }};
{% endif %}
{% endfor %}
    return slv;
  endfunction

  // Unpack a 32-bit bus word into {{ reg.name }} fields
  function automatic {{ reg.name | lower }}_t unpack_{{ reg.name | lower }}(input logic [C_DATA_WIDTH-1:0] slv);
    {{ reg.name | lower }}_t reg_out;
{% for field in reg.fields %}
{% if field.width == 1 %}
    reg_out.{{ field.name | lower }} = slv[{{ field.offset }}];
{% else %}
    reg_out.{{ field.name | lower }} = slv[{{ field.offset + field.width - 1 }}:{{ field.offset }}];
{% endif %}
{% endfor %}
    return reg_out;
  endfunction
{% endif %}
{% endfor %}

{% if sw_registers | length %}
  ////////////////////////////////////////////////////////////////////////////
  // Aggregate Register Structs (for clean port interface)
  ////////////////////////////////////////////////////////////////////////////

  // SW -> HW: Registers written by software, read by hardware
  typedef struct packed {
{% for reg in sw_registers %}
    {{ reg.name | lower }}_t {{ reg.name | lower }};
{% endfor %}
  } regs_sw2hw_t;

{% endif %}
{% if hw_registers | length %}
  // HW -> SW: Registers written by hardware, read by software
  typedef struct packed {
{% for reg in hw_registers %}
    {{ reg.name | lower }}_t {{ reg.name | lower }};
{% endfor %}
  } regs_hw2sw_t;

{% endif %}
endpackage : {{ entity_name }}_pkg
