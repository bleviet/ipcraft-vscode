////////////////////////////////////////////////////////////////////////////////
// Module: {{ entity_name }}
// Board top wrapper generated by IPCraft — connects board clock/reset nets to
// the packaged IP core {{ ip_entity_name }}. Port names are the board's own net
// names (lowercased) so board pin assignments target this module directly.
////////////////////////////////////////////////////////////////////////////////
`timescale 1ns / 1ps

module {{ entity_name }} (
{% if clock_wrapper_port %}
  input  logic {{ clock_wrapper_port }},
{% endif %}
{% if reset_wrapper_port %}
  input  logic {{ reset_wrapper_port }}{{ "," if user_ports | length else "" }}
{% endif %}
{% for p in user_ports %}
  {{ "input " if p.direction == 'in' else "output" }} logic{{ " [" ~ (p.width - 1) ~ ":0]" if p.width > 1 else "" }} {{ p.wrapper_port }}{{ "," if not loop.last else "" }}
{% endfor %}
);
{% if has_por %}

  // Power-on reset: no external board reset is mapped for {{ reset_ip_port }}, so
  // synthesize one from a free-running counter that releases {{ por_cycles }} clock
  // cycles after configuration.
  logic [{{ por_width - 1 }}:0] por_counter = '0;
  logic por_done = 1'b0;

  always_ff @(posedge {{ clock_wrapper_port }}) begin
    if (!por_done) begin
      por_counter <= por_counter + 1'b1;
      if (por_counter == {{ por_width }}'d{{ por_cycles - 1 }}) begin
        por_done <= 1'b1;
      end
    end
  end
{% endif %}

  {{ ip_entity_name }} u_core (
{% if clock_ip_port %}
    .{{ clock_ip_port }} ({{ clock_wrapper_port }}){{ "," if reset_ip_port or user_ports | length else "" }}
{% endif %}
{% if reset_ip_port %}
    .{{ reset_ip_port }} ({{ "~" if reset_invert }}{{ reset_connection_signal }}){{ "," if user_ports | length else "" }}
{% endif %}
{% for p in user_ports %}
    .{{ p.ip_port }} ({{ p.wrapper_port }}){{ "," if not loop.last else "" }}
{% endfor %}
  );

endmodule : {{ entity_name }}
