{% set has_mixed = mixed_registers | length > 0 %}
  constant C_REGS_HW2SW_RESET : t_regs_hw2sw := (
{% for reg in hw_registers %}
{% set is_last = loop.last and not has_ext_w1c and not has_sc and not has_mixed %}
{% if reg.fields | length %}
