// VUnit testbench for {{ entity_name }}
// Generated by IPCraft
//
// Run with:  python tb/run.py
// Single:    python tb/run.py lib.{{ entity_name }}_tb.test_basic_smoke
//
// Note: VUnit's SystemVerilog support requires a compatible simulator
// (Questa / ModelSim / Aldec) and the vunit_pkg SV package.

`timescale 1ns/1ps

module {{ entity_name }}_tb;
  import vunit_pkg::*;

  // VUnit runner configuration passed via command-line plusargs
  string runner_cfg;
  initial begin
    if (!$value$plusargs("VUNIT_RUNNER_CFG=%s", runner_cfg)) begin
      runner_cfg = "__VUNIT_RUNNER_CFG__";
    end
  end

  // Clock generation (10 ns period)
  logic clk = 1'b0;
  always #5 clk = ~clk;

  // Reset — {% if reset_active_high %}assert high{% else %}assert low{% endif %}
  logic rst = {% if reset_active_high %}1'b1{% else %}1'b0{% endif %};

  // DUT port signals
{% for port in ports %}
  {% if port.width is defined and port.width > 1 %}logic [{{ port.width - 1 }}:0] {{ port.name }} = '0;{% else %}logic {{ port.name }} = 1'b0;{% endif %}
{% endfor %}

  // DUT instantiation
  {{ entity_name }} dut (
    .{{ clock_port }}(clk),
    .{{ reset_port }}(rst){% for port in ports %}{% if port.name != clock_port and port.name != reset_port %},
    .{{ port.name }}({{ port.name }}){% endif %}{% endfor %}

  );

  initial begin
    test_runner_setup(runner, runner_cfg);

    while (test_suite) begin

      if (run("test_basic_smoke")) begin
        // Apply reset
        rst = {% if reset_active_high %}1'b1{% else %}1'b0{% endif %};
        #100;
        rst = {% if reset_active_high %}1'b0{% else %}1'b1{% endif %};
        @(posedge clk);
        @(posedge clk);

        // Run for 20 clock cycles
        repeat (20) @(posedge clk);

        check(1, "Smoke test: DUT ran 20 cycles after reset");
      end

    end

    test_runner_cleanup(runner);
  end

endmodule
