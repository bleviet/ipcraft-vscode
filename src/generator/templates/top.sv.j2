{# SystemVerilog Top-Level Template #}
{# Generates top-level module that instantiates core and bus wrapper #}
////////////////////////////////////////////////////////////////////////////////
// Module: {{ entity_name }}
// Description: {{ description | default('') }}
// Generated by ipcraft SystemVerilog Generator
////////////////////////////////////////////////////////////////////////////////
`timescale 1ns / 1ps

{# Header import, not compilation-unit scope: iverilog 12 cannot resolve
   functions imported into $unit, only types and parameters. #}
module {{ entity_name }}{% if has_memory_mapped_slave %} import {{ entity_name }}_pkg::*;{% endif %}{% if generics | length %} #(
{% for generic in generics %}
  parameter {{ generic.sv_type ~ " " if generic.sv_type }}{{ generic.name }} = {{ generic.sv_default }}{{ "," if not loop.last else "" }}
{% endfor %}
){% endif %} (
  // Clock and reset
  input  logic {{ clock_port }},
  input  logic {{ reset_port }}{{ "," if bus_ports | length or secondary_bus_ports | length or user_ports | length else "" }}
{% for iface in expanded_bus_interfaces %}{% set iface_loop = loop %}
{% if iface.ports %}

  // {{ iface.name }} ({{ iface.mode | upper }})
{% for port in iface.ports %}
  {{ "%-6s"|format(port.sv_direction) }} {{ "%-34s"|format(port.sv_type) }} {{ port.name }}{{ "," if not loop.last or not iface_loop.last or user_ports | length else "" }}
{% endfor %}
{% endif %}
{% endfor %}
{% if user_ports | length %}

  // User ports
{% for port in user_ports %}
  {{ "%-6s"|format(port.sv_direction) }} {{ "%-34s"|format(port.sv_type) }} {{ port.name }}{{ "," if not loop.last else "" }}
{% endfor %}
{% endif %}
);
{% set has_regs_in = hw_registers | length > 0 or w1c_registers | length > 0 or cos_registers | length > 0 %}
{% if has_memory_mapped_slave and (sw_registers | length > 0 or has_regs_in) %}

  // Internal register signals
{% if sw_registers | length > 0 %}
  regs_sw2hw_t regs_sw2hw;
{% endif %}
{% if has_regs_in %}
  regs_hw2sw_t regs_hw2sw;
{% endif %}
{% endif %}
{% if has_memory_mapped_slave %}

  ////////////////////////////////////////////////////////////////////////////
  // Bus Wrapper Instance
  ////////////////////////////////////////////////////////////////////////////
  {{ entity_name }}_{{ bus_type }} u_{{ bus_type }} (
    .clk ({{ clock_port }}),
    .rst ({% if reset_active_high %}{{ reset_port }}{% else %}~{{ reset_port }}{% endif %}){% if bus_ports | length or sw_registers | length > 0 or has_regs_in %},{% endif %}

{% for port in bus_ports %}
    .{{ "%-14s"|format(port.name) }}({{ port.name }}){{ "," if not loop.last or sw_registers | length > 0 or has_regs_in else "" }}
{% endfor %}
{% if sw_registers | length > 0 %}
    .regs_out (regs_sw2hw){{ "," if has_regs_in else "" }}
{% endif %}
{% if has_regs_in %}
    .regs_in  (regs_hw2sw)
{% endif %}
  );

  ////////////////////////////////////////////////////////////////////////////
  // Core Logic Instance
  ////////////////////////////////////////////////////////////////////////////
  {{ entity_name }}_core{% if generics | length %} #(
{% for generic in generics %}
    .{{ generic.name }}({{ generic.name }}){{ "," if not loop.last else "" }}
{% endfor %}
  ){% endif %} u_core (
    .clk ({{ clock_port }}),
    .rst ({% if reset_active_high %}{{ reset_port }}{% else %}~{{ reset_port }}{% endif %}){{ "," if sw_registers | length > 0 or has_regs_in or secondary_bus_ports | length > 0 or user_ports | length > 0 else "" }}
{% if sw_registers | length > 0 %}
    .regs_in  (regs_sw2hw){{ "," if has_regs_in or secondary_bus_ports | length > 0 or user_ports | length > 0 else "" }}
{% endif %}
{% if has_regs_in %}
    .regs_out (regs_hw2sw){{ "," if secondary_bus_ports | length > 0 or user_ports | length > 0 else "" }}
{% endif %}
{% if secondary_bus_interfaces | length %}
{% for iface in secondary_bus_interfaces %}{% set iface_loop = loop %}

    // {{ iface.name }}
{% for port in iface.ports %}
    .{{ "%-14s"|format(port.name) }}({{ port.name }}){{ "," if not loop.last or not iface_loop.last or user_ports | length > 0 else "" }}
{% endfor %}
{% endfor %}
{% endif %}
{% if user_ports | length %}
{% for port in user_ports %}
    .{{ port.name }}({{ port.name }}){{ "," if not loop.last else "" }}
{% endfor %}
{% endif %}
  );

{% endif %}
endmodule : {{ entity_name }}
