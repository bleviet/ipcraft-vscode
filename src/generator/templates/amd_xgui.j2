# Definitional proc to organize widgets for parameters.
proc init_gui { IPINST } {
  ipgui::add_param $IPINST -name "Component_Name"
{% for page in xgui_pages %}
  #Adding Page
  set {{ page.tcl_var }} [ipgui::add_page $IPINST -name "{{ page.name }}"]
{% for group in page.groups %}
  set {{ group.tcl_var }} [ipgui::add_group $IPINST -name "{{ group.name }}" -parent ${{"{"}}{{ page.tcl_var }}{{"}"}}]
{% endfor %}
{% for param in page.ungrouped_params %}
{% if param.tooltip %}
  set {{ param.name }} [ipgui::add_param $IPINST -name "{{ param.name }}" -parent ${{"{"}}{{ page.tcl_var }}{{"}"}}]
  set_property tooltip {{"{"}}{{ param.tooltip }}{{"}"}} ${{"{"}}{{ param.name }}{{"}"}}
{% else %}
  ipgui::add_param $IPINST -name "{{ param.name }}" -parent ${{"{"}}{{ page.tcl_var }}{{"}"}}
{% endif %}
{% endfor %}
{% for group in page.groups %}
{% for param in group.params %}
{% if param.tooltip %}
  set {{ param.name }} [ipgui::add_param $IPINST -name "{{ param.name }}" -parent ${{"{"}}{{ group.tcl_var }}{{"}"}}]
  set_property tooltip {{"{"}}{{ param.tooltip }}{{"}"}} ${{"{"}}{{ param.name }}{{"}"}}
{% else %}
  ipgui::add_param $IPINST -name "{{ param.name }}" -parent ${{"{"}}{{ group.tcl_var }}{{"}"}}
{% endif %}
{% endfor %}
{% endfor %}
{% endfor %}
}

{% for generic in generics %}
proc update_PARAM_VALUE.{{ generic.name }} { PARAM_VALUE.{{ generic.name }} } {
	# Procedure called to update {{ generic.name }} when any of the dependent parameters in the arguments change
}

proc validate_PARAM_VALUE.{{ generic.name }} { PARAM_VALUE.{{ generic.name }} } {
	# Procedure called to validate {{ generic.name }}
	return true
}

proc update_MODELPARAM_VALUE.{{ generic.name }} { MODELPARAM_VALUE.{{ generic.name }} PARAM_VALUE.{{ generic.name }} } {
	# Procedure called to set VHDL generic/Verilog parameter value(s) based on TCL parameter value
	set_property value [get_property value ${PARAM_VALUE.{{ generic.name }}}] ${MODELPARAM_VALUE.{{ generic.name }}}
}
