--------------------------------------------------------------------------------
-- Entity: {{ entity_name }}
-- Board top wrapper generated by IPCraft — connects board clock/reset nets to
-- the packaged IP core {{ ip_entity_name }}. Port names are the board's own net
-- names (lowercased) so board pin assignments target this entity directly.
--------------------------------------------------------------------------------

library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

entity {{ entity_name }} is
  port (
{% if clock_wrapper_port %}
    {{ clock_wrapper_port }} : in std_logic{{ ";" if reset_wrapper_port or user_ports | length else "" }}
{% endif %}
{% if reset_wrapper_port %}
    {{ reset_wrapper_port }} : in std_logic{{ ";" if user_ports | length else "" }}
{% endif %}
{% for p in user_ports %}
    {{ p.wrapper_port }} : {{ "in " if p.direction == 'in' else "out" }} std_logic{{ "_vector(" ~ (p.width - 1) ~ " downto 0)" if p.width > 1 else "" }}{{ ";" if not loop.last else "" }}
{% endfor %}
  );
end entity {{ entity_name }};

architecture rtl of {{ entity_name }} is
{% if has_por %}

  -- Power-on reset: no external board reset is mapped for {{ reset_ip_port }}, so
  -- synthesize one from a free-running counter that releases {{ por_cycles }} clock
  -- cycles after configuration.
  signal por_counter : unsigned({{ por_width - 1 }} downto 0) := (others => '0');
  signal por_done     : std_logic := '0';
{% endif %}

begin
{% if has_por %}

  process ({{ clock_wrapper_port }})
  begin
    if rising_edge({{ clock_wrapper_port }}) then
      if por_done = '0' then
        por_counter <= por_counter + 1;
        if por_counter = to_unsigned({{ por_cycles - 1 }}, {{ por_width }}) then
          por_done <= '1';
        end if;
      end if;
    end if;
  end process;
{% endif %}

  u_core : entity work.{{ ip_entity_name }}
    port map (
{% if clock_ip_port %}
      {{ clock_ip_port }} => {{ clock_wrapper_port }}{{ "," if reset_ip_port or user_ports | length else "" }}
{% endif %}
{% if reset_ip_port %}
      {{ reset_ip_port }} => {{ "not " if reset_invert }}{{ reset_connection_signal }}{{ "," if user_ports | length else "" }}
{% endif %}
{% for p in user_ports %}
      {{ p.ip_port }} => {{ p.wrapper_port }}{{ "," if not loop.last else "" }}
{% endfor %}
    );

end architecture rtl;
