# Quartus synthesis project for {{ entity_name }}
# Generated by IPCraft
#
# Target device : {{ target_device }} ({{ device_family }})
#
# Usage (batch — run from the quartus/ directory):
#   quartus_sh --flow compile {{ entity_name }}
#
# All I/O ports are marked as virtual pins so timing analysis runs without
# board pin assignments, which is sufficient for IP-core timing verification.

set script_dir   [file normalize [file dirname [info script]]]
set project_name {{ entity_name }}

# Remove any existing project files to allow a clean re-run
foreach f [glob -nocomplain $project_name.qpf $project_name.qsf] {
    file delete -force $f
}
foreach d [list db incremental_db] {
    if {[file isdirectory $d]} { file delete -force $d }
}

puts "=== Creating Quartus project ==="
puts "Project : $project_name"
puts "Device  : {{ target_device }}"
puts "Dir     : $script_dir"

project_new $project_name -revision $project_name -overwrite

# ---- Device settings --------------------------------------------------------
set_global_assignment -name FAMILY "{{ device_family }}"
set_global_assignment -name DEVICE {{ target_device }}
set_global_assignment -name VHDL_INPUT_VERSION VHDL_2008
set_global_assignment -name TOP_LEVEL_ENTITY {{ entity_name }}

# ---- RTL source files -------------------------------------------------------
{% for file in rtl_files %}
set_global_assignment -name VHDL_FILE [file normalize [file join $script_dir {{ file }}]]
{% endfor %}

# ---- Timing constraints -----------------------------------------------------
set_global_assignment -name SDC_FILE [file normalize [file join $script_dir {{ sdc_file }}]]

# ---- Virtual pins -----------------------------------------------------------
# Marks every top-level I/O as a virtual (unconstrained) pin so that Quartus
# runs synthesis and timing analysis without requiring board pin assignments.
set_instance_assignment -name VIRTUAL_PIN ON -to *

project_close

puts ""
puts "Project ready.  Run full compilation with:"
puts "  quartus_sh --flow compile $project_name"
puts "Timing report will be written to output_files/${project_name}.sta.summary"
