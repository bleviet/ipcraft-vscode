{# VHDL Standalone Register Bank Template #}
{# Generates a reusable register bank module without bus interface #}
{# Can be instantiated with any bus wrapper #}
--------------------------------------------------------------------------------
-- Entity: {{ entity_name }}_regs
-- Description: Register bank with software/hardware access interface
-- Generated by ipcraft VHDL Generator
--
-- This is a bus-agnostic register bank that provides:
-- - Register storage for SW-writable registers
-- - Pulse generation for write-1-to-clear fields
-- - Clean interface for hardware logic access
--
-- Connect to a bus wrapper (AXI-Lite, Avalon-MM, etc.) for host access.
--------------------------------------------------------------------------------

library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;

use work.{{ entity_name }}_pkg.all;

entity {{ entity_name }}_regs is
  port (
    -- Clock and reset
    clk : in std_logic;
    rst : in std_logic;

    -- Write interface (from bus wrapper)
    wr_en   : in  std_logic;
    wr_addr : in  std_logic_vector(C_ADDR_WIDTH-1 downto 0);
    wr_data : in  std_logic_vector(C_DATA_WIDTH-1 downto 0);
    wr_strb : in  std_logic_vector((C_DATA_WIDTH/8)-1 downto 0);

    -- Read interface (from bus wrapper)
    rd_en   : in  std_logic;
    rd_addr : in  std_logic_vector(C_ADDR_WIDTH-1 downto 0);
    rd_data : out std_logic_vector(C_DATA_WIDTH-1 downto 0);
    rd_valid: out std_logic;

    -- Register interface to core logic
{% if sw_registers | length > 0 %}
    regs_out : out t_regs_sw2hw{{ ";" if hw_registers | length > 0 or w1c_registers | length > 0 or sc_registers | length > 0 or cos_registers | length > 0 else "" }}  -- SW-writable registers (to core)
{% endif %}
{% if hw_registers | length > 0 or w1c_registers | length > 0 or sc_registers | length > 0 or cos_registers | length > 0 %}
    regs_in  : in  t_regs_hw2sw   -- HW status registers + W1C event pulses + CoS values (from core)
{% endif %}
  );
end entity {{ entity_name }}_regs;

architecture rtl of {{ entity_name }}_regs is

  -- Internal register storage
{% if sw_registers | length > 0 %}
  signal regs : t_regs_sw2hw := C_REGS_SW2HW_RESET;
{% endif %}

  -- Read data pipeline
  signal rd_data_int  : std_logic_vector(C_DATA_WIDTH-1 downto 0);
  signal rd_valid_int : std_logic;
{% if cos_registers | length %}

  -- Shadow registers and CoS pulse signals for change-of-state detection
{% for reg in cos_registers %}
{% for cf in reg.cos_fields %}
{% if cf.monitored_field.width == 1 %}
  signal {{ reg.name | lower }}_{{ cf.monitored_field.name | lower }}_shadow : std_logic := '0';
{% else %}
  signal {{ reg.name | lower }}_{{ cf.monitored_field.name | lower }}_shadow : std_logic_vector({{ cf.monitored_field.width - 1 }} downto 0) := (others => '0');
{% endif %}
  signal {{ reg.name | lower }}_{{ cf.name | lower }}_cos : std_logic;
{% endfor %}
{% endfor %}
{% endif %}

  -- Apply write strobe to data
  function apply_wstrb(
    old_data : std_logic_vector(C_DATA_WIDTH-1 downto 0);
    new_data : std_logic_vector(C_DATA_WIDTH-1 downto 0);
    wstrb    : std_logic_vector((C_DATA_WIDTH/8)-1 downto 0)
  ) return std_logic_vector is
    variable result : std_logic_vector(C_DATA_WIDTH-1 downto 0);
  begin
    for i in 0 to (C_DATA_WIDTH/8)-1 loop
      if wstrb(i) = '1' then
        result(i*8+7 downto i*8) := new_data(i*8+7 downto i*8);
      else
        result(i*8+7 downto i*8) := old_data(i*8+7 downto i*8);
      end if;
    end loop;
    return result;
  end function;

begin

  -- Output register values to core
{% if sw_registers | length > 0 %}
  regs_out <= regs;
{% endif %}
  rd_data  <= rd_data_int;
  rd_valid <= rd_valid_int;
{% if cos_registers | length %}

  -- Combinatorial CoS pulse detection (current value vs shadow)
{% for reg in cos_registers %}
{% for cf in reg.cos_fields %}
  {{ reg.name | lower }}_{{ cf.name | lower }}_cos <= '1' when regs_in.{{ reg.name | lower }}_val.{{ cf.monitored_field.name | lower }} /= {{ reg.name | lower }}_{{ cf.monitored_field.name | lower }}_shadow else '0';
{% endfor %}
{% endfor %}
{% endif %}

  ----------------------------------------------------------------------------
  -- Write Process
  ----------------------------------------------------------------------------
  p_write : process(clk)
    variable v_addr_index : natural;
    variable v_wdata      : std_logic_vector(C_DATA_WIDTH-1 downto 0);
  begin
    if rising_edge(clk) then
      if rst = '1' then
{% if sw_registers | length > 0 %}
        regs <= C_REGS_SW2HW_RESET;
{% else %}
        null;
{% endif %}
      else
        v_addr_index := to_integer(unsigned(wr_addr(C_ADDR_WIDTH-1 downto 2)));

{% if cos_registers | length %}
        -- Shadow register updates (capture monitored field values every clock)
{% for reg in cos_registers %}
{% for cf in reg.cos_fields %}
        {{ reg.name | lower }}_{{ cf.monitored_field.name | lower }}_shadow <= regs_in.{{ reg.name | lower }}_val.{{ cf.monitored_field.name | lower }};
{% endfor %}
{% endfor %}

{% endif %}
{% if w1c_registers | length > 0 %}
        -- W1C arbitration: hardware event-set has priority over CPU Write-1-to-Clear.
        -- Runs every clock cycle so no pulse is missed even when the CPU is not writing.
{% for reg in w1c_registers %}
{% set ext_flds = reg.fields | selectattr('access', 'in', ['write-1-to-clear', 'read-write-1-to-clear']) | selectattr('is_cos', 'equalto', false) %}
{% for field in ext_flds %}
{% if field.width == 1 %}
        if regs_in.{{ reg.name | lower }}_pulse.{{ field.name | lower }}_pulse = '1' then
          regs.{{ reg.name | lower }}.{{ field.name | lower }} <= '1';
        elsif wr_en = '1' and v_addr_index = t_reg_index'pos(REG_{{ reg.name | upper }})
              and wr_strb({{ (field.offset / 8) | int }}) = '1' and wr_data({{ field.offset }}) = '1' then
          regs.{{ reg.name | lower }}.{{ field.name | lower }} <= '0';
        end if;
{% else %}
        for i in 0 to {{ field.width - 1 }} loop
          if regs_in.{{ reg.name | lower }}_pulse.{{ field.name | lower }}_pulse(i) = '1' then
            regs.{{ reg.name | lower }}.{{ field.name | lower }}(i) <= '1';
          elsif wr_en = '1' and v_addr_index = t_reg_index'pos(REG_{{ reg.name | upper }})
                and wr_strb(({{ field.offset }} + i) / 8) = '1' and wr_data({{ field.offset }} + i) = '1' then
            regs.{{ reg.name | lower }}.{{ field.name | lower }}(i) <= '0';
          end if;
        end loop;
{% endif %}
{% endfor %}
{% endfor %}

{% endif %}
{% if sc_registers | length > 0 %}
        -- SC arbitration: hardware event-clear has priority over CPU set.
        -- Runs every clock cycle so no pulse is missed even when the CPU is not writing.
{% for reg in sc_registers %}
{% set sc_flds = reg.fields | selectattr('access', 'in', ['write-self-clearing', 'read-write-self-clearing']) %}
{% for field in sc_flds %}
{% if field.width == 1 %}
        if regs_in.{{ reg.name | lower }}_clear.{{ field.name | lower }}_clear = '1' then
          regs.{{ reg.name | lower }}.{{ field.name | lower }} <= '0';
        elsif wr_en = '1' and v_addr_index = t_reg_index'pos(REG_{{ reg.name | upper }})
              and wr_strb({{ (field.offset / 8) | int }}) = '1' and wr_data({{ field.offset }}) = '1' then
          regs.{{ reg.name | lower }}.{{ field.name | lower }} <= '1';
        end if;
{% else %}
        for i in 0 to {{ field.width - 1 }} loop
          if regs_in.{{ reg.name | lower }}_clear.{{ field.name | lower }}_clear(i) = '1' then
            regs.{{ reg.name | lower }}.{{ field.name | lower }}(i) <= '0';
          elsif wr_en = '1' and v_addr_index = t_reg_index'pos(REG_{{ reg.name | upper }})
                and wr_strb(({{ field.offset }} + i) / 8) = '1' and wr_data({{ field.offset }} + i) = '1' then
            regs.{{ reg.name | lower }}.{{ field.name | lower }}(i) <= '1';
          end if;
        end loop;
{% endif %}
{% endfor %}
{% endfor %}

{% endif %}
{% if cos_registers | length %}
        -- CoS W1C arbitration (internally generated change-of-state pulse)
{% for reg in cos_registers %}
{% for cf in reg.cos_fields %}
{% if cf.width == 1 %}
        if {{ reg.name | lower }}_{{ cf.name | lower }}_cos = '1' then
          regs.{{ reg.name | lower }}.{{ cf.name | lower }} <= '1';
        elsif wr_en = '1' and v_addr_index = t_reg_index'pos(REG_{{ reg.name | upper }})
              and wr_strb({{ (cf.offset / 8) | int }}) = '1' and wr_data({{ cf.offset }}) = '1' then
          regs.{{ reg.name | lower }}.{{ cf.name | lower }} <= '0';
        end if;
{% else %}
        for i in 0 to {{ cf.width - 1 }} loop
          if {{ reg.name | lower }}_{{ cf.name | lower }}_cos = '1' then
            regs.{{ reg.name | lower }}.{{ cf.name | lower }}(i) <= '1';
          elsif wr_en = '1' and v_addr_index = t_reg_index'pos(REG_{{ reg.name | upper }})
                and wr_strb(({{ cf.offset }} + i) / 8) = '1' and wr_data({{ cf.offset }} + i) = '1' then
            regs.{{ reg.name | lower }}.{{ cf.name | lower }}(i) <= '0';
          end if;
        end loop;
{% endif %}
{% endfor %}
{% endfor %}

{% endif %}
        if wr_en = '1' then
          case v_addr_index is
{% for reg in registers %}
{% if reg.access in ['read-write', 'write-only', 'rw', 'wo', 'read_write', 'write_only'] %}
{% set blocked_flds = reg.fields | selectattr('access', 'in', ['write-1-to-clear', 'read-write-1-to-clear', 'write-self-clearing', 'read-write-self-clearing', 'read-only', 'ro']) %}
          when t_reg_index'pos(REG_{{ reg.name | upper }}) =>
{% if reg.fields | length %}
{% if blocked_flds | length %}
            v_wdata := apply_wstrb(to_slv(regs.{{ reg.name | lower }}), wr_data, wr_strb);
{% for field in reg.fields %}
{% if field.access not in ['write-1-to-clear', 'read-write-1-to-clear', 'write-self-clearing', 'read-write-self-clearing', 'read-only', 'ro'] %}
            regs.{{ reg.name | lower }}.{{ field.name | lower }} <= to_{{ reg.name | lower }}(v_wdata).{{ field.name | lower }};
{% endif %}
{% endfor %}
{% else %}
            v_wdata := apply_wstrb(to_slv(regs.{{ reg.name | lower }}), wr_data, wr_strb);
            regs.{{ reg.name | lower }} <= to_{{ reg.name | lower }}(v_wdata);
{% endif %}
{% else %}
            regs.{{ reg.name | lower }} <= apply_wstrb(regs.{{ reg.name | lower }}, wr_data, wr_strb);
{% endif %}
{% endif %}
{% endfor %}
          when others =>
            null;
          end case;
        end if;
      end if;
    end if;
  end process;

  ----------------------------------------------------------------------------
  -- Read Process
  ----------------------------------------------------------------------------
  p_read : process(clk)
    variable v_addr_index : natural;
{% if cos_registers | length %}
    variable v_rd_data    : std_logic_vector(C_DATA_WIDTH-1 downto 0);
{% endif %}
  begin
    if rising_edge(clk) then
      rd_valid_int <= '0';

      if rst = '1' then
        rd_data_int  <= (others => '0');
        rd_valid_int <= '0';
      elsif rd_en = '1' then
        v_addr_index := to_integer(unsigned(rd_addr(C_ADDR_WIDTH-1 downto 2)));

        case v_addr_index is
{% for reg in registers %}
{% if not reg.has_cos_fields %}
{% if reg.access in ['read-only', 'ro', 'read_only'] %}
          when t_reg_index'pos(REG_{{ reg.name | upper }}) =>
{% if reg.fields | length %}
            rd_data_int <= to_slv(regs_in.{{ reg.name | lower }});
{% else %}
            rd_data_int <= regs_in.{{ reg.name | lower }};
{% endif %}
{% elif reg.access in ['read-write', 'rw', 'read_write', 'read-write-1-to-clear', 'read-write-self-clearing'] %}
          when t_reg_index'pos(REG_{{ reg.name | upper }}) =>
{% if reg.fields | length %}
            rd_data_int <= to_slv(regs.{{ reg.name | lower }});
{% else %}
            rd_data_int <= regs.{{ reg.name | lower }};
{% endif %}
{% endif %}
{% endif %}
{% endfor %}
{% for reg in cos_registers %}
          when t_reg_index'pos(REG_{{ reg.name | upper }}) =>
            v_rd_data := (others => '0');
{% for field in reg.fields %}
{% if field.access in ['write-1-to-clear', 'read-write-1-to-clear', 'write-self-clearing', 'read-write-self-clearing'] %}
{% if field.width == 1 %}
            v_rd_data({{ field.offset }}) := regs.{{ reg.name | lower }}.{{ field.name | lower }};
{% else %}
            v_rd_data({{ field.offset + field.width - 1 }} downto {{ field.offset }}) := regs.{{ reg.name | lower }}.{{ field.name | lower }};
{% endif %}
{% elif field.access in ['read-only', 'ro'] %}
{% if field.width == 1 %}
            v_rd_data({{ field.offset }}) := regs_in.{{ reg.name | lower }}_val.{{ field.name | lower }};
{% else %}
            v_rd_data({{ field.offset + field.width - 1 }} downto {{ field.offset }}) := regs_in.{{ reg.name | lower }}_val.{{ field.name | lower }};
{% endif %}
{% elif field.access in ['read-write', 'rw'] %}
{% if field.width == 1 %}
            v_rd_data({{ field.offset }}) := regs.{{ reg.name | lower }}.{{ field.name | lower }};
{% else %}
            v_rd_data({{ field.offset + field.width - 1 }} downto {{ field.offset }}) := regs.{{ reg.name | lower }}.{{ field.name | lower }};
{% endif %}
{% endif %}
{% endfor %}
            rd_data_int <= v_rd_data;
{% endfor %}
          when others =>
            rd_data_int <= (others => '0');
        end case;

        rd_valid_int <= '1';
      end if;
    end if;
  end process;

end architecture rtl;
