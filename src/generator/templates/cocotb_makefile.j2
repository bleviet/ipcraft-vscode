# Makefile for cocotb simulation — {{ engine_display_name }}
# Generated by ipcraft VHDL Generator
#
# Usage:
#   make                    # Run all tests
#   make SIM={{ engine_sim_var }}       # Explicitly specify simulator
#   make WAVES=0            # Suppress waveform generation
#   make TESTCASE=test_xyz  # Run specific test
#
# Prerequisites:
#   - {{ engine_display_name }}
#   - cocotb (pip install cocotb)
{% if bus_type in ['axil', 'axi4'] %}
#   - cocotbext-axi (pip install cocotbext-axi)
{% endif %}

# Simulator settings
SIM ?= {{ engine_sim_var }}
TOPLEVEL_LANG ?= vhdl

# VHDL source files (relative to tb/ directory)
BASE_DIR = $(CURDIR)/..
{% if rtl_source_files | length > 0 %}
# From ip.yml fileSets
{% for src in rtl_source_files %}
VHDL_SOURCES += $(BASE_DIR)/{{ src }}
{% endfor %}
{% else %}
# Derived from entity structure
{% if has_memory_mapped_slave %}
VHDL_SOURCES += $(BASE_DIR)/rtl/{{ entity_name }}_pkg.vhd
VHDL_SOURCES += $(BASE_DIR)/rtl/{{ entity_name }}_regs.vhd
VHDL_SOURCES += $(BASE_DIR)/rtl/{{ entity_name }}_core.vhd
{% if bus_type == 'axil' or bus_type == 'avmm' %}
VHDL_SOURCES += $(BASE_DIR)/rtl/{{ entity_name }}_{{ bus_type }}.vhd
{% endif %}
{% endif %}
VHDL_SOURCES += $(BASE_DIR)/rtl/{{ entity_name }}.vhd
{% endif %}

# Top-level module
TOPLEVEL = {{ top_level }}

# Test module (Python file without .py extension)
MODULE = {{ entity_name }}_test
# Required for Questa/ModelSim: cocotb reads this env var directly inside vsim
export COCOTB_TEST_MODULES = $(MODULE)

{% if engine_cocotb_run_args_var %}
# Simulator flags — routed through {{ engine_cocotb_run_args_var }} (not
# {{ engine_cocotb_compile_var }}) because {{ engine_display_name }} must see these same
# flags again at run time (not just at analyse time) or it can't locate the elaborated
# design; {{ engine_cocotb_run_args_var }} feeds GHDL_ARGS, which cocotb's Makefile.ghdl
# applies to both analyse and run
{{ engine_cocotb_run_args_var }} += {{ engine_compile_args }}
{% else %}
# Simulator compile flags
{{ engine_cocotb_compile_var }} += {{ engine_compile_args }}
{% endif %}
{% if engine_extra_compile_args %}

# Extra compile flags from simulation.compileArgs in the .ip.yml
{{ engine_cocotb_compile_var }} += {{ engine_extra_compile_args }}
{% endif %}

{% if engine_wave_args %}
# Generate waveforms by default; suppress with WAVES=0
WAVES ?= 1
ifeq ($(WAVES),1)
{% for arg in engine_wave_args %}
    SIM_ARGS += {{ arg }}
{% endfor %}
endif
{% endif %}
{% if engine_extra_sim_args %}

# Extra sim flags from simulation.simArgs in the .ip.yml
SIM_ARGS += {{ engine_extra_sim_args }}
{% endif %}

# Cocotb settings
export COCOTB_REDUCED_LOG_FMT=1
{% for kv in engine_extra_env %}
export {{ kv.key }}={{ kv.value }}
{% endfor %}



# Default target
include $(shell cocotb-config --makefiles)/Makefile.sim

# Additional targets
.PHONY: clean_all view_waves lint

clean_all: clean
	rm -rf sim_build __pycache__ results.xml *.{{ engine_wave_ext }}

view_waves:
	{{ engine_wave_viewer_cmd }}

lint:
	@echo "Checking VHDL syntax..."
	@for f in $(VHDL_SOURCES); do \
		echo "  $$f"; \
		ghdl -a --std=08 $$f || exit 1; \
	done
	@echo "All files OK"

# Help target
help:
	@echo "cocotb Testbench for {{ entity_name }}"
	@echo ""
	@echo "Targets:"
	@echo "  make            - Run all tests"
	@echo "  make WAVES=0    - Run tests without generating waveforms"
	@echo "  make view_waves - Open waveforms"
	@echo "  make lint       - Check VHDL syntax (uses GHDL)"
	@echo "  make clean      - Remove simulation build files"
	@echo "  make clean_all  - Remove all generated files"
	@echo ""
	@echo "Options:"
	@echo "  SIM={{ engine_sim_var }}|ghdl|questa  - Simulator (default: {{ engine_sim_var }})"
	@echo "  WAVES=0                   - Suppress waveform generation (default: 1)"
	@echo "  TESTCASE=test_name        - Run specific test"
	@echo "  COCOTB_LOG_LEVEL=DEBUG    - Verbose logging"
