{# SystemVerilog Standalone Register Bank Template #}
{# Generates a reusable register bank module without bus interface #}
{# Can be instantiated with any bus wrapper #}
////////////////////////////////////////////////////////////////////////////////
// Module: {{ entity_name }}_regs
// Description: Register bank with software/hardware access interface
// Generated by ipcraft SystemVerilog Generator
//
// This is a bus-agnostic register bank that provides:
// - Register storage for SW-writable registers
// - Clean interface for hardware logic access
//
// Connect to a bus wrapper (AXI-Lite, Avalon-MM, etc.) for host access.
////////////////////////////////////////////////////////////////////////////////
`timescale 1ns / 1ps

import {{ entity_name }}_pkg::*;

module {{ entity_name }}_regs (
  // Clock and reset
  input  logic clk,
  input  logic rst,

  // Write interface (from bus wrapper)
  input  logic                          wr_en,
  input  logic [C_ADDR_WIDTH-1:0]       wr_addr,
  input  logic [C_DATA_WIDTH-1:0]       wr_data,
  input  logic [(C_DATA_WIDTH/8)-1:0]   wr_strb,

  // Read interface (from bus wrapper)
  input  logic                          rd_en,
  input  logic [C_ADDR_WIDTH-1:0]       rd_addr,
  output logic [C_DATA_WIDTH-1:0]       rd_data,
  output logic                          rd_valid{% if sw_registers | length > 0 or hw_registers | length > 0 or w1c_registers | length > 0 or cos_registers | length > 0 %},{% endif %}

  // Register interface to core logic
{% if sw_registers | length > 0 %}
  output regs_sw2hw_t regs_out{{ "," if hw_registers | length > 0 or w1c_registers | length > 0 or cos_registers | length > 0 else "" }}  // SW-writable registers (to core)
{% endif %}
{% if hw_registers | length > 0 or w1c_registers | length > 0 or cos_registers | length > 0 %}
  input  regs_hw2sw_t regs_in   // HW status registers + W1C event pulses + CoS values (from core)
{% endif %}
);

  // Internal register storage
{% if sw_registers | length > 0 %}
  regs_sw2hw_t regs;
{% endif %}

  // Read data pipeline
  logic [C_DATA_WIDTH-1:0] rd_data_int;
  logic                    rd_valid_int;
{% if cos_registers | length %}

  // Shadow registers and CoS pulse signals for change-of-state detection
{% for reg in cos_registers %}
{% for cf in reg.cos_fields %}
{% if cf.monitored_field.width == 1 %}
  logic        {{ reg.name | lower }}_{{ cf.monitored_field.name | lower }}_shadow;
{% else %}
  logic [{{ cf.monitored_field.width - 1 }}:0] {{ reg.name | lower }}_{{ cf.monitored_field.name | lower }}_shadow;
{% endif %}
  logic        {{ reg.name | lower }}_{{ cf.name | lower }}_cos;
{% endfor %}
{% endfor %}
{% endif %}

  // Apply write strobe: merge new bytes from wr_data into existing word
  function automatic logic [C_DATA_WIDTH-1:0] apply_wstrb(
    input logic [C_DATA_WIDTH-1:0]     old_data,
    input logic [C_DATA_WIDTH-1:0]     new_data,
    input logic [(C_DATA_WIDTH/8)-1:0] wstrb
  );
    logic [C_DATA_WIDTH-1:0] result;
    result = old_data;
    for (int i = 0; i < C_DATA_WIDTH/8; i++) begin
      if (wstrb[i]) result[i*8 +: 8] = new_data[i*8 +: 8];
    end
    return result;
  endfunction

  // Output register values to core
{% if sw_registers | length > 0 %}
  assign regs_out  = regs;
{% endif %}
  assign rd_data   = rd_data_int;
  assign rd_valid  = rd_valid_int;
{% if cos_registers | length %}

  // Combinatorial CoS pulse detection (current value vs shadow)
{% for reg in cos_registers %}
{% for cf in reg.cos_fields %}
  assign {{ reg.name | lower }}_{{ cf.name | lower }}_cos = (regs_in.{{ reg.name | lower }}_val.{{ cf.monitored_field.name | lower }} !== {{ reg.name | lower }}_{{ cf.monitored_field.name | lower }}_shadow);
{% endfor %}
{% endfor %}
{% endif %}

  ////////////////////////////////////////////////////////////////////////////
  // Write Process
  ////////////////////////////////////////////////////////////////////////////
  always_ff @(posedge clk) begin : p_write
    if (rst) begin
{% if sw_registers | length > 0 %}
      regs <= '0;
{% endif %}
    end else begin
{% if cos_registers | length %}
      // Shadow register updates (capture monitored field values every clock)
{% for reg in cos_registers %}
{% for cf in reg.cos_fields %}
      {{ reg.name | lower }}_{{ cf.monitored_field.name | lower }}_shadow <= regs_in.{{ reg.name | lower }}_val.{{ cf.monitored_field.name | lower }};
{% endfor %}
{% endfor %}

{% endif %}
{% if w1c_registers | length > 0 %}
      // W1C arbitration: hardware event-set has priority over CPU Write-1-to-Clear.
      // Runs every clock cycle so no pulse is missed even when the CPU is not writing.
{% for reg in w1c_registers %}
{% set ext_flds = reg.fields | selectattr('access', 'in', ['write-1-to-clear', 'read-write-1-to-clear']) | selectattr('is_cos', 'equalto', false) %}
{% for field in ext_flds %}
{% if field.width == 1 %}
      if (regs_in.{{ reg.name | lower }}_pulse.{{ field.name | lower }}_pulse) begin
        regs.{{ reg.name | lower }}.{{ field.name | lower }} <= 1'b1;
      end else if (wr_en && wr_addr[C_ADDR_WIDTH-1:2] == REG_{{ reg.name | upper }}_ADDR
                   && wr_strb[{{ (field.offset / 8) | int }}] && wr_data[{{ field.offset }}]) begin
        regs.{{ reg.name | lower }}.{{ field.name | lower }} <= 1'b0;
      end
{% else %}
      for (int i = 0; i < {{ field.width }}; i++) begin
        if (regs_in.{{ reg.name | lower }}_pulse.{{ field.name | lower }}_pulse[i]) begin
          regs.{{ reg.name | lower }}.{{ field.name | lower }}[i] <= 1'b1;
        end else if (wr_en && wr_addr[C_ADDR_WIDTH-1:2] == REG_{{ reg.name | upper }}_ADDR
                     && wr_strb[({{ field.offset }} + i) / 8] && wr_data[{{ field.offset }} + i]) begin
          regs.{{ reg.name | lower }}.{{ field.name | lower }}[i] <= 1'b0;
        end
      end
{% endif %}
{% endfor %}
{% endfor %}
{% endif %}
{% if cos_registers | length %}
      // CoS W1C arbitration (internally generated change-of-state pulse)
{% for reg in cos_registers %}
{% for cf in reg.cos_fields %}
{% if cf.width == 1 %}
      if ({{ reg.name | lower }}_{{ cf.name | lower }}_cos) begin
        regs.{{ reg.name | lower }}.{{ cf.name | lower }} <= 1'b1;
      end else if (wr_en && wr_addr[C_ADDR_WIDTH-1:2] == REG_{{ reg.name | upper }}_ADDR
                   && wr_strb[{{ (cf.offset / 8) | int }}] && wr_data[{{ cf.offset }}]) begin
        regs.{{ reg.name | lower }}.{{ cf.name | lower }} <= 1'b0;
      end
{% else %}
      for (int i = 0; i < {{ cf.width }}; i++) begin
        if ({{ reg.name | lower }}_{{ cf.name | lower }}_cos) begin
          regs.{{ reg.name | lower }}.{{ cf.name | lower }}[i] <= 1'b1;
        end else if (wr_en && wr_addr[C_ADDR_WIDTH-1:2] == REG_{{ reg.name | upper }}_ADDR
                     && wr_strb[({{ cf.offset }} + i) / 8] && wr_data[{{ cf.offset }} + i]) begin
          regs.{{ reg.name | lower }}.{{ cf.name | lower }}[i] <= 1'b0;
        end
      end
{% endif %}
{% endfor %}
{% endfor %}
{% endif %}
      if (wr_en) begin
        unique case (wr_addr[C_ADDR_WIDTH-1:2])
{% for reg in registers %}
{% if reg.access in ['read-write', 'write-only', 'rw', 'wo', 'read_write', 'write_only'] %}
{% set blocked_flds = reg.fields | selectattr('access', 'in', ['write-1-to-clear', 'read-write-1-to-clear', 'read-only', 'ro']) %}
{% if blocked_flds | length %}
          REG_{{ reg.name | upper }}_ADDR: begin : wr_{{ reg.name | lower }}
            // Temp variable: member select on a function call is not supported
            // by all tools (e.g. Icarus Verilog).
            {{ reg.name | lower }}_t v_new;
            v_new = unpack_{{ reg.name | lower }}(apply_wstrb(pack_{{ reg.name | lower }}(regs.{{ reg.name | lower }}), wr_data, wr_strb));
{% for field in reg.fields %}
{% if field.access not in ['write-1-to-clear', 'read-write-1-to-clear', 'read-only', 'ro'] %}
            regs.{{ reg.name | lower }}.{{ field.name | lower }} <= v_new.{{ field.name | lower }};
{% endif %}
{% endfor %}
          end
{% else %}
          REG_{{ reg.name | upper }}_ADDR: regs.{{ reg.name | lower }} <= unpack_{{ reg.name | lower }}(apply_wstrb(pack_{{ reg.name | lower }}(regs.{{ reg.name | lower }}), wr_data, wr_strb));
{% endif %}
{% endif %}
{% endfor %}
          default: ;
        endcase
      end
    end
  end

  ////////////////////////////////////////////////////////////////////////////
  // Read Process
  ////////////////////////////////////////////////////////////////////////////
  always_ff @(posedge clk) begin : p_read
    rd_valid_int <= 1'b0;
    if (rst) begin
      rd_data_int  <= '0;
      rd_valid_int <= 1'b0;
    end else if (rd_en) begin
      rd_valid_int <= 1'b1;
      unique case (rd_addr[C_ADDR_WIDTH-1:2])
{% for reg in registers %}
{% if not reg.has_cos_fields %}
{% if reg.access in ['read-only', 'ro', 'read_only'] %}
        REG_{{ reg.name | upper }}_ADDR: rd_data_int <= pack_{{ reg.name | lower }}(regs_in.{{ reg.name | lower }});
{% elif reg.access in ['read-write', 'rw', 'read_write', 'read-write-1-to-clear'] %}
        REG_{{ reg.name | upper }}_ADDR: rd_data_int <= pack_{{ reg.name | lower }}(regs.{{ reg.name | lower }});
{% endif %}
{% endif %}
{% endfor %}
{% for reg in cos_registers %}
        REG_{{ reg.name | upper }}_ADDR: begin
          begin : blk_rd_{{ reg.name | lower }}
            logic [C_DATA_WIDTH-1:0] v;
            v = '0;
{% for field in reg.fields %}
{% if field.access in ['write-1-to-clear', 'read-write-1-to-clear'] %}
{% if field.width == 1 %}
            v[{{ field.offset }}] = regs.{{ reg.name | lower }}.{{ field.name | lower }};
{% else %}
            v[{{ field.offset + field.width - 1 }}:{{ field.offset }}] = regs.{{ reg.name | lower }}.{{ field.name | lower }};
{% endif %}
{% elif field.access in ['read-only', 'ro'] %}
{% if field.width == 1 %}
            v[{{ field.offset }}] = regs_in.{{ reg.name | lower }}_val.{{ field.name | lower }};
{% else %}
            v[{{ field.offset + field.width - 1 }}:{{ field.offset }}] = regs_in.{{ reg.name | lower }}_val.{{ field.name | lower }};
{% endif %}
{% elif field.access in ['read-write', 'rw'] %}
{% if field.width == 1 %}
            v[{{ field.offset }}] = regs.{{ reg.name | lower }}.{{ field.name | lower }};
{% else %}
            v[{{ field.offset + field.width - 1 }}:{{ field.offset }}] = regs.{{ reg.name | lower }}.{{ field.name | lower }};
{% endif %}
{% endif %}
{% endfor %}
            rd_data_int <= v;
          end
        end
{% endfor %}
        default: rd_data_int <= '0;
      endcase
    end
  end

endmodule : {{ entity_name }}_regs
