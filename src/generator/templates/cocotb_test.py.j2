@cocotb.test()
async def test_basic_smoke(dut):
    """
    Basic smoke test: verify clock and reset behaviour for {{ entity_name }}.
    Extend this test with stimulus specific to your design.
    """
    cocotb.start_soon(Clock(dut.{{ clock_port }}, 10, units="ns").start())
    await reset_dut(dut)

    # Run for a number of clock cycles and verify the DUT is responsive
    for i in range(20):
        await RisingEdge(dut.{{ clock_port }})

    dut._log.info("Smoke test passed — DUT ran 20 clock cycles after reset")


@cocotb.test()
async def test_reset_behaviour(dut):
    """
    Verify that reset can be applied and released multiple times without error.
    """
    cocotb.start_soon(Clock(dut.{{ clock_port }}, 10, units="ns").start())

    for cycle in range(3):
        await reset_dut(dut)
        for _ in range(10):
            await RisingEdge(dut.{{ clock_port }})
        dut._log.info(f"Reset cycle {cycle + 1} OK")

    dut._log.info("Reset behaviour test passed")
