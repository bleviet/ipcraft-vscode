{% set reset_assert = 1 if reset_active_high else 0 %}
{% set reset_deassert = 0 if reset_active_high else 1 %}
{% if has_memory_mapped_slave %}
import os
import cocotb
from cocotb.clock import Clock
from cocotb.triggers import RisingEdge, Timer
from mm_loader import load_regmap
{% if bus_type in ['axil', 'axi4'] %}
{% if bus_type == 'axil' %}
from cocotbext.axi import AxiLiteMaster, AxiLiteBus
{% else %}
from cocotbext.axi import AxiMaster, AxiBus
{% endif %}


async def _write_reg(master, addr: int, value: int) -> None:
    """Write a 32-bit register value via the AXI master."""
    await master.write(addr, value.to_bytes(4, "little"))


async def _read_reg(master, addr: int) -> int:
    """Read a 32-bit register value via the AXI master."""
    result = await master.read(addr, 4)
    return int.from_bytes(result.data, "little")
{% elif bus_type == 'avmm' %}


async def _write_reg(dut, addr: int, value: int) -> None:
    """Write a 32-bit register over Avalon-MM."""
    dut.{{ bus_prefix }}_address.value = addr >> 2
    dut.{{ bus_prefix }}_writedata.value = value
    if hasattr(dut, "{{ bus_prefix }}_byteenable"):
        dut.{{ bus_prefix }}_byteenable.value = 0xF
    dut.{{ bus_prefix }}_write.value = 1
    await RisingEdge(dut.{{ clock_port }})
    if hasattr(dut, "{{ bus_prefix }}_waitrequest"):
        while dut.{{ bus_prefix }}_waitrequest.value:
            await RisingEdge(dut.{{ clock_port }})
    dut.{{ bus_prefix }}_write.value = 0


async def _read_reg(dut, addr: int) -> int:
    """Read a 32-bit register over Avalon-MM."""
    dut.{{ bus_prefix }}_address.value = addr >> 2
    dut.{{ bus_prefix }}_read.value = 1
    await RisingEdge(dut.{{ clock_port }})
    if hasattr(dut, "{{ bus_prefix }}_waitrequest"):
        while dut.{{ bus_prefix }}_waitrequest.value:
            await RisingEdge(dut.{{ clock_port }})
    dut.{{ bus_prefix }}_read.value = 0
    if hasattr(dut, "{{ bus_prefix }}_readdatavalid"):
        while not dut.{{ bus_prefix }}_readdatavalid.value:
            await RisingEdge(dut.{{ clock_port }})
    return int(dut.{{ bus_prefix }}_readdata.value)
{% endif %}


_MM_YML = os.path.join(os.path.dirname(__file__), "{{ memmap_relpath }}")
regmap = load_regmap(_MM_YML)


async def _reset_dut(dut) -> None:
    """Apply and release reset for {{ entity_name }}."""
    dut.{{ reset_port }}.value = {{ reset_assert }}
    await Timer(100, unit="ns")
    dut.{{ reset_port }}.value = {{ reset_deassert }}
    await RisingEdge(dut.{{ clock_port }})
    await RisingEdge(dut.{{ clock_port }})
    dut._log.info("Reset complete")


@cocotb.test()
async def test_register_access(dut):
    """Test register read/write access for {{ entity_name }}."""
    cocotb.start_soon(Clock(dut.{{ clock_port }}, 10, unit="ns").start())
    await _reset_dut(dut)
{% if bus_type in ['axil', 'axi4'] %}
{% if bus_type == 'axil' %}
    master = AxiLiteMaster(AxiLiteBus.from_prefix(dut, "{{ bus_prefix }}"), dut.{{ clock_port }})
{% else %}
    master = AxiMaster(AxiBus.from_prefix(dut, "{{ bus_prefix }}"), dut.{{ clock_port }})
{% endif %}
{% endif %}

    for reg in regmap:
        if "write" in reg.access:
            await _write_reg({% if bus_type in ['axil', 'axi4'] %}master{% else %}dut{% endif %}, reg.offset, 0xA5A5A5A5)
            if "read" in reg.access:
                val = await _read_reg({% if bus_type in ['axil', 'axi4'] %}master{% else %}dut{% endif %}, reg.offset)
                dut._log.info(f"{reg.name}: wrote 0xA5A5A5A5, read back 0x{val:08X}")
        elif "read" in reg.access:
            val = await _read_reg({% if bus_type in ['axil', 'axi4'] %}master{% else %}dut{% endif %}, reg.offset)
            dut._log.info(f"{reg.name}: 0x{val:08X}")

    dut._log.info("Register access test passed!")


