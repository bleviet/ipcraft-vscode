{% for reg in registers %}
{% set access = reg.access | lower %}
{% if 'read' in access %}
    val = await _read_reg({% if bus_type in ['axil', 'axi4'] %}master{% else %}dut{% endif %}, 0x{{ "%04X" | format(reg.offset) }})
