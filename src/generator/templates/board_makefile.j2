# Makefile for the {{ board_name }} board project — {{ entity_name }}
# Generated by IPCraft
#
# Lets the board project be driven from a terminal without VS Code, mirroring
# the commands the "Open Project" / "Build the Project" toolbar actions run:
#   make project   # create/refresh the Quartus project (.qpf/.qsf) from the TCL
#   make compile   # full synthesis + fitter + timing (implies 'project')
#   make program   # download the .sof to the board over JTAG
#   make clean     # remove generated project/build artifacts
#
# Run from this directory (altera-board/), or `make -C altera-board <target>`.

QUARTUS_SH  ?= quartus_sh
QUARTUS_PGM ?= quartus_pgm
PROJECT     := {{ entity_name }}
JTAG_CABLE  ?= 1

.PHONY: project compile program clean

project:
	$(QUARTUS_SH) -t $(PROJECT)_board_project.tcl

compile: project
	$(QUARTUS_SH) --flow compile $(PROJECT)

program:
	$(QUARTUS_PGM) -c $(JTAG_CABLE) -m JTAG -o "p;output_files/$(PROJECT).sof@1"

clean:
	rm -rf db incremental_db output_files $(PROJECT).qpf $(PROJECT).qsf
