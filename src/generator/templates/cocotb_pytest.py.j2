"""cocotb tests for {{ entity_name }}, wrapped as individual pytest functions.

Each function here maps 1-to-1 to a @cocotb.test() in {{ entity_name }}_test.py,
so VS Code's Testing panel and ``pytest tb/`` both show them as separate tests.

Run all tests:            pytest tb/
Run one test:             pytest tb/ -k test_register_access
Use a different simulator: SIM=icarus pytest tb/

The HDL is compiled once by the ``sim_runner`` fixture in conftest.py.
"""

{% if has_memory_mapped_slave %}
def test_register_access(sim_runner):
    """Read/write all registers via the {{ bus_type | upper }} bus interface."""
    sim_runner("test_register_access")


def test_reset_values(sim_runner):
    """Read all registers immediately after reset and log their values."""
    sim_runner("test_reset_values")
{% else %}

def test_basic_smoke(sim_runner):
    """Verify the DUT clocks and resets cleanly for 20 cycles."""
    sim_runner("test_basic_smoke")


def test_reset_behaviour(sim_runner):
    """Apply and release reset three times; verify no errors."""
    sim_runner("test_reset_behaviour")
{% endif %}
