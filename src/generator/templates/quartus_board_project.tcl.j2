# Quartus board project for {{ entity_name }} on {{ board_name }}
# Generated by IPCraft
#
# Target device : {{ target_device }} ({{ device_family }})
#
# Usage (batch — run from the altera-board/ directory):
#   quartus_sh -t {{ entity_name }}_project.tcl
#   quartus_sh --flow compile {{ entity_name }}
#
# Unlike the IP-OOC timing project ({{ ip_entity_name }}_project.tcl), this project targets
# real board pins for {{ board_name }} — no VIRTUAL_PIN assignment — so a full compile
# produces a programmable .sof.

package require ::quartus::project

set script_dir   [file normalize [file dirname [info script]]]
set project_name {{ entity_name }}

# Gracefully handle already open projects in active session to prevent locking/corruption
if {[is_project_open]} {
    puts "Closing currently open project: [get_current_project]"
    project_close
}

# Remove any existing project files to allow a clean re-run
foreach f [glob -nocomplain $project_name.qpf $project_name.qsf] {
    file delete -force $f
}
foreach d [list db incremental_db] {
    if {[file isdirectory $d]} { file delete -force $d }
}

puts "=== Creating Quartus board project ==="
puts "Project : $project_name"
puts "Device  : {{ target_device }}"
puts "Dir     : $script_dir"

project_new $project_name -revision $project_name -overwrite

# ---- Device settings --------------------------------------------------------
set_global_assignment -name FAMILY "{{ device_family }}"
set_global_assignment -name DEVICE {{ target_device }}
set_global_assignment -name TOP_LEVEL_ENTITY {{ entity_name }}
# Without this, quartus_asm writes the .sof next to the project files instead of
# output_files/ — the location every path below (and BuildCommands' report parser)
# assumes.
set_global_assignment -name PROJECT_OUTPUT_DIRECTORY output_files

# ---- RTL source files -------------------------------------------------------
# Board top wrapper is a sibling of this project file; the IP's own RTL is
# referenced relative to the .ip.yml directory, one level up.
set_global_assignment -name {{ wrapper_hdl_type }} {{ wrapper_file }}
{% for file in ip_rtl_files %}
{% if file.endsWith('.sv') %}
set_global_assignment -name SYSTEMVERILOG_FILE [file join .. {{ file }}]
{% elif file.endsWith('.vhd') or file.endsWith('.vhdl') %}
set_global_assignment -name VHDL_FILE [file join .. {{ file }}]
{% else %}
set_global_assignment -name VERILOG_FILE [file join .. {{ file }}]
{% endif %}
{% endfor %}

# ---- Timing constraints -----------------------------------------------------
set_global_assignment -name SDC_FILE {{ sdc_file }}

# ---- Board pin assignments ---------------------------------------------------
# Real board pins for {{ board_name }} — sourced from the sibling pin file so it stays
# independently generatable/testable (see quartus_pins.tcl.j2).
source [file join $script_dir {{ pins_file }}]

project_close

puts ""
puts "Board project ready.  Run full compilation with:"
puts "  quartus_sh --flow compile $project_name"
puts "Program the board with:"
puts "  quartus_pgm -c 1 -m JTAG -o \"p;output_files/${project_name}.sof@1\""
