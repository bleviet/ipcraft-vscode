# Vivado full synthesis + implementation for {{ entity_name }}
# Generated by IPCraft
#
# Usage (from the xilinx/ directory):
#   vivado -mode batch -source {{ entity_name }}_run_xpr.tcl -nojournal -nolog
#   vivado -mode batch -source {{ entity_name }}_run_xpr.tcl -nojournal -nolog -tclargs 8
#
# Optional argument: number of parallel jobs (default 4).
# Reports are written to xilinx/build/xpr/.

set script_dir   [file normalize [file dirname [info script]]]
set project_name {{ entity_name }}
set project_dir  [file join $script_dir build xpr]
set part         {{ target_part }}
set jobs         [expr {[llength $argv] > 0 ? int([lindex $argv 0]) : 4}]

puts "=== IPCraft: Synthesis + Implementation — {{ entity_name }} ==="
puts "Part      : $part"
puts "Build dir : $project_dir"
puts "Jobs      : $jobs"

if {[file exists $project_dir]} {
    puts "Removing existing build: $project_dir"
    file delete -force $project_dir
}

create_project $project_name $project_dir -part $part

# ---- RTL sources --------------------------------------------------------
{% for file in rtl_files %}
add_files -norecurse [file normalize [file join $script_dir {{ file }}]]
{% endfor %}
set_property file_type {VHDL 2008} [get_files *.vhd]

# ---- Constraints ---------------------------------------------------------
# Standard (non-OOC) XDC — same clock constraints, used for implementation
add_files -fileset constrs_1 \
    [file normalize [file join $script_dir {{ xdc_file }}]]

set_property top {{ entity_name }} [current_fileset]
update_compile_order -fileset sources_1

# ---- Synthesis ----------------------------------------------------------
puts "\n--- Launching synthesis ---"
launch_runs synth_1 -jobs $jobs
wait_on_run synth_1

set synth_status [get_property STATUS [get_runs synth_1]]
puts "Synthesis status: $synth_status"
if {[string match "*error*" [string tolower $synth_status]]} {
    puts "ERROR: Synthesis failed."
    exit 1
}

# ---- Implementation -----------------------------------------------------
puts "\n--- Launching implementation ---"
launch_runs impl_1 -jobs $jobs
wait_on_run impl_1

set impl_status [get_property STATUS [get_runs impl_1]]
puts "Implementation status: $impl_status"
if {[string match "*error*" [string tolower $impl_status]]} {
    puts "ERROR: Implementation failed."
    exit 1
}

# ---- Reports ------------------------------------------------------------
puts "\n--- Generating reports ---"
open_run impl_1 -name impl_1

report_timing_summary \
    -file            [file join $project_dir timing.rpt] \
    -warn_on_violation

report_utilization \
    -file            [file join $project_dir utilization.rpt]

catch {
    report_cdc -file [file join $project_dir cdc.rpt]
}

puts "\n=== Implementation complete ==="
puts "Reports: $project_dir"
puts "Project: [file join $project_dir ${project_name}.xpr]"
exit
