# Makefile for cocotb simulation with Icarus Verilog (SystemVerilog)
# Generated by ipcraft SystemVerilog Generator
#
# Usage:
#   make                    # Run all tests
#   make SIM=icarus         # Explicitly use Icarus Verilog
#   make SIM=verilator      # Use Verilator (faster)
#   make WAVES=0            # Suppress waveform generation
#   make TESTCASE=test_xyz  # Run specific test
#
# Prerequisites:
#   - Icarus Verilog >= 11 (iverilog) — OR — Verilator >= 4.106
#   - cocotb (pip install cocotb)
{% if bus_type in ['axil', 'axi4'] %}
#   - cocotbext-axi (pip install cocotbext-axi)
{% endif %}

# Simulator settings
SIM ?= icarus
TOPLEVEL_LANG ?= verilog

# SystemVerilog source files (relative to tb/ directory)
RTL_DIR = $(CURDIR)/../rtl
{% if has_memory_mapped_slave %}
VERILOG_SOURCES += $(RTL_DIR)/{{ entity_name }}_pkg.sv
VERILOG_SOURCES += $(RTL_DIR)/{{ entity_name }}_regs.sv
VERILOG_SOURCES += $(RTL_DIR)/{{ entity_name }}_core.sv
{% if bus_type == 'axil' or bus_type == 'avmm' %}
VERILOG_SOURCES += $(RTL_DIR)/{{ entity_name }}_{{ bus_type }}.sv
{% endif %}
{% endif %}
VERILOG_SOURCES += $(RTL_DIR)/{{ entity_name }}.sv

# Top-level module
TOPLEVEL = {{ entity_name }}

# Test module (Python file without .py extension)
MODULE = {{ entity_name }}_test

# Icarus Verilog options
ifeq ($(SIM),icarus)
    # Enable SystemVerilog support
    COMPILE_ARGS += -g2012

    # Generate waveforms by default; suppress with WAVES=0
    WAVES ?= 1
    ifeq ($(WAVES),1)
        COMPILE_ARGS += -DCOCOTB_SIM
    endif
endif

# Verilator options
ifeq ($(SIM),verilator)
    COMPILE_ARGS += --sv
    COMPILE_ARGS += -Wno-fatal
    WAVES ?= 1
    ifeq ($(WAVES),1)
        COMPILE_ARGS += --trace-fst
    endif
endif

# Cocotb settings
export COCOTB_REDUCED_LOG_FMT=1



# Default target
include $(shell cocotb-config --makefiles)/Makefile.sim

# Additional targets
.PHONY: clean_all view_waves lint

clean_all: clean
	rm -rf sim_build __pycache__ results.xml *.fst *.vcd *.vzt

view_waves:
	gtkwave {{ entity_name }}.fst &

lint:
	@echo "Checking SystemVerilog syntax..."
	@for f in $(VERILOG_SOURCES); do \
		echo "  $$f"; \
		iverilog -g2012 -tnull $$f || exit 1; \
	done
	@echo "All files OK"

# Help target
help:
	@echo "cocotb Testbench for {{ entity_name }} (SystemVerilog)"
	@echo ""
	@echo "Targets:"
	@echo "  make            - Run all tests"
	@echo "  make WAVES=0    - Run tests without generating waveforms"
	@echo "  make view_waves - Open waveforms in GTKWave"
	@echo "  make lint       - Check SystemVerilog syntax"
	@echo "  make clean      - Remove simulation build files"
	@echo "  make clean_all  - Remove all generated files"
	@echo ""
	@echo "Options:"
	@echo "  SIM=icarus|verilator|modelsim  - Simulator (default: icarus)"
	@echo "  WAVES=0                        - Suppress waveform generation (default: 1)"
	@echo "  TESTCASE=test_name             - Run specific test"
	@echo "  COCOTB_LOG_LEVEL=DEBUG         - Verbose logging"
