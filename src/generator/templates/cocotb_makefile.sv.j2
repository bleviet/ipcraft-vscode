# Makefile for cocotb simulation with SystemVerilog — {{ engine_display_name }}
# Generated by ipcraft SystemVerilog Generator
#
# Usage:
#   make                    # Run all tests
#   make SIM={{ engine_sim_var }}       # Explicitly specify simulator
#   make SIM=icarus         # Use Icarus Verilog
#   make SIM=verilator      # Use Verilator (faster)
#   make WAVES=0            # Suppress waveform generation
#   make TESTCASE=test_xyz  # Run specific test
#
# Prerequisites:
#   - {{ engine_display_name }}
#   - cocotb (pip install cocotb)
{% if bus_type in ['axil', 'axi4'] %}
#   - cocotbext-axi (pip install cocotbext-axi)
{% endif %}

# Simulator settings
SIM ?= {{ engine_sim_var }}
TOPLEVEL_LANG ?= verilog

# SystemVerilog source files (relative to tb/ directory)
BASE_DIR = $(CURDIR)/..
{% if rtl_source_files | length > 0 %}
# From ip.yml fileSets
{% for src in rtl_source_files %}
VERILOG_SOURCES += $(BASE_DIR)/{{ src }}
{% endfor %}
{% if rtl_include_dirs | length > 0 %}
{% for inc_dir in rtl_include_dirs %}
COMPILE_ARGS += -I$(BASE_DIR)/{{ inc_dir }}
{% endfor %}
{% endif %}
{% else %}
# Derived from entity structure
{% if has_memory_mapped_slave %}
VERILOG_SOURCES += $(BASE_DIR)/rtl/{{ entity_name }}_pkg.sv
VERILOG_SOURCES += $(BASE_DIR)/rtl/{{ entity_name }}_regs.sv
VERILOG_SOURCES += $(BASE_DIR)/rtl/{{ entity_name }}_core.sv
{% if bus_type == 'axil' or bus_type == 'avmm' %}
VERILOG_SOURCES += $(BASE_DIR)/rtl/{{ entity_name }}_{{ bus_type }}.sv
{% endif %}
{% endif %}
VERILOG_SOURCES += $(BASE_DIR)/rtl/{{ entity_name }}.sv
{% endif %}

# Top-level module
TOPLEVEL = {{ top_level }}

# Test module (Python file without .py extension)
MODULE = {{ entity_name }}_test
# Required for Questa/ModelSim: cocotb reads this env var directly inside vsim
export COCOTB_TEST_MODULES = $(MODULE)

# Icarus Verilog options
ifeq ($(SIM),icarus)
    # Enable SystemVerilog support
    COMPILE_ARGS += -g2012

    # Generate waveforms by default; suppress with WAVES=0
    WAVES ?= 1
    ifeq ($(WAVES),1)
        # dump.v instantiates $dumpfile/$dumpvars to produce a VCD trace
        VERILOG_SOURCES += $(CURDIR)/dump.v
    endif
endif

# Verilator options
ifeq ($(SIM),verilator)
    COMPILE_ARGS += --sv
    COMPILE_ARGS += -Wno-fatal
    WAVES ?= 1
    ifeq ($(WAVES),1)
        COMPILE_ARGS += --trace-fst
    endif
endif
{% if engine_extra_compile_args %}

# Extra compile flags from simulation.compileArgs in the .ip.yml
COMPILE_ARGS += {{ engine_extra_compile_args }}
{% endif %}
{% if engine_extra_sim_args %}

# Extra sim flags from simulation.simArgs in the .ip.yml
SIM_ARGS += {{ engine_extra_sim_args }}
{% endif %}

# Cocotb settings
export COCOTB_REDUCED_LOG_FMT=1
{% for kv in engine_extra_env %}
export {{ kv.key }}={{ kv.value }}
{% endfor %}



# Default target
include $(shell cocotb-config --makefiles)/Makefile.sim

# Additional targets
.PHONY: clean_all view_waves lint

ifeq ($(SIM),icarus)
    WAVE_FILE = {{ entity_name }}.vcd
else
    WAVE_FILE = {{ entity_name }}.fst
endif

clean_all: clean
	rm -rf sim_build __pycache__ results.xml *.fst *.vcd *.vzt

view_waves:
	gtkwave $(WAVE_FILE) &

lint:
	@echo "Checking SystemVerilog syntax..."
	@for f in $(VERILOG_SOURCES); do \
		echo "  $$f"; \
		iverilog -g2012 -tnull $$f || exit 1; \
	done
	@echo "All files OK"

# Help target
help:
	@echo "cocotb Testbench for {{ entity_name }} (SystemVerilog)"
	@echo ""
	@echo "Targets:"
	@echo "  make            - Run all tests"
	@echo "  make WAVES=0    - Run tests without generating waveforms"
	@echo "  make view_waves - Open waveforms in GTKWave"
	@echo "  make lint       - Check SystemVerilog syntax"
	@echo "  make clean      - Remove simulation build files"
	@echo "  make clean_all  - Remove all generated files"
	@echo ""
	@echo "Options:"
	@echo "  SIM=icarus|verilator|modelsim  - Simulator (default: icarus)"
	@echo "  WAVES=0                        - Suppress waveform generation (default: 1)"
	@echo "  TESTCASE=test_name             - Run specific test"
	@echo "  COCOTB_LOG_LEVEL=DEBUG         - Verbose logging"
