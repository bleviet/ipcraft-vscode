{# VHDL Top-Level Template #}
{# Generates top-level entity that instantiates core and bus wrapper #}
--------------------------------------------------------------------------------
-- Entity: {{ entity_name }}
-- Description: {{ description | default('') }}
{% if author %}
-- Author: {{ author }}
{% endif %}
-- Generated by ipcraft VHDL Generator
--------------------------------------------------------------------------------

library ieee;
use ieee.std_logic_1164.all;
use ieee.numeric_std.all;
{% if uses_math_real %}
use ieee.math_real.all;
{% endif %}
{% if has_memory_mapped_slave %}
use work.{{ entity_name }}_pkg.all;
{% endif %}

entity {{ entity_name }} is
{% if generics | length %}
  generic (
{% for generic in generics %}
    {{ generic.name }} : {{ generic.type }}{% if generic.min is not none and generic.max is not none %} range {{ generic.min }} to {{ generic.max }}{% endif %}{{ " := " ~ generic.default_value if generic.default_value is not none else "" }}{{ ";" if not loop.last else "" }}
{% endfor %}
  );
{% endif %}
  port (
    -- Clock and reset
    {{ clock_port }} : in std_logic;
    {{ reset_port }} : in std_logic{{ ";" if secondary_clocks | length or secondary_resets | length or bus_ports | length or secondary_bus_ports | length or user_ports | length or interrupt_ports | length else "" }}
{% for clk in secondary_clocks %}
    {{ clk.name }} : in std_logic{{ ";" if not loop.last or secondary_resets | length or bus_ports | length or secondary_bus_ports | length or user_ports | length or interrupt_ports | length else "" }}
{% endfor %}
{% for rst in secondary_resets %}
    {{ rst.name }} : in std_logic{{ ";" if not loop.last or bus_ports | length or secondary_bus_ports | length or user_ports | length or interrupt_ports | length else "" }}
{% endfor %}

{% for iface in expanded_bus_interfaces %}{% set iface_loop = loop %}
{% if iface.ports %}

    -- {{ iface.name }} ({{ iface.mode | upper }})
{% for port in iface.ports %}
    {{ "%-14s"|format(port.name) }} : {{ "%-3s"|format(port.direction) }} {{ port.type }}{{ ";" if not loop.last or not iface_loop.last or user_ports | length or interrupt_ports | length else "" }}
{% endfor %}
{% endif %}
{% endfor %}
{% if user_ports | length %}

    -- User ports
{% for port in user_ports %}
    {{ port.name }} : {{ port.direction }} {{ port.type }}{{ ";" if not loop.last or interrupt_ports | length else "" }}
{% endfor %}
{% endif %}
{% if interrupt_ports | length %}

    -- Interrupts
{% for port in interrupt_ports %}
    {{ port.name }} : {{ port.direction }} std_logic{{ ";" if not loop.last else "" }}
{% endfor %}
{% endif %}
    );
end entity {{ entity_name }};

architecture rtl of {{ entity_name }} is
{% set has_regs_in = hw_registers | length > 0 or w1c_registers | length > 0 or sc_registers | length > 0 or cos_registers | length > 0 %}
{% if has_memory_mapped_slave and (sw_registers | length > 0 or has_regs_in) %}

    -- Internal register signals
{% if sw_registers | length > 0 %}
  signal regs_sw2hw : t_regs_sw2hw;
{% endif %}
{% if has_regs_in %}
  signal regs_hw2sw : t_regs_hw2sw;
{% endif %}
{% endif %}
{% if has_memory_mapped_slave and has_endian_swap %}

    -- Big-endian intermediate signals (byte-swapped view for internal logic)
{% for port in endian_swap_ports %}
  signal {{ port.name }}_be : {{ port.type }};
{% endfor %}
{% endif %}

begin
{% if has_memory_mapped_slave and has_endian_swap %}

    -- Endianness: swap big-endian ports/bus data ports to/from their internal view
{% for port in endian_swap_ports %}
{% if port.is_parameterized %}
{% if port.direction == 'in' %}
    gen_swap_{{ port.name }} : for byte_idx in 0 to ({{ port.name }}'length / 8) - 1 generate
      {{ port.name }}_be((byte_idx + 1) * 8 - 1 downto byte_idx * 8) <=
        {{ port.name }}({{ port.name }}'length - byte_idx * 8 - 1 downto {{ port.name }}'length - (byte_idx + 1) * 8);
    end generate;
{% else %}
    gen_swap_{{ port.name }} : for byte_idx in 0 to ({{ port.name }}'length / 8) - 1 generate
      {{ port.name }}((byte_idx + 1) * 8 - 1 downto byte_idx * 8) <=
        {{ port.name }}_be({{ port.name }}'length - byte_idx * 8 - 1 downto {{ port.name }}'length - (byte_idx + 1) * 8);
    end generate;
{% endif %}
{% else %}
{% if port.direction == 'in' %}
    {{ port.name }}_be <= swap_bytes_{{ port.width }}({{ port.name }});
{% else %}
    {{ port.name }} <= swap_bytes_{{ port.width }}({{ port.name }}_be);
{% endif %}
{% endif %}
{% endfor %}
{% endif %}
{% if has_memory_mapped_slave %}
{# When no register file exists but user ports do, route them through the bus wrapper.
   This covers IPs like AXI-Lite slaves that expose a direct register-bank interface
   (rb_addr/rb_wr/…) rather than a generated register file. #}
{% set pass_user_via_bus = user_ports | length > 0 and sw_registers | length == 0 and not has_regs_in %}

    ----------------------------------------------------------------------------
    -- Bus Wrapper Instance
    ----------------------------------------------------------------------------
    u_{{ bus_type }} : entity work.{{ entity_name }}_{{ bus_type }}
{% if pass_user_via_bus and generics | length %}
    generic map (
{% for generic in generics %}
      {{ generic.name }} => {{ generic.name }}{{ "," if not loop.last else "" }}
{% endfor %}
    )
{% endif %}
    port map (
      clk => {{ clock_port }},
      rst => {% if reset_active_high %}{{ reset_port }}{% else %}not {{ reset_port }}{% endif %},

{% set has_regs_ports = sw_registers | length > 0 or has_regs_in %}
{% if bus_ports %}
{% for port in bus_ports %}
      {{ "%-14s"|format(port.name) }} => {{ port.name }}{{ "_be" if port.needs_swap else "" }}{{ "," if not loop.last or has_regs_ports or pass_user_via_bus else "" }}
{% endfor %}
{% endif %}
{% if sw_registers | length > 0 %}
      regs_out => regs_sw2hw{{ "," if has_regs_in else "" }}
{% endif %}
{% if has_regs_in %}
      regs_in  => regs_hw2sw
{% endif %}
{% if pass_user_via_bus %}
{% for port in user_ports %}
      {{ port.name }} => {{ port.name }}{{ "_be" if port.needs_swap else "" }}{{ "," if not loop.last else "" }}
{% endfor %}
{% endif %}
    );

{% if not pass_user_via_bus %}
    ----------------------------------------------------------------------------
    -- Core Logic Instance
    ----------------------------------------------------------------------------
    u_core : entity work.{{ entity_name }}_core
{% if generics | length %}
    generic map (
{% for generic in generics %}
      {{ generic.name }} => {{ generic.name }}{{ "," if not loop.last else "" }}
{% endfor %}
    )
{% endif %}
    port map (
      clk => {{ clock_port }},
      rst => {% if reset_active_high %}{{ reset_port }}{% else %}not {{ reset_port }}{% endif %},
{% if sw_registers | length > 0 %}
      regs_in  => regs_sw2hw{{ "," if has_regs_in or secondary_bus_ports | length > 0 or user_ports | length > 0 else "" }}
{% endif %}
{% if has_regs_in %}
      regs_out => regs_hw2sw{{ "," if secondary_bus_ports | length > 0 or user_ports | length > 0 else "" }}
{% endif %}
{% if secondary_bus_interfaces | length %}
{% for iface in secondary_bus_interfaces %}{% set iface_loop = loop %}

      -- {{ iface.name }}
{% for port in iface.ports %}
      {{ "%-14s"|format(port.name) }} => {{ port.name }}{{ "_be" if port.needs_swap else "" }}{{ "," if not loop.last or not iface_loop.last or user_ports | length else "" }}
{% endfor %}
{% endfor %}
{% endif %}
{% if user_ports | length %}
{% for port in user_ports %}
      {{ port.name }} => {{ port.name }}{{ "_be" if port.needs_swap else "" }}{{ "," if not loop.last else "" }}
{% endfor %}
{% endif %}
    );

{% endif %}
{% endif %}
end architecture rtl;
