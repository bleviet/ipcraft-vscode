# -----------------------------------------------------------------------------
# Elaborate callback — declares parameterized ports with HDL generic widths.
# add_interface_port with parameter-dependent widths must live here;
# get_parameter_value is only valid during the elaboration phase.
# -----------------------------------------------------------------------------
proc elaborate {} {
    add_interface_port DBG dbg_trace_data trace_data Output [get_parameter_value DATA_W]
    add_interface_port o_gpio o_gpio o_gpio Output [get_parameter_value DATA_W]
    add_interface_port o_fifo_level o_fifo_level o_fifo_level Output [expr int(ceil(log([get_parameter_value FIFO_DEPTH])/log(2)))]
}

