  <spirit:description>Comprehensive AXI-family example. Exercises every register-map property (all access types, enumerated values, monitorChangeOf, register arrays, register groups, memory and reserved blocks) together with an AXI4-Lite CSR slave, an AXI4-Full master, an arrayed AXI-Stream master, an AXI-Stream slave and a custom conduit interface.
</spirit:description>
  <spirit:parameters>
    <spirit:parameter>
      <spirit:name>DATA_W</spirit:name>
      <spirit:displayName>Data W</spirit:displayName>
      <spirit:description>Width of the parallel GPIO output port</spirit:description>
      <spirit:value spirit:format="long" spirit:resolve="user" spirit:id="PARAM_VALUE.DATA_W" spirit:rangeType="long">32</spirit:value>
    </spirit:parameter>
    <spirit:parameter>
