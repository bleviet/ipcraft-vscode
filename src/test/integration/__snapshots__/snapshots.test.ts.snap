exports[`testbench Makefile content matches snapshot 1`] = `
{
  "avalon_peripheral_sv": "# Makefile for cocotb simulation with SystemVerilog — GHDL
# Generated by ipcraft SystemVerilog Generator
#
# Usage:
#   make                    # Run all tests
#   make SIM=ghdl       # Explicitly specify simulator
#   make SIM=icarus         # Use Icarus Verilog
#   make SIM=verilator      # Use Verilator (faster)
#   make WAVES=0            # Suppress waveform generation
#   make TESTCASE=test_xyz  # Run specific test
#
# Prerequisites:
#   - GHDL
#   - cocotb (pip install cocotb)

# Simulator settings
SIM ?= ghdl
TOPLEVEL_LANG ?= verilog

# SystemVerilog source files (relative to tb/ directory)
BASE_DIR = $(CURDIR)/..
# Derived from entity structure
VERILOG_SOURCES += $(BASE_DIR)/rtl/avalon_peripheral.sv

# Top-level module
TOPLEVEL = avalon_peripheral

# Test module (Python file without .py extension)
MODULE = avalon_peripheral_test
# Required for Questa/ModelSim: cocotb reads this env var directly inside vsim
export COCOTB_TEST_MODULES = $(MODULE)

# Icarus Verilog options
ifeq ($(SIM),icarus)
    # Enable SystemVerilog support
    COMPILE_ARGS += -g2012

    # Generate waveforms by default; suppress with WAVES=0
    WAVES ?= 1
    ifeq ($(WAVES),1)
        # dump.v instantiates $dumpfile/$dumpvars to produce a VCD trace
        VERILOG_SOURCES += $(CURDIR)/dump.v
    endif
endif

# Verilator options
ifeq ($(SIM),verilator)
    COMPILE_ARGS += --sv
    COMPILE_ARGS += -Wno-fatal
    WAVES ?= 1
    ifeq ($(WAVES),1)
        COMPILE_ARGS += --trace-fst
    endif
endif

# Cocotb settings
export COCOTB_REDUCED_LOG_FMT=1



# Default target
include $(shell cocotb-config --makefiles)/Makefile.sim

# Additional targets
.PHONY: clean_all view_waves lint

ifeq ($(SIM),icarus)
    WAVE_FILE = avalon_peripheral.vcd
else
    WAVE_FILE = avalon_peripheral.fst
endif

clean_all: clean
	rm -rf sim_build __pycache__ results.xml *.fst *.vcd *.vzt

view_waves:
	gtkwave $(WAVE_FILE) &

lint:
	@echo "Checking SystemVerilog syntax..."
	@for f in $(VERILOG_SOURCES); do \\
		echo "  $$f"; \\
		iverilog -g2012 -tnull $$f || exit 1; \\
	done
	@echo "All files OK"

# Help target
help:
	@echo "cocotb Testbench for avalon_peripheral (SystemVerilog)"
	@echo ""
	@echo "Targets:"
	@echo "  make            - Run all tests"
	@echo "  make WAVES=0    - Run tests without generating waveforms"
	@echo "  make view_waves - Open waveforms in GTKWave"
	@echo "  make lint       - Check SystemVerilog syntax"
	@echo "  make clean      - Remove simulation build files"
	@echo "  make clean_all  - Remove all generated files"
	@echo ""
	@echo "Options:"
	@echo "  SIM=icarus|verilator|modelsim  - Simulator (default: icarus)"
	@echo "  WAVES=0                        - Suppress waveform generation (default: 1)"
