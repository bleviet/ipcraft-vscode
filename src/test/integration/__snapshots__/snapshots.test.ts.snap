set_interface_property o_fifo_level SVD_ADDRESS_GROUP ""



# -----------------------------------------------------------------------------
# Interrupt Interface(s)
# -----------------------------------------------------------------------------
# o_irq: interrupt sender (out)
add_interface o_irq interrupt end
set_interface_property o_irq associatedAddressablePoint ""
set_interface_property o_irq ENABLED true

add_interface_port o_irq o_irq irq Output 1

# o_err_pulse: interrupt sender (out)
add_interface o_err_pulse interrupt end
set_interface_property o_err_pulse associatedAddressablePoint ""
set_interface_property o_err_pulse ENABLED true

add_interface_port o_err_pulse o_err_pulse irq Output 1


# -----------------------------------------------------------------------------
# Elaborate callback — declares parameterized ports with HDL generic widths.
# add_interface_port with parameter-dependent widths must live here;
# get_parameter_value is only valid during the elaboration phase.
# -----------------------------------------------------------------------------
proc elaborate {} {
    add_interface_port DBG dbg_trace_data trace_data Output [get_parameter_value DATA_W]
    add_interface_port o_gpio o_gpio o_gpio Output [get_parameter_value DATA_W]
    add_interface_port o_fifo_level o_fifo_level o_fifo_level Output [expr int(ceil(log([get_parameter_value FIFO_DEPTH])/log(2)))]
}

