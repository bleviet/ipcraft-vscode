  "examples/xcvr_loopback_sv/xcvr_loopback_hw.tcl": "# xcvr_loopback_hw.tcl - Altera Platform Designer Component Definition
# Generated by ipcraft SystemVerilog Generator
#
# Provides component integration for Altera Quartus Platform Designer (Qsys)
# with Avalon-MM slave interface for register access.
#
# Usage: Place this file in the same directory as your RTL files and
# add the directory to Platform Designer's IP search path.

# -----------------------------------------------------------------------------
# Package Definition
# -----------------------------------------------------------------------------
package require qsys

# -----------------------------------------------------------------------------
# Module Properties
# -----------------------------------------------------------------------------
set_module_property DESCRIPTION "Demonstrates a custom bus interface definition (xcvr) with parameterized widths. The bus definition uses constant literal widths; this IP overrides them per-interface using portWidthOverrides referencing design parameters.
"
set_module_property NAME xcvr_loopback
set_module_property VERSION 1.0.0
set_module_property INTERNAL false
set_module_property OPAQUE_ADDRESS_MAP true
set_module_property AUTHOR "ipcraft"
set_module_property DISPLAY_NAME "Xcvr Loopback"
set_module_property INSTANTIATE_IN_SYSTEM_MODULE true
set_module_property EDITABLE true
set_module_property REPORT_TO_TALKBACK false
set_module_property ALLOW_GREYBOX_GENERATION false
set_module_property REPORT_HIERARCHY false
set_module_property ELABORATION_CALLBACK elaborate

# -----------------------------------------------------------------------------
# Parameters
# -----------------------------------------------------------------------------
add_parameter XCVR_DW INTEGER 16
set_parameter_property XCVR_DW DEFAULT_VALUE 16
set_parameter_property XCVR_DW DISPLAY_NAME "Xcvr Dw"
set_parameter_property XCVR_DW TYPE INTEGER
set_parameter_property XCVR_DW UNITS None
set_parameter_property XCVR_DW DESCRIPTION "Transceiver data bus width in bits"
set_parameter_property XCVR_DW HDL_PARAMETER true
set_parameter_property XCVR_DW AFFECTS_GENERATION false
set_parameter_property XCVR_DW AFFECTS_ELABORATION true

add_parameter XCVR_KW INTEGER 2
set_parameter_property XCVR_KW DEFAULT_VALUE 2
set_parameter_property XCVR_KW DISPLAY_NAME "Xcvr Kw"
set_parameter_property XCVR_KW TYPE INTEGER
set_parameter_property XCVR_KW UNITS None
set_parameter_property XCVR_KW DESCRIPTION "Transceiver control (K) bus width in bits"
set_parameter_property XCVR_KW HDL_PARAMETER true
set_parameter_property XCVR_KW AFFECTS_GENERATION false
set_parameter_property XCVR_KW AFFECTS_ELABORATION true

# -----------------------------------------------------------------------------
# Clock Interface
# -----------------------------------------------------------------------------
add_interface clk clock end
set_interface_property clk clockRate 0
set_interface_property clk ENABLED true
set_interface_property clk EXPORT_OF ""
set_interface_property clk PORT_NAME_MAP ""
set_interface_property clk CMSIS_SVD_VARIABLES ""
set_interface_property clk SVD_ADDRESS_GROUP ""

add_interface_port clk clk clk Input 1

# -----------------------------------------------------------------------------
# Reset Interface
# -----------------------------------------------------------------------------
add_interface reset_n reset end
set_interface_property reset_n associatedClock clk
set_interface_property reset_n synchronousEdges DEASSERT
set_interface_property reset_n ENABLED true
set_interface_property reset_n EXPORT_OF ""
set_interface_property reset_n PORT_NAME_MAP ""
set_interface_property reset_n CMSIS_SVD_VARIABLES ""
set_interface_property reset_n SVD_ADDRESS_GROUP ""

add_interface_port reset_n reset_n reset_n Input 1

# -----------------------------------------------------------------------------
# Bus Interfaces (Generic)
# -----------------------------------------------------------------------------

# Interface: xcvr_in (user:busif:xcvr:1.0)
add_interface xcvr_in conduit end
set_interface_property xcvr_in associatedClock clk
set_interface_property xcvr_in associatedReset reset_n
set_interface_property xcvr_in ENABLED true
set_interface_property xcvr_in EXPORT_OF ""
set_interface_property xcvr_in PORT_NAME_MAP ""
set_interface_property xcvr_in CMSIS_SVD_VARIABLES ""
set_interface_property xcvr_in SVD_ADDRESS_GROUP ""

# Type-specific properties

# Ports


# Interface: xcvr_out (user:busif:xcvr:1.0)
add_interface xcvr_out conduit end
set_interface_property xcvr_out associatedClock clk
set_interface_property xcvr_out associatedReset reset_n
set_interface_property xcvr_out ENABLED true
set_interface_property xcvr_out EXPORT_OF ""
set_interface_property xcvr_out PORT_NAME_MAP ""
set_interface_property xcvr_out CMSIS_SVD_VARIABLES ""
set_interface_property xcvr_out SVD_ADDRESS_GROUP ""

# Type-specific properties

# Ports



# -----------------------------------------------------------------------------
# Interrupt Interface(s)
# -----------------------------------------------------------------------------

# -----------------------------------------------------------------------------
# Elaborate callback — declares parameterized ports with HDL generic widths.
# add_interface_port with parameter-dependent widths must live here;
# get_parameter_value is only valid during the elaboration phase.
# -----------------------------------------------------------------------------
proc elaborate {} {
    add_interface_port xcvr_in xcvr_in_tx_data tx_data Input [get_parameter_value XCVR_DW]
    add_interface_port xcvr_in xcvr_in_tx_k tx_k Input [get_parameter_value XCVR_KW]
    add_interface_port xcvr_in xcvr_in_rx_data rx_data Input [get_parameter_value XCVR_DW]
    add_interface_port xcvr_in xcvr_in_rx_k rx_k Input [get_parameter_value XCVR_KW]
    add_interface_port xcvr_out xcvr_out_tx_data tx_data Output [get_parameter_value XCVR_DW]
    add_interface_port xcvr_out xcvr_out_tx_k tx_k Output [get_parameter_value XCVR_KW]
    add_interface_port xcvr_out xcvr_out_rx_data rx_data Output [get_parameter_value XCVR_DW]
    add_interface_port xcvr_out xcvr_out_rx_k rx_k Output [get_parameter_value XCVR_KW]
}

# -----------------------------------------------------------------------------
# File Sets
# -----------------------------------------------------------------------------
add_fileset QUARTUS_SYNTH QUARTUS_SYNTH "" ""
set_fileset_property QUARTUS_SYNTH TOP_LEVEL xcvr_loopback
set_fileset_property QUARTUS_SYNTH ENABLE_RELATIVE_INCLUDE_PATHS false
set_fileset_property QUARTUS_SYNTH ENABLE_FILE_OVERWRITE_MODE false
add_fileset_file xcvr_loopback.sv SYSTEM_VERILOG PATH ../rtl/xcvr_loopback.sv TOP_LEVEL_FILE

add_fileset SIM_VERILOG SIM_VERILOG "" ""
set_fileset_property SIM_VERILOG TOP_LEVEL xcvr_loopback
set_fileset_property SIM_VERILOG ENABLE_RELATIVE_INCLUDE_PATHS false
set_fileset_property SIM_VERILOG ENABLE_FILE_OVERWRITE_MODE false
add_fileset_file xcvr_loopback.sv SYSTEM_VERILOG PATH ../rtl/xcvr_loopback.sv TOP_LEVEL_FILE
