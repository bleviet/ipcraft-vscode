{
  "avalon_peripheral_sv": "<?xml version="1.0" encoding="UTF-8"?>
<spirit:component xmlns:xilinx="http://www.xilinx.com"
  xmlns:spirit="http://www.spiritconsortium.org/XMLSchema/SPIRIT/1685-2009"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
  <spirit:vendor>ipcraft</spirit:vendor>
  <spirit:library>templates</spirit:library>
  <spirit:name>avalon_peripheral</spirit:name>
  <spirit:version>1.0.0</spirit:version>
  <spirit:busInterfaces>
    <spirit:busInterface>
      <spirit:name>avalon_mm_slave</spirit:name>
      <spirit:busType spirit:vendor="xilinx.com" spirit:library="interface" spirit:name="avalon" spirit:version="1.0" />
      <spirit:abstractionType spirit:vendor="xilinx.com" spirit:library="interface" spirit:name="avalon_rtl" spirit:version="1.0" />
      <spirit:slave>
        <spirit:memoryMapRef spirit:memoryMapRef="CSR_MAP" />
      </spirit:slave>
      <spirit:portMaps>
        <spirit:portMap>
          <spirit:logicalPort>
            <spirit:name>address</spirit:name>
          </spirit:logicalPort>
          <spirit:physicalPort>
            <spirit:name>s_avmm_address</spirit:name>
          </spirit:physicalPort>
