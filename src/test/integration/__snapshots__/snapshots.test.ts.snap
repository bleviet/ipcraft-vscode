  <spirit:description>Comprehensive Avalon-family example. Exercises an Avalon-MM CSR slave (with optional byteenable/waitrequest/readdatavalid ports), Avalon-ST source and sink interfaces (source/sink modes, optional packet ports, port name overrides) and change-of-state W1C automation behind the Avalon-MM register wrapper.
</spirit:description>
  <spirit:parameters>
    <spirit:parameter>
      <spirit:name>ST_DATA_W</spirit:name>
      <spirit:displayName>St Data W</spirit:displayName>
      <spirit:description>Streaming data width in bits</spirit:description>
      <spirit:value spirit:format="long" spirit:resolve="user" spirit:id="PARAM_VALUE.ST_DATA_W" spirit:rangeType="long">64</spirit:value>
    </spirit:parameter>
    <spirit:parameter>
      <spirit:name>Component_Name</spirit:name>
      <spirit:value spirit:resolve="user" spirit:id="PARAM_VALUE.Component_Name" spirit:order="1">comprehensive_avalon_v1_0_0</spirit:value>
    </spirit:parameter>
  </spirit:parameters>
