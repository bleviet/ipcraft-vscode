exports[`hw.tcl content matches snapshot for every Altera fixture 1`] = `
{
  "avalon_peripheral_sv/avalon_peripheral_hw.tcl": "# avalon_peripheral_hw.tcl - Altera Platform Designer Component Definition
# Generated by ipcraft SystemVerilog Generator
#
# Provides component integration for Altera Quartus Platform Designer (Qsys)
# with Avalon-MM slave interface for register access.
#
# Usage: Place this file in the same directory as your RTL files and
# add the directory to Platform Designer's IP search path.

# -----------------------------------------------------------------------------
# Package Definition
# -----------------------------------------------------------------------------
package require qsys

# -----------------------------------------------------------------------------
# Module Properties
# -----------------------------------------------------------------------------
set_module_property DESCRIPTION "IP core template with Avalon-MM Slave and Avalon-ST Source/Sink interfaces"
set_module_property NAME avalon_peripheral
set_module_property VERSION 1.0.0
set_module_property INTERNAL false
set_module_property OPAQUE_ADDRESS_MAP true
set_module_property AUTHOR "ipcraft"
set_module_property DISPLAY_NAME "Avalon Peripheral"
set_module_property INSTANTIATE_IN_SYSTEM_MODULE true
set_module_property EDITABLE true
set_module_property REPORT_TO_TALKBACK false
set_module_property ALLOW_GREYBOX_GENERATION false
set_module_property REPORT_HIERARCHY false

# -----------------------------------------------------------------------------
# Parameters
# -----------------------------------------------------------------------------
# -----------------------------------------------------------------------------
# Clock Interface
# -----------------------------------------------------------------------------
add_interface clk clock end
set_interface_property clk clockRate 0
set_interface_property clk ENABLED true
set_interface_property clk EXPORT_OF ""
set_interface_property clk PORT_NAME_MAP ""
set_interface_property clk CMSIS_SVD_VARIABLES ""
set_interface_property clk SVD_ADDRESS_GROUP ""

add_interface_port clk clk clk Input 1

# -----------------------------------------------------------------------------
# Reset Interface
# -----------------------------------------------------------------------------
add_interface reset reset end
set_interface_property reset associatedClock clk
set_interface_property reset synchronousEdges DEASSERT
set_interface_property reset ENABLED true
set_interface_property reset EXPORT_OF ""
set_interface_property reset PORT_NAME_MAP ""
set_interface_property reset CMSIS_SVD_VARIABLES ""
set_interface_property reset SVD_ADDRESS_GROUP ""

add_interface_port reset reset reset Input 1

# -----------------------------------------------------------------------------
# Bus Interfaces (Generic)
# -----------------------------------------------------------------------------

# Interface: avalon_mm_slave (ipcraft:busif:avalon_mm:1.0)
add_interface avalon_mm_slave avalon end
set_interface_property avalon_mm_slave associatedClock clk
set_interface_property avalon_mm_slave associatedReset reset
set_interface_property avalon_mm_slave ENABLED true
set_interface_property avalon_mm_slave EXPORT_OF ""
set_interface_property avalon_mm_slave PORT_NAME_MAP ""
set_interface_property avalon_mm_slave CMSIS_SVD_VARIABLES ""
set_interface_property avalon_mm_slave SVD_ADDRESS_GROUP ""

# Type-specific properties
set_interface_property avalon_mm_slave addressUnits WORDS
set_interface_property avalon_mm_slave maximumPendingReadTransactions 0

# Ports
add_interface_port avalon_mm_slave s_avmm_address address Input 32
add_interface_port avalon_mm_slave s_avmm_read read Input 1
add_interface_port avalon_mm_slave s_avmm_write write Input 1
add_interface_port avalon_mm_slave s_avmm_writedata writedata Input 32
add_interface_port avalon_mm_slave s_avmm_readdata readdata Output 32
add_interface_port avalon_mm_slave s_avmm_readdatavalid readdatavalid Output 1
add_interface_port avalon_mm_slave s_avmm_waitrequest waitrequest Output 1


# Interface: avalon_st_sink (ipcraft:busif:avalon_st:1.0)
add_interface avalon_st_sink avalon_streaming end
set_interface_property avalon_st_sink associatedClock clk
set_interface_property avalon_st_sink associatedReset reset
set_interface_property avalon_st_sink ENABLED true
set_interface_property avalon_st_sink EXPORT_OF ""
set_interface_property avalon_st_sink PORT_NAME_MAP ""
set_interface_property avalon_st_sink CMSIS_SVD_VARIABLES ""
set_interface_property avalon_st_sink SVD_ADDRESS_GROUP ""

# Type-specific properties

# Ports
add_interface_port avalon_st_sink s_avst_data data Input 32
add_interface_port avalon_st_sink s_avst_valid valid Input 1
add_interface_port avalon_st_sink s_avst_ready ready Output 1
add_interface_port avalon_st_sink s_avst_startofpacket startofpacket Input 1
add_interface_port avalon_st_sink s_avst_endofpacket endofpacket Input 1


# Interface: avalon_st_source (ipcraft:busif:avalon_st:1.0)
add_interface avalon_st_source avalon_streaming start
set_interface_property avalon_st_source associatedClock clk
set_interface_property avalon_st_source associatedReset reset
set_interface_property avalon_st_source ENABLED true
set_interface_property avalon_st_source EXPORT_OF ""
set_interface_property avalon_st_source PORT_NAME_MAP ""
set_interface_property avalon_st_source CMSIS_SVD_VARIABLES ""
set_interface_property avalon_st_source SVD_ADDRESS_GROUP ""

# Type-specific properties

# Ports
add_interface_port avalon_st_source m_avst_data data Output 32
add_interface_port avalon_st_source m_avst_valid valid Output 1
add_interface_port avalon_st_source m_avst_ready ready Input 1
add_interface_port avalon_st_source m_avst_startofpacket startofpacket Output 1
add_interface_port avalon_st_source m_avst_endofpacket endofpacket Output 1



# -----------------------------------------------------------------------------
# Interrupt Interface(s)
# -----------------------------------------------------------------------------


# -----------------------------------------------------------------------------
# File Sets
# -----------------------------------------------------------------------------
add_fileset QUARTUS_SYNTH QUARTUS_SYNTH "" ""
set_fileset_property QUARTUS_SYNTH TOP_LEVEL avalon_peripheral
set_fileset_property QUARTUS_SYNTH ENABLE_RELATIVE_INCLUDE_PATHS false
set_fileset_property QUARTUS_SYNTH ENABLE_FILE_OVERWRITE_MODE false
add_fileset_file avalon_peripheral.sv SYSTEM_VERILOG PATH ../rtl/avalon_peripheral.sv TOP_LEVEL_FILE

add_fileset SIM_VERILOG SIM_VERILOG "" ""
set_fileset_property SIM_VERILOG TOP_LEVEL avalon_peripheral
set_fileset_property SIM_VERILOG ENABLE_RELATIVE_INCLUDE_PATHS false
set_fileset_property SIM_VERILOG ENABLE_FILE_OVERWRITE_MODE false
add_fileset_file avalon_peripheral.sv SYSTEM_VERILOG PATH ../rtl/avalon_peripheral.sv TOP_LEVEL_FILE
",
