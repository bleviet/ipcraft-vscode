  );

  function to_slv(reg : t_reg_dma_1_src) return std_logic_vector;
  function to_dma_1_src(slv : std_logic_vector(C_DATA_WIDTH-1 downto 0)) return t_reg_dma_1_src;

  -- DMA_1_DST register fields
  type t_reg_dma_1_dst is record
    addr : std_logic_vector(31 downto 0);  -- bits 31:0
  end record;

  constant C_REG_DMA_1_DST_RESET : t_reg_dma_1_dst := (
    addr => (others => '0')
  );

  function to_slv(reg : t_reg_dma_1_dst) return std_logic_vector;
  function to_dma_1_dst(slv : std_logic_vector(C_DATA_WIDTH-1 downto 0)) return t_reg_dma_1_dst;

  -- DMA_1_LEN register fields
  type t_reg_dma_1_len is record
    bytes : std_logic_vector(23 downto 0);  -- bits 23:0
  end record;

  constant C_REG_DMA_1_LEN_RESET : t_reg_dma_1_len := (
    bytes => (others => '0')
  );

  function to_slv(reg : t_reg_dma_1_len) return std_logic_vector;
  function to_dma_1_len(slv : std_logic_vector(C_DATA_WIDTH-1 downto 0)) return t_reg_dma_1_len;

  -- DMA_1_CTRL register fields
  type t_reg_dma_1_ctrl is record
    start : std_logic;  -- bit 0
    ie : std_logic;  -- bit 1
    done : std_logic;  -- bit 8
  end record;

  constant C_REG_DMA_1_CTRL_RESET : t_reg_dma_1_ctrl := (
    start => '0',
    ie => '0',
    done => '0'
  );

  function to_slv(reg : t_reg_dma_1_ctrl) return std_logic_vector;
  function to_dma_1_ctrl(slv : std_logic_vector(C_DATA_WIDTH-1 downto 0)) return t_reg_dma_1_ctrl;

  -- W1C event-pulse record types (hardware drives a 1-cycle strobe to set a sticky bit)

  type t_reg_irq_event_pulse is record
    done_pulse : std_logic;  -- event strobe → sets IRQ_EVENT.done
    err_pulse : std_logic;  -- event strobe → sets IRQ_EVENT.err
  end record;

  constant C_REG_IRQ_EVENT_PULSE_RESET : t_reg_irq_event_pulse := (
    done_pulse => '0',
    err_pulse => '0'
  );

  type t_reg_dma_0_ctrl_pulse is record
    done_pulse : std_logic;  -- event strobe → sets DMA_0_CTRL.done
  end record;

  constant C_REG_DMA_0_CTRL_PULSE_RESET : t_reg_dma_0_ctrl_pulse := (
    done_pulse => '0'
  );

  type t_reg_dma_1_ctrl_pulse is record
    done_pulse : std_logic;  -- event strobe → sets DMA_1_CTRL.done
  end record;

  constant C_REG_DMA_1_CTRL_PULSE_RESET : t_reg_dma_1_ctrl_pulse := (
    done_pulse => '0'
  );

  -- SC event-clear record types (hardware drives a 1-cycle strobe to clear a sticky bit)

  type t_reg_ctrl_clear is record
    soft_rst_clear : std_logic;  -- event strobe → clears CTRL.soft_rst
  end record;

  constant C_REG_CTRL_CLEAR_RESET : t_reg_ctrl_clear := (
    soft_rst_clear => '0'
  );

  -- CoS value-port record types (live hardware values for change-of-state monitoring)

  type t_reg_irq_event_val is record
    link_state : std_logic;  -- monitored by CoS field in IRQ_EVENT
  end record;

  constant C_REG_IRQ_EVENT_VAL_RESET : t_reg_irq_event_val := (
    link_state => '0'
  );

  ----------------------------------------------------------------------------
  -- Aggregate Register Records (for clean port interface)
  ----------------------------------------------------------------------------

  -- SW -> HW: Registers written by software, read by hardware
  type t_regs_sw2hw is record
    ctrl : t_reg_ctrl;
    cmd : t_reg_cmd;
    scratch : t_reg_scratch;
    irq_event : t_reg_irq_event;
    ch_gain_0 : t_reg_ch_gain_0;
    ch_gain_1 : t_reg_ch_gain_1;
    ch_gain_2 : t_reg_ch_gain_2;
    ch_gain_3 : t_reg_ch_gain_3;
    dma_0_src : t_reg_dma_0_src;
    dma_0_dst : t_reg_dma_0_dst;
    dma_0_len : t_reg_dma_0_len;
    dma_0_ctrl : t_reg_dma_0_ctrl;
    dma_1_src : t_reg_dma_1_src;
    dma_1_dst : t_reg_dma_1_dst;
    dma_1_len : t_reg_dma_1_len;
    dma_1_ctrl : t_reg_dma_1_ctrl;
  end record;

  constant C_REGS_SW2HW_RESET : t_regs_sw2hw := (
    ctrl => C_REG_CTRL_RESET,
    cmd => C_REG_CMD_RESET,
    scratch => C_REG_SCRATCH_RESET,
    irq_event => C_REG_IRQ_EVENT_RESET,
    ch_gain_0 => C_REG_CH_GAIN_0_RESET,
    ch_gain_1 => C_REG_CH_GAIN_1_RESET,
    ch_gain_2 => C_REG_CH_GAIN_2_RESET,
    ch_gain_3 => C_REG_CH_GAIN_3_RESET,
    dma_0_src => C_REG_DMA_0_SRC_RESET,
    dma_0_dst => C_REG_DMA_0_DST_RESET,
    dma_0_len => C_REG_DMA_0_LEN_RESET,
    dma_0_ctrl => C_REG_DMA_0_CTRL_RESET,
    dma_1_src => C_REG_DMA_1_SRC_RESET,
    dma_1_dst => C_REG_DMA_1_DST_RESET,
    dma_1_len => C_REG_DMA_1_LEN_RESET,
    dma_1_ctrl => C_REG_DMA_1_CTRL_RESET
  );

  -- HW -> SW: Status registers (RO) + W1C/SC event pulses + CoS value ports
  type t_regs_hw2sw is record
    id : t_reg_id;
    status : t_reg_status;
    irq_event_pulse : t_reg_irq_event_pulse;  -- W1C event pulses for IRQ_EVENT
    dma_0_ctrl_pulse : t_reg_dma_0_ctrl_pulse;  -- W1C event pulses for DMA_0_CTRL
    dma_1_ctrl_pulse : t_reg_dma_1_ctrl_pulse;  -- W1C event pulses for DMA_1_CTRL
    ctrl_clear : t_reg_ctrl_clear;  -- SC event clear pulses for CTRL
    irq_event_val : t_reg_irq_event_val;  -- live values monitored for CoS in IRQ_EVENT
  end record;

  constant C_REGS_HW2SW_RESET : t_regs_hw2sw := (
    id => C_REG_ID_RESET,
    status => C_REG_STATUS_RESET,
    irq_event_pulse => C_REG_IRQ_EVENT_PULSE_RESET,
    dma_0_ctrl_pulse => C_REG_DMA_0_CTRL_PULSE_RESET,
    dma_1_ctrl_pulse => C_REG_DMA_1_CTRL_PULSE_RESET,
    ctrl_clear => C_REG_CTRL_CLEAR_RESET,
    irq_event_val => C_REG_IRQ_EVENT_VAL_RESET
  );

end package comprehensive_axi_pkg;


package body comprehensive_axi_pkg is

  ----------------------------------------------------------------------------
  -- Register Address Function
  ----------------------------------------------------------------------------
  function reg_addr(reg : t_reg_index) return natural is
  begin
    return t_reg_index'pos(reg) * C_REG_WIDTH;
  end function;

  ----------------------------------------------------------------------------
  -- Conversion Functions
  ----------------------------------------------------------------------------

  -- ID conversions
  function to_slv(reg : t_reg_id) return std_logic_vector is
    variable slv : std_logic_vector(C_DATA_WIDTH-1 downto 0) := (others => '0');
  begin
    slv(7 downto 0) := reg.revision;
    slv(31 downto 8) := reg.device_id;
    return slv;
  end function;

  function to_id(slv : std_logic_vector(C_DATA_WIDTH-1 downto 0)) return t_reg_id is
    variable reg : t_reg_id;
  begin
    reg.revision := slv(7 downto 0);
    reg.device_id := slv(31 downto 8);
    return reg;
  end function;

  -- CTRL conversions
  function to_slv(reg : t_reg_ctrl) return std_logic_vector is
    variable slv : std_logic_vector(C_DATA_WIDTH-1 downto 0) := (others => '0');
  begin
    slv(0) := reg.enable;
    slv(2 downto 1) := reg.mode;
    slv(11 downto 4) := reg.prescale;
    slv(31) := reg.soft_rst;
    return slv;
  end function;

  function to_ctrl(slv : std_logic_vector(C_DATA_WIDTH-1 downto 0)) return t_reg_ctrl is
    variable reg : t_reg_ctrl;
  begin
    reg.enable := slv(0);
    reg.mode := slv(2 downto 1);
    reg.prescale := slv(11 downto 4);
    reg.soft_rst := slv(31);
    return reg;
  end function;

  -- STATUS conversions
  function to_slv(reg : t_reg_status) return std_logic_vector is
    variable slv : std_logic_vector(C_DATA_WIDTH-1 downto 0) := (others => '0');
  begin
    slv(0) := reg.busy;
    slv(15 downto 4) := reg.fifo_level;
    slv(18 downto 16) := reg.fsm_state;
    return slv;
  end function;

  function to_status(slv : std_logic_vector(C_DATA_WIDTH-1 downto 0)) return t_reg_status is
    variable reg : t_reg_status;
  begin
    reg.busy := slv(0);
    reg.fifo_level := slv(15 downto 4);
    reg.fsm_state := slv(18 downto 16);
    return reg;
  end function;

  -- CMD conversions
  function to_slv(reg : t_reg_cmd) return std_logic_vector is
    variable slv : std_logic_vector(C_DATA_WIDTH-1 downto 0) := (others => '0');
  begin
    slv(7 downto 0) := reg.opcode;
    slv(31 downto 8) := reg.arg;
    return slv;
  end function;

  function to_cmd(slv : std_logic_vector(C_DATA_WIDTH-1 downto 0)) return t_reg_cmd is
    variable reg : t_reg_cmd;
  begin
    reg.opcode := slv(7 downto 0);
    reg.arg := slv(31 downto 8);
    return reg;
  end function;

  -- SCRATCH conversions
  function to_slv(reg : t_reg_scratch) return std_logic_vector is
    variable slv : std_logic_vector(C_DATA_WIDTH-1 downto 0) := (others => '0');
  begin
    slv(31 downto 0) := reg.value;
    return slv;
  end function;

  function to_scratch(slv : std_logic_vector(C_DATA_WIDTH-1 downto 0)) return t_reg_scratch is
    variable reg : t_reg_scratch;
  begin
    reg.value := slv(31 downto 0);
    return reg;
  end function;

  -- IRQ_EVENT conversions
  function to_slv(reg : t_reg_irq_event) return std_logic_vector is
    variable slv : std_logic_vector(C_DATA_WIDTH-1 downto 0) := (others => '0');
  begin
    slv(0) := reg.done;
    slv(1) := reg.err;
    slv(4) := reg.link_state;
    slv(5) := reg.link_toggled;
    return slv;
  end function;

  function to_irq_event(slv : std_logic_vector(C_DATA_WIDTH-1 downto 0)) return t_reg_irq_event is
    variable reg : t_reg_irq_event;
  begin
    reg.done := slv(0);
    reg.err := slv(1);
    reg.link_state := slv(4);
    reg.link_toggled := slv(5);
    return reg;
  end function;

  -- CH_GAIN_0 conversions
  function to_slv(reg : t_reg_ch_gain_0) return std_logic_vector is
    variable slv : std_logic_vector(C_DATA_WIDTH-1 downto 0) := (others => '0');
  begin
    slv(11 downto 0) := reg.gain;
    slv(16) := reg.mute;
    return slv;
  end function;

  function to_ch_gain_0(slv : std_logic_vector(C_DATA_WIDTH-1 downto 0)) return t_reg_ch_gain_0 is
    variable reg : t_reg_ch_gain_0;
  begin
    reg.gain := slv(11 downto 0);
    reg.mute := slv(16);
    return reg;
  end function;

  -- CH_GAIN_1 conversions
  function to_slv(reg : t_reg_ch_gain_1) return std_logic_vector is
    variable slv : std_logic_vector(C_DATA_WIDTH-1 downto 0) := (others => '0');
  begin
    slv(11 downto 0) := reg.gain;
    slv(16) := reg.mute;
    return slv;
  end function;

  function to_ch_gain_1(slv : std_logic_vector(C_DATA_WIDTH-1 downto 0)) return t_reg_ch_gain_1 is
    variable reg : t_reg_ch_gain_1;
  begin
    reg.gain := slv(11 downto 0);
    reg.mute := slv(16);
    return reg;
  end function;

  -- CH_GAIN_2 conversions
  function to_slv(reg : t_reg_ch_gain_2) return std_logic_vector is
    variable slv : std_logic_vector(C_DATA_WIDTH-1 downto 0) := (others => '0');
  begin
    slv(11 downto 0) := reg.gain;
    slv(16) := reg.mute;
    return slv;
  end function;

  function to_ch_gain_2(slv : std_logic_vector(C_DATA_WIDTH-1 downto 0)) return t_reg_ch_gain_2 is
    variable reg : t_reg_ch_gain_2;
  begin
    reg.gain := slv(11 downto 0);
    reg.mute := slv(16);
    return reg;
  end function;

  -- CH_GAIN_3 conversions
  function to_slv(reg : t_reg_ch_gain_3) return std_logic_vector is
    variable slv : std_logic_vector(C_DATA_WIDTH-1 downto 0) := (others => '0');
  begin
    slv(11 downto 0) := reg.gain;
    slv(16) := reg.mute;
    return slv;
  end function;

  function to_ch_gain_3(slv : std_logic_vector(C_DATA_WIDTH-1 downto 0)) return t_reg_ch_gain_3 is
    variable reg : t_reg_ch_gain_3;
  begin
    reg.gain := slv(11 downto 0);
    reg.mute := slv(16);
    return reg;
  end function;

  -- DMA_0_SRC conversions
  function to_slv(reg : t_reg_dma_0_src) return std_logic_vector is
    variable slv : std_logic_vector(C_DATA_WIDTH-1 downto 0) := (others => '0');
  begin
    slv(31 downto 0) := reg.addr;
    return slv;
  end function;

  function to_dma_0_src(slv : std_logic_vector(C_DATA_WIDTH-1 downto 0)) return t_reg_dma_0_src is
    variable reg : t_reg_dma_0_src;
  begin
    reg.addr := slv(31 downto 0);
    return reg;
  end function;

  -- DMA_0_DST conversions
  function to_slv(reg : t_reg_dma_0_dst) return std_logic_vector is
    variable slv : std_logic_vector(C_DATA_WIDTH-1 downto 0) := (others => '0');
  begin
    slv(31 downto 0) := reg.addr;
    return slv;
  end function;

  function to_dma_0_dst(slv : std_logic_vector(C_DATA_WIDTH-1 downto 0)) return t_reg_dma_0_dst is
    variable reg : t_reg_dma_0_dst;
  begin
    reg.addr := slv(31 downto 0);
    return reg;
  end function;

  -- DMA_0_LEN conversions
  function to_slv(reg : t_reg_dma_0_len) return std_logic_vector is
    variable slv : std_logic_vector(C_DATA_WIDTH-1 downto 0) := (others => '0');
  begin
    slv(23 downto 0) := reg.bytes;
    return slv;
  end function;

  function to_dma_0_len(slv : std_logic_vector(C_DATA_WIDTH-1 downto 0)) return t_reg_dma_0_len is
    variable reg : t_reg_dma_0_len;
  begin
    reg.bytes := slv(23 downto 0);
    return reg;
  end function;

  -- DMA_0_CTRL conversions
  function to_slv(reg : t_reg_dma_0_ctrl) return std_logic_vector is
    variable slv : std_logic_vector(C_DATA_WIDTH-1 downto 0) := (others => '0');
  begin
    slv(0) := reg.start;
    slv(1) := reg.ie;
    slv(8) := reg.done;
    return slv;
  end function;

  function to_dma_0_ctrl(slv : std_logic_vector(C_DATA_WIDTH-1 downto 0)) return t_reg_dma_0_ctrl is
    variable reg : t_reg_dma_0_ctrl;
  begin
    reg.start := slv(0);
    reg.ie := slv(1);
    reg.done := slv(8);
    return reg;
  end function;

  -- DMA_1_SRC conversions
  function to_slv(reg : t_reg_dma_1_src) return std_logic_vector is
    variable slv : std_logic_vector(C_DATA_WIDTH-1 downto 0) := (others => '0');
  begin
    slv(31 downto 0) := reg.addr;
    return slv;
  end function;

  function to_dma_1_src(slv : std_logic_vector(C_DATA_WIDTH-1 downto 0)) return t_reg_dma_1_src is
    variable reg : t_reg_dma_1_src;
  begin
    reg.addr := slv(31 downto 0);
    return reg;
  end function;

  -- DMA_1_DST conversions
  function to_slv(reg : t_reg_dma_1_dst) return std_logic_vector is
    variable slv : std_logic_vector(C_DATA_WIDTH-1 downto 0) := (others => '0');
  begin
    slv(31 downto 0) := reg.addr;
    return slv;
  end function;

  function to_dma_1_dst(slv : std_logic_vector(C_DATA_WIDTH-1 downto 0)) return t_reg_dma_1_dst is
    variable reg : t_reg_dma_1_dst;
  begin
    reg.addr := slv(31 downto 0);
    return reg;
  end function;

  -- DMA_1_LEN conversions
  function to_slv(reg : t_reg_dma_1_len) return std_logic_vector is
    variable slv : std_logic_vector(C_DATA_WIDTH-1 downto 0) := (others => '0');
  begin
    slv(23 downto 0) := reg.bytes;
    return slv;
  end function;

  function to_dma_1_len(slv : std_logic_vector(C_DATA_WIDTH-1 downto 0)) return t_reg_dma_1_len is
    variable reg : t_reg_dma_1_len;
  begin
    reg.bytes := slv(23 downto 0);
    return reg;
  end function;

  -- DMA_1_CTRL conversions
  function to_slv(reg : t_reg_dma_1_ctrl) return std_logic_vector is
    variable slv : std_logic_vector(C_DATA_WIDTH-1 downto 0) := (others => '0');
  begin
    slv(0) := reg.start;
    slv(1) := reg.ie;
    slv(8) := reg.done;
    return slv;
  end function;

  function to_dma_1_ctrl(slv : std_logic_vector(C_DATA_WIDTH-1 downto 0)) return t_reg_dma_1_ctrl is
    variable reg : t_reg_dma_1_ctrl;
  begin
    reg.start := slv(0);
    reg.ie := slv(1);
    reg.done := slv(8);
    return reg;
  end function;

end package body comprehensive_axi_pkg;
",
}
`;

exports[`Vivado project Tcl scripts match snapshot 1`] = `
{
  "avalon_peripheral_sv/avalon_peripheral_project.tcl": "# Vivado out-of-context synthesis project for avalon_peripheral
# Generated by IPCraft
#
# Usage (batch mode):
#   vivado -mode batch -source avalon_peripheral_project.tcl
#
# Usage (GUI — File > Run Tcl Script, then select this file):
#   After sourcing, run synthesis via the Flow Navigator or:
#   launch_runs synth_1 -jobs 4
#   wait_on_run synth_1
#   open_run synth_1 -name synth_1
#   report_timing_summary -file timing_summary.rpt
#
# The OOC (out-of-context) synthesis mode treats avalon_peripheral as a
# standalone module, ignoring parent-level I/O constraints.  This is the
# standard approach for IP core synthesisability and timing verification.

set script_dir   [file normalize [file dirname [info script]]]
set project_name avalon_peripheral
set project_dir  [file join $script_dir build ooc]
set part         xc7z020clg484-1

# Gracefully handle already open projects to avoid locking errors
if {[current_project -quiet] ne ""} {
    puts "Closing currently open project: [current_project]"
    close_project
}

if {[file exists $project_dir]} {
    puts "Removing existing project directory: $project_dir"
    file delete -force $project_dir
}

puts "=== Creating Vivado OOC project ==="
puts "Project : $project_name"
puts "Part    : $part"
puts "Dir     : $project_dir"

create_project $project_name $project_dir -part $part

# ---- IP Repository -------------------------------------------------------
# Register this directory as an IP repository so block designs can discover
# the generated component.xml when this IP is instantiated.
set_property IP_REPO_PATHS [list $script_dir] [current_project]
update_ip_catalog -rebuild -quiet

# ---- RTL sources --------------------------------------------------------
add_files -fileset sources_1 -norecurse [file normalize [file join $script_dir ../rtl/avalon_peripheral.sv]]

# Use VHDL-2008 for VHDL source files (skipped when project contains only SystemVerilog)
# Uses FILE_TYPE filter to capture both .vhd and .vhdl safely
set vhd_files [get_files -quiet -filter {FILE_TYPE =~ "VHDL*"}]
if {[llength $vhd_files] > 0} {
    set_property file_type {VHDL 2008} $vhd_files
}

# ---- Constraints ---------------------------------------------------------
add_files -fileset constrs_1 [file normalize [file join $script_dir avalon_peripheral_ooc.xdc]]

# Mark constraints as out-of-context so they apply during OOC synthesis
# Uses file tail for robust database matching
set xdc_filename [file tail avalon_peripheral_ooc.xdc]
set xdc_obj [get_files -quiet -of_objects [get_filesets constrs_1] $xdc_filename]
if {$xdc_obj ne ""} {
    set_property USED_IN {out_of_context synthesis} $xdc_obj
} else {
    send_msg_id "IPCraft-002" "WARNING" "Could not locate constraint file $xdc_filename in project."
}

# ---- Synthesis run -------------------------------------------------------
# Configure synth_1 for out-of-context mode
set_property -name {STEPS.SYNTH_DESIGN.ARGS.MORE OPTIONS} \\
    -value {-mode out_of_context} \\
    -objects [get_runs synth_1]

# Set top-level entity
set_property top avalon_peripheral [current_fileset]
update_compile_order -fileset sources_1

puts ""
puts "Project created at: $project_dir"
puts "Open in GUI  : open_project [file join $project_dir \${project_name}.xpr]"
puts "Run via IPCraft: vivado -mode batch -source \${project_name}_run_ooc.tcl -nojournal -nolog"
",
  "avalon_peripheral_vhdl/avalon_peripheral_project.tcl": "# Vivado out-of-context synthesis project for avalon_peripheral
# Generated by IPCraft
#
# Usage (batch mode):
#   vivado -mode batch -source avalon_peripheral_project.tcl
#
# Usage (GUI — File > Run Tcl Script, then select this file):
#   After sourcing, run synthesis via the Flow Navigator or:
#   launch_runs synth_1 -jobs 4
#   wait_on_run synth_1
#   open_run synth_1 -name synth_1
#   report_timing_summary -file timing_summary.rpt
#
# The OOC (out-of-context) synthesis mode treats avalon_peripheral as a
# standalone module, ignoring parent-level I/O constraints.  This is the
# standard approach for IP core synthesisability and timing verification.

set script_dir   [file normalize [file dirname [info script]]]
set project_name avalon_peripheral
set project_dir  [file join $script_dir build ooc]
set part         xc7z020clg484-1

# Gracefully handle already open projects to avoid locking errors
if {[current_project -quiet] ne ""} {
    puts "Closing currently open project: [current_project]"
    close_project
}

if {[file exists $project_dir]} {
    puts "Removing existing project directory: $project_dir"
    file delete -force $project_dir
}

puts "=== Creating Vivado OOC project ==="
puts "Project : $project_name"
puts "Part    : $part"
puts "Dir     : $project_dir"

create_project $project_name $project_dir -part $part

# ---- IP Repository -------------------------------------------------------
# Register this directory as an IP repository so block designs can discover
# the generated component.xml when this IP is instantiated.
set_property IP_REPO_PATHS [list $script_dir] [current_project]
update_ip_catalog -rebuild -quiet

# ---- RTL sources --------------------------------------------------------
add_files -fileset sources_1 -norecurse [file normalize [file join $script_dir ../rtl/avalon_peripheral.vhd]]

# Use VHDL-2008 for VHDL source files (skipped when project contains only SystemVerilog)
# Uses FILE_TYPE filter to capture both .vhd and .vhdl safely
set vhd_files [get_files -quiet -filter {FILE_TYPE =~ "VHDL*"}]
if {[llength $vhd_files] > 0} {
    set_property file_type {VHDL 2008} $vhd_files
}

# ---- Constraints ---------------------------------------------------------
add_files -fileset constrs_1 [file normalize [file join $script_dir avalon_peripheral_ooc.xdc]]

# Mark constraints as out-of-context so they apply during OOC synthesis
# Uses file tail for robust database matching
