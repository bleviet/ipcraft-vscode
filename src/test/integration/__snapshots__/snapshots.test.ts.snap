  <spirit:description>Demonstrates a custom bus interface definition (xcvr) with parameterized widths. The bus definition uses constant literal widths; this IP overrides them per-interface using portWidthOverrides referencing design parameters.
</spirit:description>
  <spirit:parameters>
    <spirit:parameter>
      <spirit:name>XCVR_DW</spirit:name>
      <spirit:displayName>Xcvr Dw</spirit:displayName>
      <spirit:description>Transceiver data bus width in bits</spirit:description>
      <spirit:value spirit:format="long" spirit:resolve="user" spirit:id="PARAM_VALUE.XCVR_DW" spirit:rangeType="long">16</spirit:value>
    </spirit:parameter>
    <spirit:parameter>
      <spirit:name>XCVR_KW</spirit:name>
      <spirit:displayName>Xcvr Kw</spirit:displayName>
      <spirit:description>Transceiver control (K) bus width in bits</spirit:description>
      <spirit:value spirit:format="long" spirit:resolve="user" spirit:id="PARAM_VALUE.XCVR_KW" spirit:rangeType="long">2</spirit:value>
    </spirit:parameter>
    <spirit:parameter>
      <spirit:name>Component_Name</spirit:name>
      <spirit:value spirit:resolve="user" spirit:id="PARAM_VALUE.Component_Name" spirit:order="1">xcvr_loopback_v1_0_0</spirit:value>
    </spirit:parameter>
  </spirit:parameters>
