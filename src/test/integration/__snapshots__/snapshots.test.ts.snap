  <spirit:description>Comprehensive AXI-family example. Exercises every register-map property (all access types, enumerated values, monitorChangeOf, register arrays, register groups, memory and reserved blocks) together with an AXI4-Lite CSR slave, an AXI4-Full master, an arrayed AXI-Stream master, an AXI-Stream slave and a custom conduit interface.
</spirit:description>
  <spirit:parameters>
    <spirit:parameter>
      <spirit:name>DATA_W</spirit:name>
      <spirit:displayName>Data W</spirit:displayName>
      <spirit:description>Width of the parallel GPIO output port</spirit:description>
      <spirit:value spirit:format="long" spirit:resolve="user" spirit:id="PARAM_VALUE.DATA_W" spirit:rangeType="long">32</spirit:value>
    </spirit:parameter>
    <spirit:parameter>
      <spirit:name>FIFO_DEPTH</spirit:name>
      <spirit:displayName>Fifo Depth</spirit:displayName>
      <spirit:description>Internal buffer depth in words</spirit:description>
      <spirit:value spirit:format="long" spirit:resolve="user" spirit:id="PARAM_VALUE.FIFO_DEPTH" spirit:rangeType="long">512</spirit:value>
    </spirit:parameter>
    <spirit:parameter>
      <spirit:name>NUM_CH</spirit:name>
      <spirit:displayName>Num Ch</spirit:displayName>
      <spirit:description>Number of streaming output channels</spirit:description>
      <spirit:value spirit:format="long" spirit:resolve="user" spirit:id="PARAM_VALUE.NUM_CH" spirit:rangeType="long">2</spirit:value>
    </spirit:parameter>
    <spirit:parameter>
      <spirit:name>ENABLE_DBG</spirit:name>
      <spirit:displayName>Enable Dbg</spirit:displayName>
      <spirit:description>Compile-time enable for the debug conduit logic</spirit:description>
      <spirit:value spirit:format="bool" spirit:resolve="user" spirit:id="PARAM_VALUE.ENABLE_DBG">false</spirit:value>
    </spirit:parameter>
    <spirit:parameter>
      <spirit:name>DEVICE_TAG</spirit:name>
      <spirit:displayName>Device Tag</spirit:displayName>
      <spirit:description>Build tag embedded in the ID register logic</spirit:description>
      <spirit:value spirit:format="string" spirit:resolve="user" spirit:id="PARAM_VALUE.DEVICE_TAG">&quot;COMP&quot;</spirit:value>
    </spirit:parameter>
    <spirit:parameter>
      <spirit:name>Component_Name</spirit:name>
      <spirit:value spirit:resolve="user" spirit:id="PARAM_VALUE.Component_Name" spirit:order="1">comprehensive_axi_v1_0_0</spirit:value>
    </spirit:parameter>
  </spirit:parameters>
