      <spirit:value spirit:format="string" spirit:resolve="user" spirit:id="PARAM_VALUE.DEVICE_TAG">&quot;COMP&quot;</spirit:value>
    </spirit:parameter>
    <spirit:parameter>
      <spirit:name>Component_Name</spirit:name>
      <spirit:value spirit:resolve="user" spirit:id="PARAM_VALUE.Component_Name" spirit:order="1">comprehensive_axi_v1_0_0</spirit:value>
    </spirit:parameter>
