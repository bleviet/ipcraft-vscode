#   vivado -mode batch -source comprehensive_avalon_project.tcl
#
# Usage (GUI — File > Run Tcl Script, then select this file):
#   After sourcing, run synthesis via the Flow Navigator or:
#   launch_runs synth_1 -jobs 4
#   wait_on_run synth_1
#   open_run synth_1 -name synth_1
#   report_timing_summary -file timing_summary.rpt
#
# The OOC (out-of-context) synthesis mode treats comprehensive_avalon as a
# standalone module, ignoring parent-level I/O constraints.  This is the
# standard approach for IP core synthesisability and timing verification.

set script_dir   [file normalize [file dirname [info script]]]
set project_name comprehensive_avalon
set project_dir  [file join $script_dir build ooc]
set part         xc7z020clg484-1

# Gracefully handle already open projects to avoid locking errors
if {[current_project -quiet] ne ""} {
    puts "Closing currently open project: [current_project]"
    close_project
}

if {[file exists $project_dir]} {
    puts "Removing existing project directory: $project_dir"
    file delete -force $project_dir
}

puts "=== Creating Vivado OOC project ==="
puts "Project : $project_name"
puts "Part    : $part"
puts "Dir     : $project_dir"

create_project $project_name $project_dir -part $part

# ---- IP Repository -------------------------------------------------------
# Register this directory as an IP repository so block designs can discover
# the generated component.xml when this IP is instantiated.
set_property IP_REPO_PATHS [list $script_dir] [current_project]
update_ip_catalog -rebuild -quiet

# ---- RTL sources --------------------------------------------------------
add_files -fileset sources_1 -norecurse [file normalize [file join $script_dir ../rtl/comprehensive_avalon_pkg.vhd]]
add_files -fileset sources_1 -norecurse [file normalize [file join $script_dir ../rtl/comprehensive_avalon_regs.vhd]]
add_files -fileset sources_1 -norecurse [file normalize [file join $script_dir ../rtl/comprehensive_avalon_core.vhd]]
add_files -fileset sources_1 -norecurse [file normalize [file join $script_dir ../rtl/comprehensive_avalon_avmm.vhd]]
add_files -fileset sources_1 -norecurse [file normalize [file join $script_dir ../rtl/comprehensive_avalon.vhd]]

# Use VHDL-2008 for VHDL source files (skipped when project contains only SystemVerilog)
# Uses FILE_TYPE filter to capture both .vhd and .vhdl safely
set vhd_files [get_files -quiet -filter {FILE_TYPE =~ "VHDL*"}]
if {[llength $vhd_files] > 0} {
    set_property file_type {VHDL 2008} $vhd_files
}

# ---- Constraints ---------------------------------------------------------
add_files -fileset constrs_1 [file normalize [file join $script_dir comprehensive_avalon_ooc.xdc]]

# Mark constraints as out-of-context so they apply during OOC synthesis
# Uses file tail for robust database matching
set xdc_filename [file tail comprehensive_avalon_ooc.xdc]
set xdc_obj [get_files -quiet -of_objects [get_filesets constrs_1] $xdc_filename]
if {$xdc_obj ne ""} {
    set_property USED_IN {out_of_context synthesis} $xdc_obj
} else {
    send_msg_id "IPCraft-002" "WARNING" "Could not locate constraint file $xdc_filename in project."
}

# ---- Synthesis run -------------------------------------------------------
# Configure synth_1 for out-of-context mode
set_property -name {STEPS.SYNTH_DESIGN.ARGS.MORE OPTIONS} \\
    -value {-mode out_of_context} \\
    -objects [get_runs synth_1]

# Set top-level entity
set_property top comprehensive_avalon [current_fileset]
update_compile_order -fileset sources_1

puts ""
puts "Project created at: $project_dir"
puts "Open in GUI  : open_project [file join $project_dir \${project_name}.xpr]"
puts "Run via IPCraft: vivado -mode batch -source \${project_name}_run_ooc.tcl -nojournal -nolog"
