# From ip.yml fileSets
VHDL_SOURCES += $(BASE_DIR)/rtl/system_controller_pkg.vhd
VHDL_SOURCES += $(BASE_DIR)/rtl/system_controller_regs.vhd
VHDL_SOURCES += $(BASE_DIR)/rtl/system_controller_core.vhd
VHDL_SOURCES += $(BASE_DIR)/rtl/system_controller_axil.vhd
VHDL_SOURCES += $(BASE_DIR)/rtl/system_controller.vhd

# Top-level module
TOPLEVEL = system_controller

# Test module (Python file without .py extension)
MODULE = system_controller_test
# Required for Questa/ModelSim: cocotb reads this env var directly inside vsim
export COCOTB_TEST_MODULES = $(MODULE)

# Simulator compile flags
COMPILE_ARGS += --std=08 -frelaxed

# Generate waveforms by default; suppress with WAVES=0
WAVES ?= 1
ifeq ($(WAVES),1)
    SIM_ARGS += --wave=system_controller.ghw
endif

# Cocotb settings
export COCOTB_REDUCED_LOG_FMT=1



# Default target
include $(shell cocotb-config --makefiles)/Makefile.sim

# Additional targets
.PHONY: clean_all view_waves lint

clean_all: clean
	rm -rf sim_build __pycache__ results.xml *.ghw

view_waves:
	gtkwave system_controller.ghw &

lint:
	@echo "Checking VHDL syntax..."
	@for f in $(VHDL_SOURCES); do \\
		echo "  $$f"; \\
		ghdl -a --std=08 $$f || exit 1; \\
	done
	@echo "All files OK"

# Help target
help:
	@echo "cocotb Testbench for system_controller"
	@echo ""
	@echo "Targets:"
	@echo "  make            - Run all tests"
	@echo "  make WAVES=0    - Run tests without generating waveforms"
	@echo "  make view_waves - Open waveforms"
	@echo "  make lint       - Check VHDL syntax (uses GHDL)"
	@echo "  make clean      - Remove simulation build files"
	@echo "  make clean_all  - Remove all generated files"
	@echo ""
	@echo "Options:"
	@echo "  SIM=ghdl|ghdl|questa  - Simulator (default: ghdl)"
	@echo "  WAVES=0                   - Suppress waveform generation (default: 1)"
	@echo "  TESTCASE=test_name        - Run specific test"
	@echo "  COCOTB_LOG_LEVEL=DEBUG    - Verbose logging"
",
  "examples/xcvr_loopback_sv": "# Makefile for cocotb simulation with SystemVerilog — GHDL
# Generated by ipcraft SystemVerilog Generator
#
# Usage:
#   make                    # Run all tests
#   make SIM=ghdl       # Explicitly specify simulator
#   make SIM=icarus         # Use Icarus Verilog
#   make SIM=verilator      # Use Verilator (faster)
#   make WAVES=0            # Suppress waveform generation
#   make TESTCASE=test_xyz  # Run specific test
#
# Prerequisites:
#   - GHDL
#   - cocotb (pip install cocotb)

# Simulator settings
SIM ?= ghdl
TOPLEVEL_LANG ?= verilog

# SystemVerilog source files (relative to tb/ directory)
BASE_DIR = $(CURDIR)/..
# Derived from entity structure
VERILOG_SOURCES += $(BASE_DIR)/rtl/xcvr_loopback.sv

# Top-level module
TOPLEVEL = xcvr_loopback

# Test module (Python file without .py extension)
MODULE = xcvr_loopback_test
# Required for Questa/ModelSim: cocotb reads this env var directly inside vsim
export COCOTB_TEST_MODULES = $(MODULE)

# Icarus Verilog options
ifeq ($(SIM),icarus)
    # Enable SystemVerilog support
    COMPILE_ARGS += -g2012

    # Generate waveforms by default; suppress with WAVES=0
    WAVES ?= 1
    ifeq ($(WAVES),1)
        # dump.v instantiates $dumpfile/$dumpvars to produce a VCD trace
        VERILOG_SOURCES += $(CURDIR)/dump.v
    endif
endif

# Verilator options
ifeq ($(SIM),verilator)
    COMPILE_ARGS += --sv
    COMPILE_ARGS += -Wno-fatal
    WAVES ?= 1
    ifeq ($(WAVES),1)
        COMPILE_ARGS += --trace-fst
    endif
endif

# Cocotb settings
export COCOTB_REDUCED_LOG_FMT=1



# Default target
include $(shell cocotb-config --makefiles)/Makefile.sim

# Additional targets
.PHONY: clean_all view_waves lint

ifeq ($(SIM),icarus)
    WAVE_FILE = xcvr_loopback.vcd
else
    WAVE_FILE = xcvr_loopback.fst
endif

clean_all: clean
	rm -rf sim_build __pycache__ results.xml *.fst *.vcd *.vzt

view_waves:
	gtkwave $(WAVE_FILE) &

lint:
	@echo "Checking SystemVerilog syntax..."
	@for f in $(VERILOG_SOURCES); do \\
		echo "  $$f"; \\
		iverilog -g2012 -tnull $$f || exit 1; \\
	done
	@echo "All files OK"

# Help target
help:
	@echo "cocotb Testbench for xcvr_loopback (SystemVerilog)"
	@echo ""
	@echo "Targets:"
	@echo "  make            - Run all tests"
	@echo "  make WAVES=0    - Run tests without generating waveforms"
	@echo "  make view_waves - Open waveforms in GTKWave"
	@echo "  make lint       - Check SystemVerilog syntax"
	@echo "  make clean      - Remove simulation build files"
	@echo "  make clean_all  - Remove all generated files"
	@echo ""
	@echo "Options:"
	@echo "  SIM=icarus|verilator|modelsim  - Simulator (default: icarus)"
	@echo "  WAVES=0                        - Suppress waveform generation (default: 1)"
	@echo "  TESTCASE=test_name             - Run specific test"
	@echo "  COCOTB_LOG_LEVEL=DEBUG         - Verbose logging"
