    logic [23:0] bytes;  // bits 23:0
  } dma_1_len_t;

  // Pack DMA_1_LEN fields into a 32-bit bus word
  function automatic logic [C_DATA_WIDTH-1:0] pack_dma_1_len(input dma_1_len_t reg_in);
    logic [C_DATA_WIDTH-1:0] slv;
    slv = '0;
    slv[23:0] = reg_in.bytes;
    return slv;
  endfunction

  // Unpack a 32-bit bus word into DMA_1_LEN fields
  function automatic dma_1_len_t unpack_dma_1_len(input logic [C_DATA_WIDTH-1:0] slv);
    dma_1_len_t reg_out;
    reg_out.bytes = slv[23:0];
    return reg_out;
  endfunction

  // DMA_1_CTRL register fields
  typedef struct packed {
    logic        start;  // bit 0
    logic        ie;  // bit 1
    logic        done;  // bit 8
  } dma_1_ctrl_t;

  // Pack DMA_1_CTRL fields into a 32-bit bus word
  function automatic logic [C_DATA_WIDTH-1:0] pack_dma_1_ctrl(input dma_1_ctrl_t reg_in);
    logic [C_DATA_WIDTH-1:0] slv;
    slv = '0;
    slv[0] = reg_in.start;
    slv[1] = reg_in.ie;
    slv[8] = reg_in.done;
    return slv;
  endfunction

  // Unpack a 32-bit bus word into DMA_1_CTRL fields
  function automatic dma_1_ctrl_t unpack_dma_1_ctrl(input logic [C_DATA_WIDTH-1:0] slv);
    dma_1_ctrl_t reg_out;
    reg_out.start = slv[0];
    reg_out.ie = slv[1];
    reg_out.done = slv[8];
    return reg_out;
  endfunction

  // W1C event-pulse struct types (hardware drives a 1-cycle strobe to set a sticky bit)

  // IRQ_EVENT W1C event-pulse fields (external pulse only — CoS fields excluded)
  typedef struct packed {
    logic        done_pulse;  // event strobe → sets IRQ_EVENT.done
    logic        err_pulse;  // event strobe → sets IRQ_EVENT.err
  } irq_event_pulse_t;


  // DMA_0_CTRL W1C event-pulse fields (external pulse only — CoS fields excluded)
  typedef struct packed {
    logic        done_pulse;  // event strobe → sets DMA_0_CTRL.done
  } dma_0_ctrl_pulse_t;


  // DMA_1_CTRL W1C event-pulse fields (external pulse only — CoS fields excluded)
  typedef struct packed {
    logic        done_pulse;  // event strobe → sets DMA_1_CTRL.done
  } dma_1_ctrl_pulse_t;

  // SC event-clear struct types (hardware drives a 1-cycle strobe to clear a bit set by software)

  // CTRL SC event-clear fields
  typedef struct packed {
    logic        soft_rst_clear;  // event strobe → clears CTRL.soft_rst
  } ctrl_clear_t;

  // CoS value-port struct types (live hardware values for change-of-state monitoring)

  // IRQ_EVENT monitored field values
  typedef struct packed {
    logic        link_state;  // monitored by CoS field in IRQ_EVENT
  } irq_event_val_t;

  ////////////////////////////////////////////////////////////////////////////
  // Aggregate Register Structs (for clean port interface)
  ////////////////////////////////////////////////////////////////////////////

  // SW -> HW: Registers written by software, read by hardware
  typedef struct packed {
    ctrl_t ctrl;
    cmd_t cmd;
    scratch_t scratch;
    irq_event_t irq_event;
    ch_gain_0_t ch_gain_0;
    ch_gain_1_t ch_gain_1;
    ch_gain_2_t ch_gain_2;
    ch_gain_3_t ch_gain_3;
    dma_0_src_t dma_0_src;
    dma_0_dst_t dma_0_dst;
    dma_0_len_t dma_0_len;
    dma_0_ctrl_t dma_0_ctrl;
    dma_1_src_t dma_1_src;
    dma_1_dst_t dma_1_dst;
    dma_1_len_t dma_1_len;
    dma_1_ctrl_t dma_1_ctrl;
  } regs_sw2hw_t;

  // HW -> SW: Status registers (RO) + W1C/SC event pulses + CoS value ports
  typedef struct packed {
    id_t id;
    status_t status;
    irq_event_pulse_t irq_event_pulse;  // W1C event pulses for IRQ_EVENT
    dma_0_ctrl_pulse_t dma_0_ctrl_pulse;  // W1C event pulses for DMA_0_CTRL
    dma_1_ctrl_pulse_t dma_1_ctrl_pulse;  // W1C event pulses for DMA_1_CTRL
    ctrl_clear_t ctrl_clear;  // SC event clear pulses for CTRL
    irq_event_val_t irq_event_val;  // live values monitored for CoS in IRQ_EVENT
  } regs_hw2sw_t;

endpackage : comprehensive_axi_pkg
