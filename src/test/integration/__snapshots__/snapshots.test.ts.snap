  <spirit:memoryMaps>
    <spirit:memoryMap>
      <spirit:name>AVMM_CSR</spirit:name>
      <spirit:addressBlock>
        <spirit:name>CSR</spirit:name>
        <spirit:baseAddress spirit:format="long">0</spirit:baseAddress>
        <spirit:range spirit:format="long">20</spirit:range>
        <spirit:width spirit:format="long">32</spirit:width>
        <spirit:usage>register</spirit:usage>
        <spirit:register>
          <spirit:name>VERSION</spirit:name>
          <spirit:description>IP version</spirit:description>
          <spirit:addressOffset>0x0</spirit:addressOffset>
          <spirit:size spirit:format="long">32</spirit:size>
          <spirit:access>read-only</spirit:access>
          <spirit:field>
            <spirit:name>MINOR</spirit:name>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth spirit:format="long">8</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
            <spirit:reset>0x2</spirit:reset>
          </spirit:field>
          <spirit:field>
            <spirit:name>MAJOR</spirit:name>
            <spirit:bitOffset>8</spirit:bitOffset>
            <spirit:bitWidth spirit:format="long">8</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
            <spirit:reset>0x1</spirit:reset>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>CONTROL</spirit:name>
          <spirit:description>Run control</spirit:description>
          <spirit:addressOffset>0x4</spirit:addressOffset>
          <spirit:size spirit:format="long">32</spirit:size>
          <spirit:access>read-write</spirit:access>
          <spirit:field>
            <spirit:name>RUN</spirit:name>
            <spirit:description>Start/stop the stream engine</spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth spirit:format="long">1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>STOP_ON_ERR</spirit:name>
            <spirit:description>Halt on first stream error</spirit:description>
            <spirit:bitOffset>1</spirit:bitOffset>
            <spirit:bitWidth spirit:format="long">1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
            <spirit:reset>0x1</spirit:reset>
          </spirit:field>
          <spirit:field>
            <spirit:name>LOG_LEVEL</spirit:name>
            <spirit:description>Diagnostic verbosity</spirit:description>
            <spirit:bitOffset>4</spirit:bitOffset>
            <spirit:bitWidth spirit:format="long">4</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>CLEAR_STATS</spirit:name>
            <spirit:description>Pulse to clear the sample counters</spirit:description>
            <spirit:bitOffset>31</spirit:bitOffset>
            <spirit:bitWidth spirit:format="long">1</spirit:bitWidth>
            <spirit:access>write-only</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>EVENTS</spirit:name>
          <spirit:description>Sticky events. OVERRUN/UNDERRUN set by hardware pulses; SRC_TOGGLED auto-sets when SRC_ACTIVE changes (monitorChangeOf through the Avalon-MM wrapper).
</spirit:description>
          <spirit:addressOffset>0x8</spirit:addressOffset>
          <spirit:size spirit:format="long">32</spirit:size>
          <spirit:access>read-write</spirit:access>
          <spirit:field>
            <spirit:name>OVERRUN</spirit:name>
            <spirit:description>Sink FIFO overrun (sticky, W1C)</spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth spirit:format="long">1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>UNDERRUN</spirit:name>
            <spirit:description>Source FIFO underrun (sticky, W1C)</spirit:description>
            <spirit:bitOffset>1</spirit:bitOffset>
            <spirit:bitWidth spirit:format="long">1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>SRC_ACTIVE</spirit:name>
            <spirit:description>Live source-channel activity flag</spirit:description>
            <spirit:bitOffset>8</spirit:bitOffset>
            <spirit:bitWidth spirit:format="long">1</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
          <spirit:field>
            <spirit:name>SRC_TOGGLED</spirit:name>
            <spirit:description>Sticky change-of-state flag for SRC_ACTIVE</spirit:description>
            <spirit:bitOffset>9</spirit:bitOffset>
            <spirit:bitWidth spirit:format="long">1</spirit:bitWidth>
            <spirit:access>read-write</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>SAMPLE_CNT_0</spirit:name>
          <spirit:description>Per-direction sample counters (flat array)</spirit:description>
          <spirit:addressOffset>0xC</spirit:addressOffset>
          <spirit:size spirit:format="long">32</spirit:size>
          <spirit:access>read-only</spirit:access>
          <spirit:field>
            <spirit:name>VALUE</spirit:name>
            <spirit:description>Free-running sample count</spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth spirit:format="long">32</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
        </spirit:register>
        <spirit:register>
          <spirit:name>SAMPLE_CNT_1</spirit:name>
          <spirit:description>Per-direction sample counters (flat array)</spirit:description>
          <spirit:addressOffset>0x10</spirit:addressOffset>
          <spirit:size spirit:format="long">32</spirit:size>
          <spirit:access>read-only</spirit:access>
          <spirit:field>
            <spirit:name>VALUE</spirit:name>
            <spirit:description>Free-running sample count</spirit:description>
            <spirit:bitOffset>0</spirit:bitOffset>
            <spirit:bitWidth spirit:format="long">32</spirit:bitWidth>
            <spirit:access>read-only</spirit:access>
          </spirit:field>
        </spirit:register>
      </spirit:addressBlock>
      <spirit:addressBlock>
        <spirit:name>MAILBOX</spirit:name>
        <spirit:baseAddress spirit:format="long">1024</spirit:baseAddress>
        <spirit:range spirit:format="long">4</spirit:range>
        <spirit:width spirit:format="long">32</spirit:width>
        <spirit:usage>memory</spirit:usage>
      </spirit:addressBlock>
    </spirit:memoryMap>
  </spirit:memoryMaps>
