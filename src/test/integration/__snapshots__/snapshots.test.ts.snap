add_interface_port pcie_interface m_axi_pcie_bresp bresp Input 2
add_interface_port pcie_interface m_axi_pcie_bvalid bvalid Input 1
add_interface_port pcie_interface m_axi_pcie_bready bready Output 1
add_interface_port pcie_interface m_axi_pcie_araddr araddr Output 32
add_interface_port pcie_interface m_axi_pcie_arvalid arvalid Output 1
add_interface_port pcie_interface m_axi_pcie_arready arready Input 1
add_interface_port pcie_interface m_axi_pcie_arprot arprot Output 3
add_interface_port pcie_interface m_axi_pcie_rdata rdata Input 32
add_interface_port pcie_interface m_axi_pcie_rresp rresp Input 2
add_interface_port pcie_interface m_axi_pcie_rvalid rvalid Input 1
add_interface_port pcie_interface m_axi_pcie_rready rready Output 1


# Interface: usb_data_in (ipcraft:busif:axi_stream:1.0)
add_interface usb_data_in axi4stream end
set_interface_property usb_data_in associatedClock CLK_SYS
set_interface_property usb_data_in associatedReset RST_SYS
set_interface_property usb_data_in ENABLED true
set_interface_property usb_data_in EXPORT_OF ""
set_interface_property usb_data_in PORT_NAME_MAP ""
set_interface_property usb_data_in CMSIS_SVD_VARIABLES ""
set_interface_property usb_data_in SVD_ADDRESS_GROUP ""

# Type-specific properties

# Ports
add_interface_port usb_data_in s_axis_usb_tdata tdata Input 32
add_interface_port usb_data_in s_axis_usb_tvalid tvalid Input 1
add_interface_port usb_data_in s_axis_usb_tready tready Output 1


# Interface: usb_data_out (ipcraft:busif:axi_stream:1.0)
add_interface usb_data_out axi4stream start
set_interface_property usb_data_out associatedClock CLK_SYS
set_interface_property usb_data_out associatedReset RST_SYS
set_interface_property usb_data_out ENABLED true
set_interface_property usb_data_out EXPORT_OF ""
set_interface_property usb_data_out PORT_NAME_MAP ""
set_interface_property usb_data_out CMSIS_SVD_VARIABLES ""
set_interface_property usb_data_out SVD_ADDRESS_GROUP ""

# Type-specific properties

# Ports
add_interface_port usb_data_out m_axis_usb_tdata tdata Output 32
add_interface_port usb_data_out m_axis_usb_tvalid tvalid Output 1
add_interface_port usb_data_out m_axis_usb_tready tready Input 1



# -----------------------------------------------------------------------------
# Interrupt Interface(s)
# -----------------------------------------------------------------------------
# IRQ_OUT: interrupt sender (out)
add_interface IRQ_OUT interrupt end
set_interface_property IRQ_OUT associatedAddressablePoint ""
set_interface_property IRQ_OUT ENABLED true

add_interface_port IRQ_OUT IRQ_OUT irq Output 1



