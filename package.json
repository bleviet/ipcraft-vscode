{
  "name": "ipcraft-vscode",
  "publisher": "bleviet",
  "license": "MIT",
  "icon": "resources/icon.png",
  "galleryBanner": {
    "color": "#1a1a2e",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/bleviet/ipcraft-vscode"
  },
  "homepage": "https://github.com/bleviet/ipcraft-vscode#readme",
  "bugs": {
    "url": "https://github.com/bleviet/ipcraft-vscode/issues"
  },
  "keywords": [
    "fpga",
    "ip core",
    "memory map",
    "vhdl",
    "rtl",
    "visual editor",
    "yaml",
    "register",
    "bitfield"
  ],
  "displayName": "IPCraft for VS Code",
  "description": "Visual editor for IP Core (IPCraft) and Memory Map specifications",
  "version": "0.2.0",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Programming Languages",
    "Visualization",
    "Other"
  ],
  "activationEvents": [],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "fpga-ip-core.createIpCore",
        "title": "New IP Core",
        "category": "IPCraft"
      },
      {
        "command": "fpga-ip-core.createMemoryMap",
        "title": "New Memory Map",
        "category": "IPCraft"
      },
      {
        "command": "fpga-ip-core.createIpCoreWithMemoryMap",
        "title": "New IP Core + Memory Map",
        "category": "IPCraft"
      },
      {
        "command": "fpga-ip-core.editInIpPackager",
        "title": "Edit in IP Packager",
        "category": "IPCraft",
        "enablement": "ipcraft.vivadoFound"
      },
      {
        "command": "fpga-ip-core.editInPlatformDesigner",
        "title": "Open in Platform Designer",
        "category": "IPCraft",
        "enablement": "ipcraft.qsysEditFound"
      },
      {
        "command": "fpga-ip-core.generateHdl",
        "title": "Generate HDL",
        "category": "IPCraft",
        "icon": "$(code)"
      },
      {
        "command": "fpga-ip-core.scaffoldProject",
        "title": "Scaffold Project",
        "category": "IPCraft",
        "icon": "$(package)"
      },
      {
        "command": "fpga-ip-core.exportAltera",
        "title": "Generate Altera Platform Designer Component (_hw.tcl)",
        "category": "IPCraft",
        "icon": "$(export)"
      },
      {
        "command": "fpga-ip-core.exportXilinx",
        "title": "Generate Xilinx Vivado Component (component.xml)",
        "category": "IPCraft",
        "icon": "$(export)"
      },
      {
        "command": "fpga-ip-core.generateTestbench",
        "title": "Generate CocoTB Testbench",
        "category": "IPCraft",
        "icon": "$(beaker)"
      },
      {
        "command": "fpga-ip-core.generateVivadoProject",
        "title": "Generate Vivado Project",
        "category": "IPCraft",
        "icon": "$(circuit-board)"
      },
      {
        "command": "fpga-ip-core.generateQuartusProject",
        "title": "Generate Quartus Project",
        "category": "IPCraft",
        "icon": "$(circuit-board)"
      },
      {
        "command": "fpga-ip-core.generateAndBuildVivado",
        "title": "Generate & Build (Vivado OOC)",
        "category": "IPCraft",
        "icon": "$(zap)",
        "enablement": "ipcraft.vivadoFound"
      },
      {
        "command": "fpga-ip-core.generateAndBuildQuartus",
        "title": "Generate & Build (Quartus)",
        "category": "IPCraft",
        "icon": "$(zap)",
        "enablement": "ipcraft.quartusFound"
      },
      {
        "command": "fpga-ip-core.buildVivadoOoc",
        "title": "Build: Vivado OOC Synthesis",
        "category": "IPCraft",
        "icon": "$(play)",
        "enablement": "ipcraft.vivadoFound"
      },
      {
        "command": "fpga-ip-core.buildQuartusCompile",
        "title": "Build: Quartus Compile",
        "category": "IPCraft",
        "icon": "$(play)",
        "enablement": "ipcraft.quartusFound"
      },
      {
        "command": "fpga-ip-core.parseVHDL",
        "title": "Import from VHDL (Experimental)",
        "category": "IPCraft",
        "icon": "$(file-code)"
      },
      {
        "command": "fpga-ip-core.parseHwTcl",
        "title": "Import from Altera Platform Designer (Experimental)",
        "category": "IPCraft",
        "icon": "$(file-code)"
      },
      {
        "command": "fpga-ip-core.parseComponentXml",
        "title": "Import from Xilinx Component XML (Experimental)",
        "category": "IPCraft",
        "icon": "$(file-code)"
      },
      {
        "command": "fpga-ip-core.viewBusDefinitions",
        "title": "View Bus Definitions",
        "category": "IPCraft",
        "icon": "$(list-unordered)"
      },
      {
        "command": "fpga-ip-core.scanVivadoCatalog",
        "title": "Scan Vivado IP Catalog",
        "category": "IPCraft",
        "enablement": "ipcraft.vivadoFound"
      },
      {
        "command": "fpga-ip-core.build",
        "title": "Build",
        "category": "IPCraft",
        "icon": "$(play)",
        "enablement": "ipcraft.vivadoFound || ipcraft.quartusFound"
      },
      {
        "command": "fpga-ip-core.showBuildOutput",
        "title": "Show Build Output",
        "category": "IPCraft"
      },
      {
        "command": "fpga-ip-core.openInVivado",
        "title": "Open in Vivado",
        "category": "IPCraft",
        "enablement": "ipcraft.vivadoFound"
      },
      {
        "command": "fpga-ip-core.openInQuartus",
        "title": "Open in Quartus",
        "category": "IPCraft",
        "enablement": "ipcraft.quartusFound"
      },
      {
        "command": "fpga-ip-core.vivadoNotConfigured",
        "title": "Vivado Not Found — Click to Configure",
        "category": "IPCraft",
        "icon": "$(warning)"
      },
      {
        "command": "fpga-ip-core.quartusNotConfigured",
        "title": "Quartus Not Found — Click to Configure",
        "category": "IPCraft",
        "icon": "$(warning)"
      },
      {
        "command": "fpga-ip-core.qsysEditNotConfigured",
        "title": "Platform Designer Not Found — Click to Configure",
        "category": "IPCraft",
        "icon": "$(warning)"
      },
      {
        "command": "fpga-ip-core.buildNotConfigured",
        "title": "No Build Tools Configured — Click to Configure",
        "category": "IPCraft",
        "icon": "$(warning)"
      },
      {
        "command": "fpga-ip-core.openAsText",
        "title": "Open as Text Editor",
        "category": "IPCraft",
        "icon": "$(eye-closed)"
      },
      {
        "command": "fpga-ip-core.openAsVisual",
        "title": "Open as Visual Editor",
        "category": "IPCraft",
        "icon": "$(eye)"
      },
      {
        "command": "fpga-ip-core.previewInIpcraft",
        "title": "Preview in IPCraft (Experimental)",
        "category": "IPCraft",
        "icon": "$(eye)"
      },
      {
        "command": "fpga-ip-core.migrateLegacy",
        "title": "Migrate Legacy IP Cores (vendor: → targets:)",
        "category": "IPCraft"
      }
    ],
    "submenus": [
      {
        "id": "ipcraft.submenu",
        "label": "IPCraft"
      }
    ],
    "menus": {
      "menuBar": [
        {
          "submenu": "ipcraft.submenu",
          "group": "navigation"
        }
      ],
      "ipcraft.submenu": [
        {
          "command": "fpga-ip-core.createIpCore",
          "group": "1_create@1"
        },
        {
          "command": "fpga-ip-core.createMemoryMap",
          "group": "1_create@2"
        },
        {
          "command": "fpga-ip-core.createIpCoreWithMemoryMap",
          "group": "1_create@3"
        },
        {
          "command": "fpga-ip-core.viewBusDefinitions",
          "group": "2_view@1"
        },
        {
          "command": "fpga-ip-core.scaffoldProject",
          "when": "resourceFilename =~ /\\.ip\\.yml$/",
          "group": "3_ipfile@1"
        },
        {
          "command": "fpga-ip-core.exportAltera",
          "when": "resourceFilename =~ /\\.ip\\.yml$/",
          "group": "3_ipfile@2"
        },
        {
          "command": "fpga-ip-core.exportXilinx",
          "when": "resourceFilename =~ /\\.ip\\.yml$/",
          "group": "3_ipfile@3"
        },
        {
          "command": "fpga-ip-core.generateTestbench",
          "when": "resourceFilename =~ /\\.ip\\.yml$/",
          "group": "3_ipfile@4"
        },
        {
          "command": "fpga-ip-core.generateVivadoProject",
          "when": "resourceFilename =~ /\\.ip\\.yml$/",
          "group": "4_build@1"
        },
        {
          "command": "fpga-ip-core.generateQuartusProject",
          "when": "resourceFilename =~ /\\.ip\\.yml$/",
          "group": "4_build@2"
        },
        {
          "command": "fpga-ip-core.build",
          "when": "resourceFilename =~ /\\.ip\\.yml$/ && (ipcraft.vivadoFound || ipcraft.quartusFound)",
          "group": "4_build@3"
        },
        {
          "command": "fpga-ip-core.buildNotConfigured",
          "when": "resourceFilename =~ /\\.ip\\.yml$/ && !ipcraft.vivadoFound && !ipcraft.quartusFound",
          "group": "4_build@3"
        },
        {
          "command": "fpga-ip-core.showBuildOutput",
          "when": "resourceFilename =~ /\\.ip\\.yml$/",
          "group": "4_build@4"
        },
        {
          "command": "fpga-ip-core.editInPlatformDesigner",
          "when": "resourceFilename =~ /_hw\\.tcl$/ && ipcraft.qsysEditFound",
          "group": "5_import@1"
        },
        {
          "command": "fpga-ip-core.qsysEditNotConfigured",
          "when": "resourceFilename =~ /_hw\\.tcl$/ && !ipcraft.qsysEditFound",
          "group": "5_import@1"
        },
        {
          "command": "fpga-ip-core.editInIpPackager",
          "when": "resourceFilename == component.xml && ipcraft.vivadoFound",
          "group": "5_import@2"
        },
        {
          "command": "fpga-ip-core.vivadoNotConfigured",
          "when": "resourceFilename == component.xml && !ipcraft.vivadoFound",
          "group": "5_import@2"
        },
        {
          "command": "fpga-ip-core.openInVivado",
          "when": "resourceExtname == .xpr && ipcraft.vivadoFound",
          "group": "5_import@6"
        },
        {
          "command": "fpga-ip-core.vivadoNotConfigured",
          "when": "resourceExtname == .xpr && !ipcraft.vivadoFound",
          "group": "5_import@6"
        },
        {
          "command": "fpga-ip-core.openInQuartus",
          "when": "resourceExtname == .qpf && ipcraft.quartusFound",
          "group": "5_import@7"
        },
        {
          "command": "fpga-ip-core.quartusNotConfigured",
          "when": "resourceExtname == .qpf && !ipcraft.quartusFound",
          "group": "5_import@7"
        }
      ],
      "editor/title": [
        {
          "command": "fpga-ip-core.scaffoldProject",
          "when": "resourceFilename =~ /\\.ip\\.yml$/",
          "group": "ipcraft@1"
        },
        {
          "command": "fpga-ip-core.exportAltera",
          "when": "resourceFilename =~ /\\.ip\\.yml$/",
          "group": "ipcraft@2"
        },
        {
          "command": "fpga-ip-core.exportXilinx",
          "when": "resourceFilename =~ /\\.ip\\.yml$/",
          "group": "ipcraft@3"
        },
        {
          "command": "fpga-ip-core.generateTestbench",
          "when": "resourceFilename =~ /\\.ip\\.yml$/",
          "group": "ipcraft@4"
        },
        {
          "command": "fpga-ip-core.generateVivadoProject",
          "when": "resourceFilename =~ /\\.ip\\.yml$/",
          "group": "ipcraft@5"
        },
        {
          "command": "fpga-ip-core.generateQuartusProject",
          "when": "resourceFilename =~ /\\.ip\\.yml$/",
          "group": "ipcraft@5"
        },
        {
          "command": "fpga-ip-core.build",
          "when": "resourceFilename =~ /\\.ip\\.yml$/ && (ipcraft.vivadoFound || ipcraft.quartusFound)",
          "group": "ipcraft@6"
        },
        {
          "command": "fpga-ip-core.buildNotConfigured",
          "when": "resourceFilename =~ /\\.ip\\.yml$/ && !ipcraft.vivadoFound && !ipcraft.quartusFound",
          "group": "ipcraft@6"
        },
        {
          "command": "fpga-ip-core.editInPlatformDesigner",
          "when": "resourceFilename =~ /_hw\\.tcl$/ && ipcraft.qsysEditFound",
          "group": "navigation"
        },
        {
          "command": "fpga-ip-core.qsysEditNotConfigured",
          "when": "resourceFilename =~ /_hw\\.tcl$/ && !ipcraft.qsysEditFound",
          "group": "navigation"
        },
        {
          "command": "fpga-ip-core.editInIpPackager",
          "when": "resourceFilename == component.xml && ipcraft.vivadoFound",
          "group": "navigation"
        },
        {
          "command": "fpga-ip-core.vivadoNotConfigured",
          "when": "resourceFilename == component.xml && !ipcraft.vivadoFound",
          "group": "navigation"
        },
        {
          "command": "fpga-ip-core.openInVivado",
          "when": "resourceExtname == .xpr && ipcraft.vivadoFound",
          "group": "navigation"
        },
        {
          "command": "fpga-ip-core.vivadoNotConfigured",
          "when": "resourceExtname == .xpr && !ipcraft.vivadoFound",
          "group": "navigation"
        },
        {
          "command": "fpga-ip-core.openInQuartus",
          "when": "resourceExtname == .qpf && ipcraft.quartusFound",
          "group": "navigation"
        },
        {
          "command": "fpga-ip-core.quartusNotConfigured",
          "when": "resourceExtname == .qpf && !ipcraft.quartusFound",
          "group": "navigation"
        },
        {
          "command": "fpga-ip-core.openAsText",
          "when": "activeCustomEditorId == 'fpgaIpCore.editor' || activeCustomEditorId == 'fpgaMemoryMap.editor' || activeCustomEditorId == 'fpgaIpCore.sourcePreview'",
          "group": "navigation"
        },
        {
          "command": "fpga-ip-core.previewInIpcraft",
          "when": "resourceFilename =~ /_hw\\.tcl$/ && activeCustomEditorId != 'fpgaIpCore.sourcePreview'",
          "group": "navigation"
        },
        {
          "command": "fpga-ip-core.previewInIpcraft",
          "when": "resourceFilename == component.xml && activeCustomEditorId != 'fpgaIpCore.sourcePreview'",
          "group": "navigation"
        },
        {
          "command": "fpga-ip-core.previewInIpcraft",
          "when": "resourceExtname == .vhd && activeCustomEditorId != 'fpgaIpCore.sourcePreview' || resourceExtname == .vhdl && activeCustomEditorId != 'fpgaIpCore.sourcePreview' || resourceExtname == .v && activeCustomEditorId != 'fpgaIpCore.sourcePreview' || resourceExtname == .sv && activeCustomEditorId != 'fpgaIpCore.sourcePreview'",
          "group": "navigation"
        },
        {
          "command": "fpga-ip-core.openAsVisual",
          "when": "resourceFilename =~ /\\.ip\\.yml$/ && !activeCustomEditorId || resourceFilename =~ /\\.mm\\.yml$/ && !activeCustomEditorId",
          "group": "navigation"
        }
      ]
    },
    "configuration": [
      {
        "title": "General",
        "properties": {
          "ipcraft.busLibraryPaths": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "markdownDescription": "Paths to search recursively for custom bus definition YAML files (`.yml` / `.yaml`). Absolute paths or paths relative to the workspace root. Files ending in `.ip.yml` or `.mm.yml` are ignored."
          },
          "ipcraft.ipRepositoryPaths": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "markdownDescription": "Additional file system paths to scan for IP cores (directories containing `.ip.yml` or `component.xml` files)."
          }
        }
      },
      {
        "title": "Scaffold & Generate",
        "properties": {
          "ipcraft.generate.targets": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [],
            "markdownDescription": "Synthesis vendor targets to generate packaging files for. Each entry must match a registered toolchain id (e.g. `vivado`, `quartus`). An empty array generates HDL and testbench only."
          },
          "ipcraft.generate.includeTestbench": {
            "type": "boolean",
            "default": true,
            "description": "Generate a cocotb testbench (tb/ folder) when scaffolding a project."
          },
          "ipcraft.generate.hdlLanguage": {
            "type": "string",
            "enum": [
              "vhdl",
              "systemverilog"
            ],
            "enumDescriptions": [
              "VHDL — generates .vhd source files",
              "SystemVerilog — generates .sv source files"
            ],
            "default": "vhdl",
            "description": "HDL language for RTL file generation (VHDL or SystemVerilog)."
          },
          "ipcraft.generate.bahonaviMethodology": {
            "type": "boolean",
            "default": false,
            "markdownDescription": "Enable the **bahonavi methodology**: generates the full multi-file HDL structure (top, core, bus wrapper, package, register file). When disabled (default), only a single minimal top-level stub is generated — ideal for beginners and for manually-structured designs."
          }
        }
      },
      {
        "title": "Testbench",
        "properties": {
          "ipcraft.testbench.framework": {
            "type": "string",
            "enum": [
              "cocotb",
              "vunit"
            ],
            "enumDescriptions": [
              "Generate a CocoTB testbench (Makefile + Python test)",
              "Generate a VUnit testbench (run.py + VHDL testbench entity)"
            ],
            "default": "cocotb",
            "description": "Testbench framework used by 'Generate CocoTB Testbench'."
          },
          "ipcraft.testbench.engine": {
            "type": "string",
            "enum": [
              "ghdl",
              "icarus",
              "verilator",
              "questa"
            ],
            "enumDescriptions": [
              "GHDL — open-source VHDL simulator (--std=08)",
              "Icarus Verilog — open-source Verilog/SV simulator",
              "Verilator — high-performance SV simulator",
              "Questa / ModelSim — commercial VHDL/SV simulator"
            ],
            "default": "ghdl",
            "description": "Simulation engine used by the generated testbench."
          }
        }
      },
      {
        "title": "Toolbar",
        "properties": {
          "ipcraft.toolbar.targets": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "default": [
              "vivado",
              "quartus"
            ],
            "markdownDescription": "Which vendor toolchain sections to display in the IP Core editor toolbar. Each entry must match a registered toolchain id (e.g. `vivado`, `quartus`)."
          }
        }
      },
      {
        "title": "Import",
        "properties": {
          "ipcraft.import.vendor": {
            "type": "string",
            "default": "user",
            "description": "Vendor name used when importing IP cores (VHDL, hw.tcl, component.xml). Leave blank or 'user' to auto-detect from git user.email (e.g. user@company.com → company.com), falling back to 'ipcraft'.",
            "markdownDescription": "Vendor name used when importing IP cores (VHDL, `_hw.tcl`, `component.xml`). Leave blank or `user` to auto-detect from git `user.email` (e.g. `user@company.com` → `company.com`), falling back to `ipcraft`."
          },
          "ipcraft.import.library": {
            "type": "string",
            "default": "ip",
            "description": "Default library name used when importing a VHDL file as an IP Core."
          },
          "ipcraft.import.version": {
            "type": "string",
            "default": "1.0.0",
            "description": "Default version string used when importing a VHDL file as an IP Core."
          }
        }
      },
      {
        "title": "Vivado (Xilinx/AMD)",
        "properties": {
          "ipcraft.vivado.runner": {
            "type": "string",
            "enum": [
              "local",
              "docker"
            ],
            "enumDescriptions": [
              "Use a locally installed Vivado. Configure ipcraft.vivado.installDir.",
              "Run Vivado inside a Docker container. Configure ipcraft.vivado.dockerImage."
            ],
            "default": "local",
            "description": "How IPCraft executes Vivado commands. 'local' uses a native install; 'docker' runs every command inside a container."
          },
          "ipcraft.vivado.installDir": {
            "type": "string",
            "default": "",
            "markdownDescription": "_(Used when `runner` is `local`)_ Path to your Vivado installation directory. IPCraft will locate the correct executable automatically.\n\n**Linux:** `/tools/Xilinx/Vivado/2024.2`\n\n**Windows:** `C:\\Xilinx\\2025.1\\Vivado`\n\nLeave empty to use `vivado` from your system PATH."
          },
          "ipcraft.vivado.dockerImage": {
            "type": "string",
            "default": "",
            "markdownDescription": "_(Used when `runner` is `docker`)_ Docker image used to run Vivado (e.g. `cvsoc/vivado:2024.2`). Every Vivado command is executed inside this container via `docker run --rm`, with the IP core directory mounted as `/work`."
          },
          "ipcraft.vivado.defaultPart": {
            "type": "string",
            "default": "xc7z020clg484-1",
            "markdownDescription": "Fallback part number used when no board has been selected yet. The board picker remembers the last-used selection across sessions, so this setting rarely needs to be changed manually."
          },
          "ipcraft.customBoards.vivado": {
            "type": "array",
            "default": [],
            "markdownDescription": "Your own boards for Vivado. Each entry appears at the top of the board picker under **My Boards**.",
            "items": {
              "type": "object",
              "required": [
                "label",
                "part"
              ],
              "additionalProperties": false,
              "properties": {
                "label": {
                  "type": "string",
                  "description": "Display name shown in the board picker (e.g. My Zynq Module)"
                },
                "part": {
                  "type": "string",
                  "description": "Xilinx/AMD part number (e.g. xc7z020clg484-1)"
                }
              }
            }
          }
        }
      },
      {
        "title": "Quartus (Intel/Altera)",
        "properties": {
          "ipcraft.quartus.runner": {
            "type": "string",
            "enum": [
              "local",
              "docker"
            ],
            "enumDescriptions": [
              "Use a locally installed Quartus. Configure ipcraft.quartus.installDir.",
              "Run Quartus inside a Docker container. Configure ipcraft.quartus.dockerImage."
            ],
            "default": "local",
            "description": "How IPCraft executes Quartus commands. 'local' uses a native install; 'docker' runs every command inside a container."
          },
          "ipcraft.quartus.installDir": {
            "type": "string",
            "default": "",
            "markdownDescription": "_(Used when `runner` is `local`)_ Top-level Quartus installation directory (e.g. `/opt/intelFPGA_pro/23.1` on Linux or `C:\\intelFPGA_pro\\23.1` on Windows). When set, IPCraft automatically locates `quartus_sh`, `quartus`, and `qsys-edit` inside the installation, searching `quartus/bin` (Linux) or `quartus/bin64` (Windows) first. Supersedes the individual `shellPath`, `guiPath`, and `qsysEditPath` settings."
          },
          "ipcraft.quartus.dockerImage": {
            "type": "string",
            "default": "",
            "markdownDescription": "_(Used when `runner` is `docker`)_ Docker image used to run Quartus (e.g. `cvsoc/quartus:23.1`). Every Quartus command is executed inside this container via `docker run --rm`, with the IP core directory mounted as `/work`."
          },
          "ipcraft.quartus.defaultDevice": {
            "type": "string",
            "default": "5CSEBA6U23I7",
            "markdownDescription": "Fallback device number used when no board has been selected yet. The board picker remembers the last-used selection across sessions, so this setting rarely needs to be changed manually."
          },
          "ipcraft.customBoards.quartus": {
            "type": "array",
            "default": [],
            "markdownDescription": "Your own boards for Quartus. Each entry appears at the top of the board picker under **My Boards**.",
            "items": {
              "type": "object",
              "required": [
                "label",
                "device"
              ],
              "additionalProperties": false,
              "properties": {
                "label": {
                  "type": "string",
                  "description": "Display name shown in the board picker (e.g. My Cyclone V Board)"
                },
                "device": {
                  "type": "string",
                  "description": "Intel/Altera device part number (e.g. 5CSEBA6U23I7)"
                }
              }
            }
          }
        }
      },
      {
        "title": "Build",
        "properties": {
          "ipcraft.build.jobs": {
            "type": "number",
            "default": 4,
            "minimum": 1,
            "description": "Number of parallel jobs passed to Vivado launch_runs and Quartus compilation."
          }
        }
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "fpga-ip-core.reportsView",
          "name": "IPCraft Build"
        }
      ]
    },
    "customEditors": [
      {
        "viewType": "fpgaMemoryMap.editor",
        "displayName": "Memory Map Visual Editor",
        "selector": [
          {
            "filenamePattern": "*.mm.yml"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "fpgaIpCore.editor",
        "displayName": "IP Core Visual Editor",
        "selector": [
          {
            "filenamePattern": "*.ip.yml"
          }
        ],
        "priority": "default"
      },
      {
        "viewType": "fpgaIpCore.sourcePreview",
        "displayName": "IPCraft Source Preview",
        "selector": [
          {
            "filenamePattern": "*_hw.tcl"
          },
          {
            "filenamePattern": "component.xml"
          },
          {
            "filenamePattern": "*.vhd"
          },
          {
            "filenamePattern": "*.vhdl"
          },
          {
            "filenamePattern": "*.v"
          },
          {
            "filenamePattern": "*.sv"
          }
        ],
        "priority": "option"
      }
    ],
    "keybindings": [
      {
        "command": "fpga-ip-core.previewInIpcraft",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "!terminalFocus && (resourceExtname == .vhd && activeCustomEditorId != 'fpgaIpCore.sourcePreview' || resourceExtname == .vhdl && activeCustomEditorId != 'fpgaIpCore.sourcePreview' || resourceExtname == .v && activeCustomEditorId != 'fpgaIpCore.sourcePreview' || resourceExtname == .sv && activeCustomEditorId != 'fpgaIpCore.sourcePreview' || resourceFilename =~ /_hw\\.tcl$/ && activeCustomEditorId != 'fpgaIpCore.sourcePreview' || resourceFilename == component.xml && activeCustomEditorId != 'fpgaIpCore.sourcePreview')"
      },
      {
        "command": "fpga-ip-core.openAsVisual",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "!terminalFocus && (resourceFilename =~ /\\.ip\\.yml$/ && !activeCustomEditorId || resourceFilename =~ /\\.mm\\.yml$/ && !activeCustomEditorId)"
      },
      {
        "command": "fpga-ip-core.openAsText",
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "when": "!terminalFocus && (activeCustomEditorId == 'fpgaIpCore.editor' || activeCustomEditorId == 'fpgaMemoryMap.editor' || activeCustomEditorId == 'fpgaIpCore.sourcePreview')"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run package",
    "compile": "webpack --config config/webpack.config.js",
    "watch": "webpack --watch --config config/webpack.config.js",
    "package": "webpack --mode production --devtool hidden-source-map --config config/webpack.config.js",
    "compile-tests": "tsc -p . --outDir out",
    "watch-tests": "tsc -p . -w --outDir out",
    "pretest": "npm run compile-tests && npm run compile && npm run lint",
    "lint": "eslint src --max-warnings 0",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "type-check": "tsc --noEmit",
    "test": "npm run test:unit",
    "test:unit": "jest --config config/jest.config.js",
    "test:unit:watch": "jest --watch --config config/jest.config.js",
    "test:unit:coverage": "jest --coverage --config config/jest.config.js",
    "test:e2e": "node ./out/test/e2e/runTests.js",
    "test:browser": "playwright test --config config/playwright.config.ts",
    "test:integration": "jest --config config/jest.integration.js",
    "test:integration:vivado": "jest --config config/jest.integration.js --testPathPatterns=vivado",
    "test:integration:quartus": "jest --config config/jest.integration.js --testPathPatterns=quartus",
    "test:all": "npm run test:unit && npm run test:e2e && npm run test:browser",
    "generate-types": "json2ts -i node_modules/ipcraft-spec/schemas/memory_map.schema.json -o src/webview/types/memoryMap.d.ts && json2ts -i node_modules/ipcraft-spec/schemas/ip_core.schema.json -o src/webview/types/ipCore.d.ts",
    "prepare": "husky install"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^14.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/glob": "^8.1.0",
    "@types/jest": "^30.0.0",
    "@types/js-yaml": "^4.0.9",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.19.33",
    "@types/nunjucks": "^3.2.6",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "@types/vscode": "^1.80.0",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "@vscode/test-electron": "^2.3.2",
    "@vscode/vsce": "^3.7.1",
    "autoprefixer": "^10.4.24",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^7.1.4",
    "eslint": "^10.0.1",
    "glob": "^8.1.0",
    "husky": "^8.0.3",
    "identity-obj-proxy": "^3.0.0",
    "ipcraft-spec": "file:./ipcraft-spec",
    "jest": "^30.3.0",
    "jest-environment-jsdom": "^30.3.0",
    "json-schema-to-typescript": "^13.0.0",
    "lint-staged": "^15.5.2",
    "mini-css-extract-plugin": "^2.10.0",
    "mocha": "^11.7.5",
    "playwright": "^1.58.2",
    "postcss": "^8.5.6",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.7.4",
    "style-loader": "^4.0.0",
    "tailwindcss": "^3.4.19",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.4.3",
    "typescript": "^5.1.3",
    "webpack": "^5.85.0",
    "webpack-cli": "^5.1.1"
  },
  "dependencies": {
    "@vscode/codicons": "^0.0.33",
    "@vscode/webview-ui-toolkit": "^1.2.2",
    "@xmldom/xmldom": "^0.9.10",
    "ajv": "^8.20.0",
    "js-yaml": "^4.1.0",
    "nunjucks": "^3.2.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "yaml": "^2.8.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ]
  },
  "overrides": {
    "mocha": {
      "diff": "^9.0.0",
      "serialize-javascript": "^7.0.5"
    },
    "brace-expansion@<1.1.13": "1.1.14"
  }
}
