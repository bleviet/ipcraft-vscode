# Makefile for cocotb simulation — GHDL
# Generated by ipcraft VHDL Generator
#
# Usage:
#   make                    # Run all tests
#   make SIM=ghdl       # Explicitly specify simulator
#   make WAVES=0            # Suppress waveform generation
#   make TESTCASE=test_xyz  # Run specific test
#
# Prerequisites:
#   - GHDL
#   - cocotb (pip install cocotb)

# Simulator settings
SIM ?= ghdl
TOPLEVEL_LANG ?= vhdl

# VHDL source files (relative to tb/ directory)
BASE_DIR = $(CURDIR)/..
# From ip.yml fileSets
VHDL_SOURCES += $(BASE_DIR)/rtl/led_controller_avmm_pkg.vhd
VHDL_SOURCES += $(BASE_DIR)/rtl/led_controller_avmm_regs.vhd
VHDL_SOURCES += $(BASE_DIR)/rtl/led_controller_avmm_core.vhd
VHDL_SOURCES += $(BASE_DIR)/rtl/led_controller_avmm_avmm.vhd
VHDL_SOURCES += $(BASE_DIR)/rtl/led_controller_avmm.vhd

# Top-level module
TOPLEVEL = led_controller_avmm

# Test module (Python file without .py extension)
MODULE = led_controller_avmm_test
# Required for Questa/ModelSim: cocotb reads this env var directly inside vsim
export COCOTB_TEST_MODULES = $(MODULE)

# Simulator compile flags
EXTRA_ARGS += --std=08 -frelaxed

# Generate waveforms by default; suppress with WAVES=0
WAVES ?= 1
ifeq ($(WAVES),1)
    SIM_ARGS += --wave=led_controller_avmm.ghw
endif

# Cocotb settings
export COCOTB_REDUCED_LOG_FMT=1



# Default target
include $(shell cocotb-config --makefiles)/Makefile.sim

# Additional targets
.PHONY: clean_all view_waves lint

clean_all: clean
	rm -rf sim_build __pycache__ results.xml *.ghw

view_waves:
	gtkwave led_controller_avmm.ghw &

lint:
	@echo "Checking VHDL syntax..."
	@for f in $(VHDL_SOURCES); do \
		echo "  $$f"; \
		ghdl -a --std=08 $$f || exit 1; \
	done
	@echo "All files OK"

# Help target
help:
	@echo "cocotb Testbench for led_controller_avmm"
	@echo ""
	@echo "Targets:"
	@echo "  make            - Run all tests"
	@echo "  make WAVES=0    - Run tests without generating waveforms"
	@echo "  make view_waves - Open waveforms"
	@echo "  make lint       - Check VHDL syntax (uses GHDL)"
	@echo "  make clean      - Remove simulation build files"
	@echo "  make clean_all  - Remove all generated files"
	@echo ""
	@echo "Options:"
	@echo "  SIM=ghdl|ghdl|questa  - Simulator (default: ghdl)"
	@echo "  WAVES=0                   - Suppress waveform generation (default: 1)"
	@echo "  TESTCASE=test_name        - Run specific test"
	@echo "  COCOTB_LOG_LEVEL=DEBUG    - Verbose logging"
